<script>
document.addEventListener('DOMContentLoaded', function() {
    // Pagination functionality
    const pageBtns = document.querySelectorAll('.page-btn');
    const prevBtn = document.querySelector('.page-btn.prev');
    const nextBtn = document.querySelector('.page-btn.next');
    const currentPage = document.querySelector('.current-page');
    const totalPages = document.querySelector('.total-pages');
    
    let currentPageNum = 1;
    const totalPageNum = 3;
    
    function updatePagination() {
        currentPage.textContent = `Trang ${currentPageNum}`;
        totalPages.textContent = `/ ${totalPageNum}`;
        
        // Update active state
        document.querySelectorAll('.page-numbers .page-btn').forEach((btn, index) => {
            btn.classList.toggle('active', index + 1 === currentPageNum);
        });
        
        // Update prev/next buttons
        prevBtn.disabled = currentPageNum === 1;
        nextBtn.disabled = currentPageNum === totalPageNum;
    }
    
    pageBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            if (btn.classList.contains('prev') && currentPageNum > 1) {
                currentPageNum--;
            } else if (btn.classList.contains('next') && currentPageNum < totalPageNum) {
                currentPageNum++;
            } else if (btn.classList.contains('active')) {
                currentPageNum = parseInt(btn.textContent);
            }
            
            updatePagination();
            // Add your page change logic here
        });
    });
    
    // Wishlist functionality
    document.querySelectorAll('.wishlist-btn').forEach(button => {
        button.addEventListener('click', (e) => {
            e.preventDefault();
            button.classList.toggle('active');
            const icon = button.querySelector('i');
            if (button.classList.contains('active')) {
                icon.classList.remove('far');
                icon.classList.add('fas');
                icon.style.color = '#ff4757';
            } else {
                icon.classList.remove('fas');
                icon.classList.add('far');
                icon.style.color = '';
            }
        });
    });
    
    // Add to cart functionality
    document.querySelectorAll('.add-to-cart').forEach(button => {
        button.addEventListener('click', (e) => {
            e.preventDefault();
            const card = button.closest('.product-card');
            const productName = card.querySelector('.product-name').textContent;
            
            // Add animation
            button.innerHTML = '<i class="fas fa-check"></i> Đã thêm';
            button.style.background = '#2ed573';
            
            setTimeout(() => {
                button.innerHTML = '<i class="fas fa-shopping-cart"></i> Thêm vào giỏ';
                button.style.background = '#00aeff';
            }, 2000);
            
            // Add your cart logic here
        });
    });
});
</script>


