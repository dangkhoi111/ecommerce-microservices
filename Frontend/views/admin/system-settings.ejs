                        <form class="space-y-6">
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-3">
                                    Thông báo qua email
                                </label>
                                <div class="space-y-3">
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="checkbox" checked class="w-5 h-5 text-orange-500 dark:text-yellow-500 bg-slate-100 dark:bg-neutral-800 border-slate-300 dark:border-neutral-700 rounded focus:ring-orange-500 dark:focus:ring-yellow-500 focus:ring-2">
                                        <span class="text-slate-700 dark:text-neutral-300">Đơn hàng mới</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="checkbox" checked class="w-5 h-5 text-orange-500 dark:text-yellow-500 bg-slate-100 dark:bg-neutral-800 border-slate-300 dark:border-neutral-700 rounded focus:ring-orange-500 dark:focus:ring-yellow-500 focus:ring-2">
                                        <span class="text-slate-700 dark:text-neutral-300">Cập nhật trạng thái đơn hàng</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="checkbox" checked class="w-5 h-5 text-orange-500 dark:text-yellow-500 bg-slate-100 dark:bg-neutral-800 border-slate-300 dark:border-neutral-700 rounded focus:ring-orange-500 dark:focus:ring-yellow-500 focus:ring-2">
                                        <span class="text-slate-700 dark:text-neutral-300">Đăng ký gian hàng mới</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="checkbox" checked class="w-5 h-5 text-orange-500 dark:text-yellow-500 bg-slate-100 dark:bg-neutral-800 border-slate-300 dark:border-neutral-700 rounded focus:ring-orange-500 dark:focus:ring-yellow-500 focus:ring-2">
                                        <span class="text-slate-700 dark:text-neutral-300">Báo cáo vi phạm</span>
                                    </label>
                                </div>
                            </div>
                            
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-3">
                                    Thông báo hệ thống
                                </label>
                                <div class="space-y-3">
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="checkbox" checked class="w-5 h-5 text-orange-500 dark:text-yellow-500 bg-slate-100 dark:bg-neutral-800 border-slate-300 dark:border-neutral-700 rounded focus:ring-orange-500 dark:focus:ring-yellow-500 focus:ring-2">
                                        <span class="text-slate-700 dark:text-neutral-300">Bảo trì hệ thống</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="checkbox" checked class="w-5 h-5 text-orange-500 dark:text-yellow-500 bg-slate-100 dark:bg-neutral-800 border-slate-300 dark:border-neutral-700 rounded focus:ring-orange-500 dark:focus:ring-yellow-500 focus:ring-2">
                                        <span class="text-slate-700 dark:text-neutral-300">Cập nhật tính năng mới</span>
                                    </label>
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        <input type="checkbox" checked class="w-5 h-5 text-orange-500 dark:text-yellow-500 bg-slate-100 dark:bg-neutral-800 border-slate-300 dark:border-neutral-700 rounded focus:ring-orange-500 dark:focus:ring-yellow-500 focus:ring-2">
                                        <span class="text-slate-700 dark:text-neutral-300">Khuyến mãi đặc biệt</span>
                                    </label>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Security Settings -->
                <div class="bg-white dark:bg-neutral-900 rounded-2xl shadow-lg shadow-orange-500/5 dark:shadow-yellow-500/5 border border-slate-200 dark:border-neutral-800 p-6">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-red-500 to-pink-500 flex items-center justify-center">
                            <i class="fas fa-shield-alt text-white"></i>
                        </div>
                        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Cài đặt bảo mật</h2>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-3">
                                Xác thực đăng nhập
                            </label>
                            <div class="space-y-3">
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" checked class="w-5 h-5 text-orange-500 dark:text-yellow-500 bg-slate-100 dark:bg-neutral-800 border-slate-300 dark:border-neutral-700 rounded focus:ring-orange-500 dark:focus:ring-yellow-500 focus:ring-2">
                                    <span class="text-slate-700 dark:text-neutral-300">Xác thực 2 yếu tố (2FA)</span>
                                </label>
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" checked class="w-5 h-5 text-orange-500 dark:text-yellow-500 bg-slate-100 dark:bg-neutral-800 border-slate-300 dark:border-neutral-700 rounded focus:ring-orange-500 dark:focus:ring-yellow-500 focus:ring-2">
                                    <span class="text-slate-700 dark:text-neutral-300">Giới hạn đăng nhập</span>
                                </label>
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" class="w-5 h-5 text-orange-500 dark:text-yellow-500 bg-slate-100 dark:bg-neutral-800 border-slate-300 dark:border-neutral-700 rounded focus:ring-orange-500 dark:focus:ring-yellow-500 focus:ring-2">
                                    <span class="text-slate-700 dark:text-neutral-300">Đăng nhập bằng Google</span>
                                </label>
                            </div>
                        </div>
                        
                        <div>
                            <label for="sessionTimeout" class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-2">
                                Thời gian hết hạn phiên (phút)
                            </label>
                            <input type="number" id="sessionTimeout" min="5" max="480" class="w-full px-4 py-3 border border-slate-300 dark:border-neutral-700 rounded-xl bg-slate-50 dark:bg-neutral-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-orange-500 dark:focus:ring-yellow-500 focus:border-transparent transition-all" value="30">
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex items-center justify-end gap-4">
                    <button class="px-6 py-3 border border-slate-300 dark:border-neutral-700 rounded-xl bg-white dark:bg-neutral-800 text-slate-700 dark:text-neutral-300 hover:bg-slate-50 dark:hover:bg-neutral-700 transition-colors font-medium">
                        <i class="fas fa-undo mr-2"></i>
                        Đặt lại
                    </button>
                    <button class="px-8 py-3 bg-gradient-to-r from-orange-500 to-yellow-500 dark:from-yellow-500 dark:to-yellow-400 text-white dark:text-black font-bold rounded-xl shadow-lg shadow-orange-500/25 dark:shadow-yellow-500/25 hover:shadow-xl hover:shadow-orange-500/40 dark:hover:shadow-yellow-500/40 hover:-translate-y-0.5 transition-all duration-200">
                        <i class="fas fa-save mr-2"></i>
                        Lưu thay đổi
                    </button>
                </div>
            </div>
        </main>
    </div>
    
    <script>
        const token = localStorage.getItem('authToken');
        if (!token) {
            window.location.href = '/admin/login';
        }

        function logout() {
            localStorage.removeItem('authToken');
            localStorage.removeItem('userInfo');
            localStorage.removeItem('hoTen');
            window.location.href = '/';
        }

        // Update admin username
        document.addEventListener('DOMContentLoaded', function() {
            const userName = 'Admin';
            try {
                const userInfo = localStorage.getItem('userInfo');
                if (userInfo) {
                    const userObj = JSON.parse(userInfo);
                    if (userObj.hoTen) userName = userObj.hoTen;
                    else if (userObj.name) userName = userObj.name;
                } else if (localStorage.getItem('hoTen')) {
                    userName = localStorage.getItem('hoTen');
                }
            } catch(e) {}
            const el = document.getElementById('admin-username');
            if (el) el.textContent = userName;
        });

        // Save settings functionality
        function saveSettings() {
            // Collect all form data
            const settings = {
                general: {
                    siteName: document.getElementById('siteName').value,
                    siteDescription: document.getElementById('siteDescription').value,
                    siteEmail: document.getElementById('siteEmail').value,
                    sitePhone: document.getElementById('sitePhone').value
                },
                payment: {
                    methods: Array.from(document.querySelectorAll('input[type="checkbox"]:checked')).map(cb => cb.nextElementSibling.textContent),
                    commission: document.getElementById('commission').value
                },
                shipping: {
                    carriers: Array.from(document.querySelectorAll('input[type="checkbox"]:checked')).map(cb => cb.nextElementSibling.textContent),
                    shippingFee: document.getElementById('shippingFee').value,
                    freeShipping: document.getElementById('freeShipping').value
                },
                security: {
                    sessionTimeout: document.getElementById('sessionTimeout').value
                }
            };

            // Here you would typically send the settings to your backend
            console.log('Saving settings:', settings);
            
            // Show success message
            alert('Cài đặt đã được lưu thành công!');
        }

        // Add event listeners
        document.addEventListener('DOMContentLoaded', function() {
            // Add save functionality to the save button
            const saveButton = document.querySelector('button:has(.fa-save)');
            if (saveButton) {
                saveButton.addEventListener('click', saveSettings);
            }

            // Add reset functionality
            const resetButton = document.querySelector('button:has(.fa-undo)');
            if (resetButton) {
                resetButton.addEventListener('click', function() {
                    if (confirm('Bạn có chắc chắn muốn đặt lại tất cả cài đặt?')) {
                        location.reload();
                    }
                });
            }
        });
    </script>
</body>
</html>