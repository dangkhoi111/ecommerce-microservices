<script>
function scrollPosts(direction) {
    const container = document.getElementById('posts-scroll');
    const scrollAmount = 370;
    
    if (direction === 'left') {
        container.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    } else {
        container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    }
}
</script>


