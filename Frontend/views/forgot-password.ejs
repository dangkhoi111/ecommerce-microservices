<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quên mật khẩu - MegaStore VN</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        if (window.tailwind) { 
            tailwind.config = { 
                darkMode: 'class',
                theme: {
                    extend: {
                        animation: {
                            'fade-in': 'fadeIn 0.5s ease-in',
                            'slide-up': 'slideUp 0.6s ease-out',
                        },
                        keyframes: {
                            fadeIn: {
                                '0%': { opacity: '0' },
                                '100%': { opacity: '1' }
                            },
                            slideUp: {
                                '0%': { transform: 'translateY(20px)', opacity: '0' },
                                '100%': { transform: 'translateY(0)', opacity: '1' }
                            }
                        }
                    }
                }
            } 
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gradient-to-br from-slate-50 via-white to-slate-50 dark:from-neutral-900 dark:via-black dark:to-neutral-900 min-h-screen transition-colors duration-300">
    <!-- Hero Section Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/4 w-[600px] h-[600px] opacity-5 dark:opacity-10">
            <div class="w-full h-full rounded-full border-8 border-slate-900 dark:border-white flex items-center justify-center">
                <div class="text-[400px] font-black text-slate-900 dark:text-white">M</div>
            </div>
        </div>
    </div>

    <!-- Forgot Password Container -->
    <div class="relative min-h-screen flex items-center justify-center px-4 py-12">
        <div class="w-full max-w-md">
            <!-- Forgot Password Card -->
            <div class="bg-white dark:bg-neutral-900 rounded-3xl shadow-2xl shadow-orange-500/10 dark:shadow-yellow-500/10 border border-slate-200 dark:border-neutral-800 p-8 md:p-10 animate-slide-up">
                <!-- Header -->
                <div class="text-center mb-8">
                    <a href="/" class="inline-block mb-6">
                        <div class="text-3xl font-black bg-gradient-to-r from-orange-500 to-yellow-500 dark:from-yellow-400 dark:to-yellow-200 bg-clip-text text-transparent">
                            MegaStore VN
                        </div>
                    </a>
                    <h1 class="text-2xl md:text-3xl font-black text-slate-900 dark:text-white mb-2">
                        Quên mật khẩu
                    </h1>
                    <p class="text-slate-600 dark:text-neutral-400">
                        Nhập email của bạn để nhận mã xác thực
                    </p>
                </div>

                <!-- Step 1: Enter Email Form -->
                <div id="step1-email-form" class="space-y-6">
                    <form id="emailForm" class="space-y-6">
                        <!-- Email Field -->
                        <div>
                            <label for="email" class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-2">
                                Email
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fas fa-envelope text-slate-400 dark:text-neutral-500"></i>
                                </div>
                                <input 
                                    type="email" 
                                    id="email" 
                                    name="email" 
                                    placeholder="Nhập email của bạn" 
                                    required
                                    class="w-full pl-12 pr-4 py-3 border border-slate-300 dark:border-neutral-700 rounded-xl bg-slate-50 dark:bg-neutral-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-orange-500 dark:focus:ring-yellow-500 focus:border-transparent transition-all"
                                >
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <button 
                            type="submit" 
                            id="send-otp-btn"
                            class="w-full py-3 px-4 bg-gradient-to-r from-orange-500 to-yellow-500 dark:from-yellow-500 dark:to-yellow-400 text-white dark:text-black font-bold text-lg rounded-xl shadow-lg shadow-orange-500/25 dark:shadow-yellow-500/25 hover:shadow-xl hover:shadow-orange-500/40 dark:hover:shadow-yellow-500/40 hover:-translate-y-0.5 transition-all duration-200"
                        >
                            <i class="fas fa-paper-plane mr-2"></i>
                            Gửi mã xác thực
                        </button>
                    </form>
                </div>

                <!-- Step 2: Enter OTP and New Password Form -->
                <div id="step2-otp-form" class="hidden space-y-6">
                    <div class="text-center mb-4">
                        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-orange-100 dark:bg-yellow-500/20 mb-4">
                            <i class="fas fa-envelope-open text-3xl text-orange-500 dark:text-yellow-500"></i>
                        </div>
                        <p class="text-slate-600 dark:text-neutral-400 text-sm">
                            Mã xác thực đã được gửi đến email của bạn
                        </p>
                    </div>

                    <form id="otpForm" class="space-y-6">
                        <!-- Email (hidden, auto-filled) -->
                        <input type="hidden" id="otp-email" name="email">

                        <!-- OTP Field -->
                        <div>
                            <label for="otp" class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-2">
                                Mã xác thực (OTP)
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fas fa-key text-slate-400 dark:text-neutral-500"></i>
                                </div>
                                <input 
                                    type="text" 
                                    id="otp" 
                                    name="otp" 
                                    placeholder="Nhập mã 6 số" 
                                    required
                                    maxlength="6"
                                    pattern="[0-9]{6}"
                                    class="w-full pl-12 pr-4 py-3 border border-slate-300 dark:border-neutral-700 rounded-xl bg-slate-50 dark:bg-neutral-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-orange-500 dark:focus:ring-yellow-500 focus:border-transparent transition-all text-center text-2xl tracking-widest"
                                >
                            </div>
                            <p class="mt-2 text-xs text-slate-500 dark:text-neutral-400">
                                <i class="fas fa-clock mr-1"></i>
                                Mã có hiệu lực trong <span id="otp-timer" class="font-semibold text-orange-500 dark:text-yellow-500">15:00</span>
                            </p>
                        </div>

                        <!-- New Password Field -->
                        <div>
                            <label for="newPassword" class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-2">
                                Mật khẩu mới
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fas fa-lock text-slate-400 dark:text-neutral-500"></i>
                                </div>
                                <input 
                                    type="password" 
                                    id="newPassword" 
                                    name="newPassword" 
                                    placeholder="Nhập mật khẩu mới" 
                                    required
                                    minlength="6"
                                    class="w-full pl-12 pr-12 py-3 border border-slate-300 dark:border-neutral-700 rounded-xl bg-slate-50 dark:bg-neutral-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-orange-500 dark:focus:ring-yellow-500 focus:border-transparent transition-all"
                                >
                                <button 
                                    type="button" 
                                    class="absolute inset-y-0 right-0 pr-4 flex items-center toggle-password-2"
                                >
                                    <i class="fas fa-eye text-slate-400 dark:text-neutral-500 hover:text-orange-500 dark:hover:text-yellow-500 transition-colors"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Confirm Password Field -->
                        <div>
                            <label for="confirmPassword" class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-2">
                                Xác nhận mật khẩu mới
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fas fa-lock text-slate-400 dark:text-neutral-500"></i>
                                </div>
                                <input 
                                    type="password" 
                                    id="confirmPassword" 
                                    name="confirmPassword" 
                                    placeholder="Nhập lại mật khẩu mới" 
                                    required
                                    minlength="6"
                                    class="w-full pl-12 pr-12 py-3 border border-slate-300 dark:border-neutral-700 rounded-xl bg-slate-50 dark:bg-neutral-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-orange-500 dark:focus:ring-yellow-500 focus:border-transparent transition-all"
                                >
                                <button 
                                    type="button" 
                                    class="absolute inset-y-0 right-0 pr-4 flex items-center toggle-password-3"
                                >
                                    <i class="fas fa-eye text-slate-400 dark:text-neutral-500 hover:text-orange-500 dark:hover:text-yellow-500 transition-colors"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Error Message -->
                        <div id="error-message" class="hidden p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl">
                            <p class="text-sm text-red-600 dark:text-red-400"></p>
                        </div>

                        <!-- Success Message -->
                        <div id="success-message" class="hidden p-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl">
                            <p class="text-sm text-green-600 dark:text-green-400"></p>
                        </div>

                        <!-- Submit Button -->
                        <button 
                            type="submit" 
                            id="reset-password-btn"
                            class="w-full py-3 px-4 bg-gradient-to-r from-orange-500 to-yellow-500 dark:from-yellow-500 dark:to-yellow-400 text-white dark:text-black font-bold text-lg rounded-xl shadow-lg shadow-orange-500/25 dark:shadow-yellow-500/25 hover:shadow-xl hover:shadow-orange-500/40 dark:hover:shadow-yellow-500/40 hover:-translate-y-0.5 transition-all duration-200"
                        >
                            <i class="fas fa-check-circle mr-2"></i>
                            Đặt lại mật khẩu
                        </button>

                        <!-- Resend OTP Button -->
                        <button 
                            type="button" 
                            id="resend-otp-btn"
                            class="w-full py-2 px-4 text-sm text-orange-500 dark:text-yellow-500 hover:text-orange-600 dark:hover:text-yellow-400 font-medium transition-colors"
                        >
                            <i class="fas fa-redo mr-2"></i>
                            Gửi lại mã xác thực
                        </button>
                    </form>
                </div>

                <!-- Footer -->
                <div class="mt-8 text-center">
                    <a href="/login" class="inline-flex items-center gap-2 text-slate-600 dark:text-neutral-400 hover:text-orange-500 dark:hover:text-yellow-500 transition-colors">
                        <i class="fas fa-arrow-left"></i>
                        <span>Quay lại đăng nhập</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        let otpTimer = null;
        let otpTimerSeconds = 900; // 15 phút = 900 giây
        let userEmail = '';

        // Toggle password visibility
        document.querySelectorAll('.toggle-password-2, .toggle-password-3').forEach(btn => {
            btn.addEventListener('click', function() {
                const input = this.parentElement.querySelector('input');
                const icon = this.querySelector('i');
                
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.remove('fa-eye');
                    icon.classList.add('fa-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.remove('fa-eye-slash');
                    icon.classList.add('fa-eye');
                }
            });
        });

        // Step 1: Send OTP
        document.getElementById('emailForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const email = document.getElementById('email').value.trim();
            const sendOtpBtn = document.getElementById('send-otp-btn');
            const errorDiv = document.getElementById('error-message');
            
            // Disable button
            sendOtpBtn.disabled = true;
            sendOtpBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Đang gửi...';
            
            // Hide error
            errorDiv.classList.add('hidden');
            
            try {
                const res = await fetch('http://localhost:3002/api/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                
                const data = await res.json();
                
                if (!res.ok) {
                    throw new Error(data.message || 'Không thể gửi mã xác thực');
                }
                
                // Success: Show step 2
                userEmail = email;
                document.getElementById('step1-email-form').classList.add('hidden');
                document.getElementById('step2-otp-form').classList.remove('hidden');
                document.getElementById('otp-email').value = email;
                
                // Start timer
                startOTPTimer();
                
            } catch (err) {
                errorDiv.querySelector('p').textContent = err.message;
                errorDiv.classList.remove('hidden');
            } finally {
                sendOtpBtn.disabled = false;
                sendOtpBtn.innerHTML = '<i class="fas fa-paper-plane mr-2"></i>Gửi mã xác thực';
            }
        });

        // Step 2: Verify OTP and Reset Password
        document.getElementById('otpForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const otp = document.getElementById('otp').value.trim();
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            const resetBtn = document.getElementById('reset-password-btn');
            const errorDiv = document.getElementById('error-message');
            const successDiv = document.getElementById('success-message');
            
            // Validate passwords match
            if (newPassword !== confirmPassword) {
                errorDiv.querySelector('p').textContent = 'Mật khẩu xác nhận không khớp';
                errorDiv.classList.remove('hidden');
                successDiv.classList.add('hidden');
                return;
            }
            
            if (newPassword.length < 6) {
                errorDiv.querySelector('p').textContent = 'Mật khẩu phải có ít nhất 6 ký tự';
                errorDiv.classList.remove('hidden');
                successDiv.classList.add('hidden');
                return;
            }
            
            // Disable button
            resetBtn.disabled = true;
            resetBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Đang xử lý...';
            
            // Hide messages
            errorDiv.classList.add('hidden');
            successDiv.classList.add('hidden');
            
            try {
                const res = await fetch('http://localhost:3002/api/auth/verify-otp-reset', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        email: userEmail,
                        otpCode: otp,
                        newPassword: newPassword
                    })
                });
                
                const data = await res.json();
                
                if (!res.ok) {
                    throw new Error(data.message || 'Không thể đặt lại mật khẩu');
                }
                
                // Success
                successDiv.querySelector('p').textContent = data.message || 'Đặt lại mật khẩu thành công!';
                successDiv.classList.remove('hidden');
                
                // Redirect to login after 2 seconds
                setTimeout(() => {
                    window.location.href = '/login';
                }, 2000);
                
            } catch (err) {
                errorDiv.querySelector('p').textContent = err.message;
                errorDiv.classList.remove('hidden');
                resetBtn.disabled = false;
                resetBtn.innerHTML = '<i class="fas fa-check-circle mr-2"></i>Đặt lại mật khẩu';
            }
        });

        // Resend OTP
        document.getElementById('resend-otp-btn').addEventListener('click', async function() {
            const resendBtn = this;
            const errorDiv = document.getElementById('error-message');
            
            resendBtn.disabled = true;
            resendBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Đang gửi lại...';
            
            try {
                const res = await fetch('http://localhost:3002/api/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: userEmail })
                });
                
                const data = await res.json();
                
                if (!res.ok) {
                    throw new Error(data.message || 'Không thể gửi lại mã xác thực');
                }
                
                // Reset timer
                otpTimerSeconds = 900;
                startOTPTimer();
                
                // Show success briefly
                const successDiv = document.getElementById('success-message');
                successDiv.querySelector('p').textContent = 'Mã xác thực mới đã được gửi đến email của bạn';
                successDiv.classList.remove('hidden');
                setTimeout(() => successDiv.classList.add('hidden'), 3000);
                
            } catch (err) {
                errorDiv.querySelector('p').textContent = err.message;
                errorDiv.classList.remove('hidden');
            } finally {
                resendBtn.disabled = false;
                resendBtn.innerHTML = '<i class="fas fa-redo mr-2"></i>Gửi lại mã xác thực';
            }
        });

        // OTP Timer
        function startOTPTimer() {
            if (otpTimer) clearInterval(otpTimer);
            
            const timerEl = document.getElementById('otp-timer');
            
            otpTimer = setInterval(() => {
                otpTimerSeconds--;
                
                if (otpTimerSeconds <= 0) {
                    clearInterval(otpTimer);
                    timerEl.textContent = 'Hết hạn';
                    timerEl.classList.add('text-red-500');
                    return;
                }
                
                const minutes = Math.floor(otpTimerSeconds / 60);
                const seconds = otpTimerSeconds % 60;
                timerEl.textContent = `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
            }, 1000);
        }

        // Format OTP input
        document.getElementById('otp').addEventListener('input', function(e) {
            e.target.value = e.target.value.replace(/\D/g, ''); // Only numbers
        });
    </script>
</body>
</html>

