<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Test OCR Hóa Đơn - MegaStore VN</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        .invoice-preview {
            max-width: 100%;
            max-height: 400px;
            border: 2px dashed #cbd5e1;
            border-radius: 8px;
            object-fit: contain;
        }
    </style>
</head>
<body class="bg-gradient-to-br from-purple-50 via-white to-blue-50 min-h-screen py-8">
    <div class="container mx-auto px-4 max-w-6xl">
        <!-- Header -->
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-blue-500 rounded-xl flex items-center justify-center">
                    <i class="fas fa-file-invoice text-white text-2xl"></i>
                </div>
                <div>
                    <h1 class="text-3xl font-bold text-gray-900">Test OCR Hóa Đơn</h1>
                    <p class="text-gray-600">Trang demo để test chức năng quét hóa đơn bằng OCR</p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Upload Section -->
            <div class="bg-white rounded-2xl shadow-lg p-6">
                <h2 class="text-xl font-bold text-gray-900 mb-4">
                    <i class="fas fa-upload text-purple-500 mr-2"></i>
                    Tải ảnh hóa đơn
                </h2>
                
                <form id="test-invoice-form" class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                            Chọn ảnh hóa đơn (PNG, JPG)
                        </label>
                        <div class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center hover:border-purple-400 transition-colors cursor-pointer" id="drop-zone">
                            <input type="file" id="invoice-file-input" accept="image/*" class="hidden">
                            <i class="fas fa-cloud-upload-alt text-4xl text-gray-400 mb-3"></i>
                            <p class="text-gray-600 mb-2">Click để chọn hoặc kéo thả ảnh vào đây</p>
                            <p class="text-sm text-gray-500">Tối đa 5MB</p>
                        </div>
                        <div id="file-name" class="mt-2 text-sm text-gray-600 hidden"></div>
                    </div>

                    <div id="image-preview-container" class="hidden">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Preview ảnh</label>
                        <img id="image-preview" class="invoice-preview w-full" alt="Preview">
                    </div>

                    <button type="submit" id="submit-btn" class="w-full bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-700 hover:to-blue-700 text-white font-bold py-3 px-6 rounded-xl transition-all shadow-lg hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed">
                        <i class="fas fa-magic mr-2"></i>
                        Quét hóa đơn (OCR)
                    </button>

                    <div id="upload-error" class="text-red-500 text-sm hidden"></div>
                </form>
            </div>

            <!-- Results Section -->
            <div class="bg-white rounded-2xl shadow-lg p-6">
                <h2 class="text-xl font-bold text-gray-900 mb-4">
                    <i class="fas fa-chart-line text-blue-500 mr-2"></i>
                    Kết quả OCR
                </h2>

                <div id="loading-state" class="hidden text-center py-8">
                    <i class="fas fa-spinner fa-spin text-4xl text-purple-500 mb-4"></i>
                    <p class="text-gray-600">Đang xử lý OCR...</p>
                    <p class="text-sm text-gray-500 mt-2">Vui lòng đợi, quá trình này có thể mất 10-30 giây</p>
                </div>

                <div id="result-container" class="hidden space-y-4">
                    <!-- Status -->
                    <div class="bg-gradient-to-r from-green-50 to-emerald-50 border border-green-200 rounded-xl p-4">
                        <div class="flex items-center gap-2 mb-2">
                            <i class="fas fa-check-circle text-green-500"></i>
                            <span class="font-semibold text-gray-700">Trạng thái:</span>
                            <span id="result-status" class="font-bold text-green-600">Đã xử lý</span>
                        </div>
                    </div>

                    <!-- Parsed Data -->
                    <div class="bg-gray-50 rounded-xl p-4">
                        <h3 class="font-bold text-gray-900 mb-3">Thông tin trích xuất:</h3>
                        <ul id="parsed-details" class="space-y-2 text-sm">
                            <!-- Will be filled by JS -->
                        </ul>
                    </div>

                    <!-- Raw Text -->
                    <div class="bg-gray-50 rounded-xl p-4">
                        <h3 class="font-bold text-gray-900 mb-3">Nội dung OCR (Raw Text):</h3>
                        <pre id="raw-text" class="bg-white border rounded-lg p-3 text-xs overflow-auto max-h-64 overflow-y-auto whitespace-pre-wrap"></pre>
                    </div>

                    <!-- Image Link -->
                    <div id="image-link-container" class="hidden">
                        <a id="image-link" href="#" target="_blank" class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 text-sm">
                            <i class="fas fa-external-link-alt"></i>
                            Xem ảnh đã tải lên
                        </a>
                    </div>
                </div>

                <div id="empty-state" class="text-center py-12 text-gray-400">
                    <i class="fas fa-receipt text-6xl mb-4"></i>
                    <p>Chưa có kết quả. Hãy tải ảnh hóa đơn để bắt đầu.</p>
                </div>
            </div>
        </div>

        <!-- Instructions -->
        <div class="bg-white rounded-2xl shadow-lg p-6 mt-6">
            <h2 class="text-xl font-bold text-gray-900 mb-4">
                <i class="fas fa-info-circle text-blue-500 mr-2"></i>
                Hướng dẫn sử dụng
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-blue-50 rounded-lg p-4">
                    <h3 class="font-semibold text-gray-900 mb-2">Cách tạo ảnh hóa đơn test:</h3>
                    <ol class="list-decimal list-inside space-y-1 text-sm text-gray-700">
                        <li>Mở Word/Google Docs</li>
                        <li>Tạo document với nội dung mẫu (xem bên dưới)</li>
                        <li>Chụp màn hình hoặc export thành ảnh PNG/JPG</li>
                        <li>Upload ảnh vào form bên trên</li>
                    </ol>
                </div>
                <div class="bg-purple-50 rounded-lg p-4">
                    <h3 class="font-semibold text-gray-900 mb-2">Nội dung mẫu hóa đơn:</h3>
                    <div class="bg-white rounded p-3 text-xs font-mono text-gray-700 border">
                        <div>HÓA ĐƠN BÁN HÀNG</div>
                        <div>Mã đơn: #ORD123456</div>
                        <div>Ngày: 15/12/2024</div>
                        <div>Khách hàng: Nguyễn Văn A</div>
                        <div>Địa chỉ: 123 Đường ABC, Quận 1, TP.HCM</div>
                        <div>---</div>
                        <div>Sản phẩm 1: 500,000 VNĐ</div>
                        <div>Sản phẩm 2: 300,000 VNĐ</div>
                        <div>Tổng tiền: 800,000 VNĐ</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const form = document.getElementById('test-invoice-form');
        const fileInput = document.getElementById('invoice-file-input');
        const dropZone = document.getElementById('drop-zone');
        const fileName = document.getElementById('file-name');
        const imagePreview = document.getElementById('image-preview');
        const imagePreviewContainer = document.getElementById('image-preview-container');
        const submitBtn = document.getElementById('submit-btn');
        const uploadError = document.getElementById('upload-error');
        const loadingState = document.getElementById('loading-state');
        const resultContainer = document.getElementById('result-container');
        const emptyState = document.getElementById('empty-state');
        const resultStatus = document.getElementById('result-status');
        const parsedDetails = document.getElementById('parsed-details');
        const rawText = document.getElementById('raw-text');
        const imageLink = document.getElementById('image-link');
        const imageLinkContainer = document.getElementById('image-link-container');

        // Drop zone handlers
        dropZone.addEventListener('click', () => fileInput.click());
        
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('border-purple-500', 'bg-purple-50');
        });

        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('border-purple-500', 'bg-purple-50');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('border-purple-500', 'bg-purple-50');
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                fileInput.files = files;
                handleFileSelect(files[0]);
            }
        });

        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                handleFileSelect(e.target.files[0]);
            }
        });

        function handleFileSelect(file) {
            if (!file.type.startsWith('image/')) {
                showError('Vui lòng chọn file ảnh (PNG, JPG)');
                return;
            }

            if (file.size > 5 * 1024 * 1024) {
                showError('File quá lớn. Tối đa 5MB');
                return;
            }

            fileName.textContent = file.name;
            fileName.classList.remove('hidden');
            uploadError.classList.add('hidden');

            // Preview image
            const reader = new FileReader();
            reader.onload = (e) => {
                imagePreview.src = e.target.result;
                imagePreviewContainer.classList.remove('hidden');
            };
            reader.readAsDataURL(file);
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const file = fileInput.files[0];
            if (!file) {
                showError('Vui lòng chọn ảnh hóa đơn');
                return;
            }

            // Show loading
            loadingState.classList.remove('hidden');
            resultContainer.classList.add('hidden');
            emptyState.classList.add('hidden');
            uploadError.classList.add('hidden');
            submitBtn.disabled = true;

            const formData = new FormData();
            formData.append('invoice', file);
            formData.append('orderId', 'test'); // Test mode

            try {
                const response = await fetch('http://localhost:3006/api/invoices', {
                    method: 'POST',
                    body: formData,
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.message || 'Không thể xử lý hóa đơn');
                }

                // Show results
                displayResults(data.invoice);
            } catch (err) {
                console.error('Error:', err);
                showError(err.message || 'Đã xảy ra lỗi khi quét hóa đơn');
                loadingState.classList.add('hidden');
                emptyState.classList.remove('hidden');
            } finally {
                submitBtn.disabled = false;
            }
        });

        function displayResults(invoice) {
            loadingState.classList.add('hidden');
            resultContainer.classList.remove('hidden');
            emptyState.classList.add('hidden');

            // Status
            if (invoice.status === 'processed') {
                resultStatus.textContent = 'Đã xử lý thành công';
                resultStatus.className = 'font-bold text-green-600';
            } else if (invoice.status === 'failed') {
                resultStatus.textContent = 'Xử lý thất bại';
                resultStatus.className = 'font-bold text-red-600';
            } else {
                resultStatus.textContent = 'Đang chờ xử lý';
                resultStatus.className = 'font-bold text-yellow-600';
            }

            // Parsed details
            const details = [];
            if (invoice.parsed) {
                // Thông tin đơn hàng
                if (invoice.parsed.orderCode) {
                    details.push(`<li class="flex justify-between py-1 border-b border-gray-200"><span class="font-semibold text-gray-700">📋 Mã đơn:</span> <span class="text-gray-900">${invoice.parsed.orderCode}</span></li>`);
                }
                if (invoice.parsed.date) {
                    details.push(`<li class="flex justify-between py-1 border-b border-gray-200"><span class="font-semibold text-gray-700">📅 Ngày:</span> <span class="text-gray-900">${invoice.parsed.date}</span></li>`);
                }
                if (invoice.parsed.status) {
                    details.push(`<li class="flex justify-between py-1 border-b border-gray-200"><span class="font-semibold text-gray-700">🔄 Trạng thái:</span> <span class="text-gray-900">${invoice.parsed.status}</span></li>`);
                }
                if (invoice.parsed.paymentMethod) {
                    details.push(`<li class="flex justify-between py-1 border-b border-gray-200"><span class="font-semibold text-gray-700">💳 Phương thức:</span> <span class="text-gray-900">${invoice.parsed.paymentMethod.toUpperCase()}</span></li>`);
                }
                
                // Thông tin khách hàng
                if (invoice.parsed.customer) {
                    details.push(`<li class="flex justify-between py-1 border-b border-gray-200"><span class="font-semibold text-gray-700">👤 Họ tên:</span> <span class="text-gray-900">${invoice.parsed.customer}</span></li>`);
                }
                if (invoice.parsed.phone) {
                    details.push(`<li class="flex justify-between py-1 border-b border-gray-200"><span class="font-semibold text-gray-700">📞 SĐT:</span> <span class="text-gray-900">${invoice.parsed.phone}</span></li>`);
                }
                if (invoice.parsed.address) {
                    details.push(`<li class="flex justify-between py-1 border-b border-gray-200"><span class="font-semibold text-gray-700">📍 Địa chỉ:</span> <span class="text-gray-900 text-xs text-right max-w-xs">${invoice.parsed.address}</span></li>`);
                }
                if (invoice.parsed.province) {
                    details.push(`<li class="flex justify-between py-1 border-b border-gray-200"><span class="font-semibold text-gray-700">🏙️ Tỉnh/Thành:</span> <span class="text-gray-900">${invoice.parsed.province}</span></li>`);
                }
                
                // Sản phẩm
                if (invoice.parsed.products && invoice.parsed.products.length > 0) {
                    details.push(`<li class="py-2 border-b border-gray-200"><span class="font-semibold text-gray-700">🛍️ Sản phẩm (${invoice.parsed.products.length}):</span></li>`);
                    invoice.parsed.products.forEach((product, idx) => {
                        const productPrice = product.price ? `${Number(product.price).toLocaleString('vi-VN')} VNĐ` : '-';
                        const colorLabel = product.color || '-';
                        const sizeLabel = product.size || '-';
                        details.push(`<li class="pl-4 py-1 text-sm border-b border-gray-100"><span class="text-gray-700">${idx + 1}. ${product.name}</span> - SL: ${product.quantity || 1} - Màu: ${colorLabel} - Kích thước: ${sizeLabel} - Giá: <span class="font-semibold">${productPrice}</span></li>`);
                    });
                }
                
                // Tổng tiền
                if (invoice.parsed.total) {
                    const totalNumber = Number(invoice.parsed.total);
                    const formattedTotal = Number.isFinite(totalNumber)
                        ? `${totalNumber.toLocaleString('vi-VN')} VNĐ`
                        : `${invoice.parsed.total} VNĐ`;
                    details.push(`<li class="flex justify-between py-2 mt-2 border-t-2 border-gray-300"><span class="font-bold text-lg text-gray-700">💰 Tổng tiền:</span> <span class="font-bold text-lg text-green-600">${formattedTotal}</span></li>`);
                }
            }

            if (details.length === 0) {
                details.push('<li class="text-gray-500 italic">Không trích xuất được thông tin từ hóa đơn</li>');
            }

            parsedDetails.innerHTML = details.join('');

            // Raw text
            rawText.textContent = invoice.rawText || 'Không có nội dung OCR';

            // Image link
            if (invoice.imagePath) {
                imageLink.href = `http://localhost:3006/${invoice.imagePath}`;
                imageLinkContainer.classList.remove('hidden');
            } else {
                imageLinkContainer.classList.add('hidden');
            }
        }

        function showError(message) {
            uploadError.textContent = message;
            uploadError.classList.remove('hidden');
        }
    </script>
</body>
</html>

