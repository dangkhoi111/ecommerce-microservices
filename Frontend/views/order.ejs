<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Chi tiết đơn hàng</title>
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    body {
      margin-top: 20px;
      background-color: #f8f9fa;
    }
    .order-details {
      background-color: #fff;
      padding: 20px;
      border-radius: 5px;
    }
    .order-info .row {
      margin-bottom: 10px;
    }
    .order-info .col-sm-3 {
      font-weight: bold;
    }
    .products-table th, .products-table td {
      vertical-align: middle;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1 class="mb-4">Chi tiết đơn hàng</h1>
    <div id="order-details" class="order-details shadow-sm">
      <div class="order-info row">
        <div class="col-sm-3">Mã đơn hàng:</div>
        <div class="col-sm-9" id="order-id"></div>
      </div>
      <div class="order-info row">
        <div class="col-sm-3">Ngày đặt hàng:</div>
        <div class="col-sm-9" id="order-date"></div>
      </div>
      <div class="order-info row">
        <div class="col-sm-3">Trạng thái:</div>
        <div class="col-sm-9" id="order-status"></div>
      </div>
      <div class="order-info row">
        <div class="col-sm-3">Thành tiền:</div>
        <div class="col-sm-9" id="order-total"></div>
      </div>
      <div class="order-info row">
        <div class="col-sm-3">Phương thức giao hàng:</div>
        <div class="col-sm-9" id="order-shipping-method"></div>
      </div>
      <div class="order-info row">
        <div class="col-sm-3">Phí vận chuyển:</div>
        <div class="col-sm-9" id="order-shipping-fee"></div>
      </div>
      <div class="order-info row">
        <div class="col-sm-3">Người bán:</div>
        <div class="col-sm-9" id="order-seller"></div>
      </div>
      <div class="order-info row">
  <div class="col-sm-3">Người nhận:</div>
  <div class="col-sm-9" id="receiver-name"></div>
</div>
<div class="order-info row">
  <div class="col-sm-3">Số điện thoại:</div>
  <div class="col-sm-9" id="receiver-phone"></div>
</div>
<div class="order-info row">
  <div class="col-sm-3">Địa chỉ chi tiết:</div>
  <div class="col-sm-9" id="receiver-address"></div>
</div>
<div class="order-info row">
  <div class="col-sm-3">Tỉnh/Thành:</div>
  <div class="col-sm-9" id="receiver-city"></div>
</div>

      <hr />
      <h5>Danh sách sản phẩm</h5>
      <table class="table table-bordered products-table">
        <thead>
          <tr>
            <th>Tên sản phẩm</th>
            <th>Số lượng</th>
            <th>Màu sắc</th>
            <th>Kích thước</th>
            <th>Tổng tiền</th>
          </tr>
        </thead>
        <tbody id="product-list">
          <!-- Dữ liệu sẽ được render bằng JS -->
        </tbody>
      </table>
    </div>
    <div class="mt-3">
      <button class="btn btn-secondary" onclick="window.history.back()">Quay lại danh sách đơn hàng</button>
      <button class="btn btn-primary ms-2" onclick="generateCustomerInvoice()">🖨️ Tạo/Xem hóa đơn</button>
    </div>
  </div>

  <!-- JavaScript -->
  <script>
  // Lấy orderId từ URL dạng /order/:id
  const pathParts = window.location.pathname.split('/');
  const orderId = pathParts[pathParts.length - 1];
  
  function generateCustomerInvoice() {
    if (orderId) {
      window.open(`http://localhost:3006/api/invoices/generate/${orderId}`, '_blank');
    } else {
      alert('Không tìm thấy mã đơn hàng');
    }
  }

  if (!orderId) {
    document.getElementById('order-details').innerHTML = '<p>Không có ID đơn hàng.</p>';
  } else {
    // Gọi API chi tiết đơn hàng
    fetch(`http://localhost:3006/api/orders/${orderId}`)
      .then(response => response.json())
      .then(data => {
        // Hiển thị thông tin đơn hàng
        document.getElementById('order-id').textContent = data._id;
        document.getElementById('order-date').textContent = new Date(data.NgayLap).toLocaleString('vi-VN');
        document.getElementById('order-status').textContent = data.TrangThai;
        document.getElementById('order-total').textContent = data.TongTien.toLocaleString('vi-VN') + ' VND';
        document.getElementById('order-shipping-method').textContent =
          data.PhuongThucGiaoHang === 'cod' ? 'Thanh toán khi nhận hàng (COD)' : data.PhuongThucGiaoHang;
        document.getElementById('order-seller').textContent = data.MaUserBan;
document.getElementById('receiver-name').textContent = data.hoTenNguoiNhan;
document.getElementById('receiver-phone').textContent = data.sdtNguoiNhan;
document.getElementById('receiver-address').textContent = data.diaChiChiTiet;
document.getElementById('receiver-city').textContent = data.tinhThanh;
        // Gọi API lấy thông tin vận chuyển nếu cần
        fetch(`http://localhost:3004/api/shipping/${data.MaVC}`)
          .then(res => res.json())
          .then(shipping => {
            document.getElementById('order-shipping-fee').textContent = (shipping.PhiVC || 0).toLocaleString('vi-VN') + ' VND';
          })
          .catch(() => {
            document.getElementById('order-shipping-fee').textContent = 'Không rõ';
          });

        // Hiển thị danh sách sản phẩm
        const productList = document.getElementById('product-list');
        productList.innerHTML = ''; // Clear danh sách cũ
        data.orderItems.forEach(item => {
          const row = document.createElement('tr');
          row.innerHTML = `
            <td>${item.TenSp}</td>
            <td>${item.SoLuong}</td>
            <td>${item.MauSac}</td>
            <td>${item.KichThuoc}</td>
            <td>${item.Tong.toLocaleString('vi-VN')} VND</td>
          `;
          productList.appendChild(row);
        });
      })
      .catch(error => {
        console.error('Lỗi khi lấy dữ liệu:', error);
        document.getElementById('order-details').innerHTML = '<p>Không thể tải thông tin đơn hàng.</p>';
      });
  }
</script>

</body>
</html>
