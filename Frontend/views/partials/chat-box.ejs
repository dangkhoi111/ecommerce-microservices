<!-- Tailwind CSS CDN -->
<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    darkMode: 'class',
    theme: {
      extend: {
        colors: {
          'orange': {
            500: '#f97316',
            600: '#ea580c',
          },
          'yellow': {
            500: '#eab308',
            600: '#ca8a04',
          }
        }
      }
    }
  }
</script>

<!-- ✅ Chat Box Hoàn Chỉnh -->
<div class="fixed bottom-5 right-5 z-50">
  <!-- Chat Icon -->
  <div class="chat-icon bg-orange-500 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg cursor-pointer hover:bg-orange-600 transition-all duration-200"
       onclick="toggleChatBox()">
    <i class="fas fa-comments text-2xl"></i>
    <span class="notification-badge absolute -top-1 -right-1 bg-red-500 text-white text-xs w-5 h-5 flex items-center justify-center rounded-full">0</span>
  </div>

  <!-- Chat Box -->
  <div class="chat-box hidden flex-col w-96 h-[520px] bg-white dark:bg-slate-800 rounded-xl shadow-2xl overflow-hidden absolute bottom-16 right-0 transform transition-all duration-300"
       id="chatBox">
    <!-- Header -->
    <div class="flex justify-between items-center bg-orange-500 text-white px-4 py-3">
      <div>
        <h4 class="text-lg font-semibold">Tin nhắn</h4>
        <span id="onlineCount" class="text-sm opacity-80">Đang tải...</span>
      </div>
      <div class="flex gap-3">
        <button class="hover:text-gray-200"><i class="fas fa-search"></i></button>
        <button class="hover:text-gray-200"><i class="fas fa-cog"></i></button>
        <button onclick="toggleChatBox()" class="hover:text-gray-200"><i class="fas fa-times"></i></button>
      </div>
    </div>

    <!-- Danh sách shop -->
    <div class="flex-1 overflow-y-auto bg-slate-50 dark:bg-slate-900 p-4 block" id="shopSelection">
      <div class="relative mb-3">
        <i class="fas fa-search absolute left-3 top-2.5 text-gray-400"></i>
        <input type="text" id="shopSearchInput" placeholder="Tìm kiếm shop..." oninput="filterShops(this.value)"
               class="pl-9 pr-3 py-2 w-full border rounded-lg outline-none focus:ring-2 focus:ring-orange-500">
      </div>
      <div id="shopList" class="flex flex-col gap-3"></div>
    </div>

    <!-- Khu vực chat -->
    <div class="hidden flex-col h-full overflow-hidden" id="chatArea">
      <div class="flex items-center justify-between bg-slate-100 dark:bg-slate-700 p-3 flex-shrink-0">
        <div class="flex items-center gap-3 flex-1">
          <!-- Avatar người nhận -->
          <img id="selectedShopImage" src="/images/default-avatar.png"
               class="w-10 h-10 rounded-full border object-cover"
               onerror="this.onerror=null;this.src='/images/default-avatar.png'">
          <div class="flex-1">
            <h5 id="selectedShopName" class="font-semibold text-slate-800 dark:text-slate-200">Shop</h5>
            <span id="selectedShopStatus" class="text-xs text-green-500">Online</span>
          </div>
          <!-- Avatar người dùng hiện tại -->
          <div class="flex items-center gap-2">
            <div class="text-right hidden sm:block">
              <div class="text-xs font-semibold text-slate-700 dark:text-slate-300" id="currentUserName">Bạn</div>
              <div class="text-xs text-green-500">Online</div>
            </div>
            <img id="currentUserAvatar" src="/images/default-avatar.png"
                 class="w-10 h-10 rounded-full border-2 border-orange-500 object-cover"
                 onerror="this.onerror=null;this.src='/images/default-avatar.png'">
          </div>
        </div>
        <div class="flex gap-2 ml-2">
          <button class="p-2 hover:bg-slate-200 rounded-lg"><i class="fas fa-paperclip"></i></button>
          <button onclick="showShopSelection()" class="p-2 hover:bg-slate-200 rounded-lg"><i class="fas fa-arrow-left"></i></button>
        </div>
      </div>

      <div id="chatMessages" class="flex-1 overflow-y-auto p-4 bg-white dark:bg-slate-900 flex flex-col gap-3"></div>

      <div class="flex items-center gap-2 border-t p-3 bg-slate-50 dark:bg-slate-800 flex-shrink-0">
        <button class="text-xl text-gray-500 hover:text-orange-500"><i class="far fa-smile"></i></button>
        <input id="messageInput" type="text" placeholder="Nhập tin nhắn..."
               class="flex-1 border rounded-lg px-3 py-2 outline-none focus:ring-2 focus:ring-orange-500">
        <button class="text-gray-500 hover:text-orange-500"><i class="fas fa-microphone"></i></button>
        <button onclick="sendMessage()" class="text-orange-500 hover:text-orange-500"><i class="fas fa-paper-plane"></i></button>
      </div>
    </div>
  </div>
</div>

<script src="https://kit.fontawesome.com/a2d9d6a04b.js" crossorigin="anonymous"></script>
<script src="http://localhost:4000/socket.io/socket.io.js"></script>
<script>
const userInfo = JSON.parse(localStorage.getItem("userInfo"));
const CURRENT_USER_ID = userInfo?.id;
const CURRENT_USERBAN_ID = userInfo?.userBanId;
const CURRENT_USER_ROLE = userInfo?.role;

// Xác định avatar và tên dựa trên role
let CURRENT_USER_AVATAR = '/images/default-avatar.png';
let CURRENT_USER_NAME = 'Bạn';

if (CURRENT_USER_ROLE === 'seller') {
  // Seller: lấy tên shop và logo shop
  CURRENT_USER_NAME = userInfo?.tenShop || userInfo?.hoTen || 'Bạn';
  CURRENT_USER_AVATAR = userInfo?.shopAvatar || '/images/default-avatar.png';
} else {
  // Customer: lấy avatar từ profile
  CURRENT_USER_NAME = userInfo?.hoTen || 'Bạn';
  CURRENT_USER_AVATAR = userInfo?.avatar || '/images/default-avatar.png';
}

// Cập nhật avatar và tên của user hiện tại trong chat area
async function updateCurrentUserInfo() {
  const currentUserAvatarEl = document.getElementById('currentUserAvatar');
  const currentUserNameEl = document.getElementById('currentUserName');
  
  if (CURRENT_USER_ROLE === 'seller') {
    // Seller: fetch thông tin shop để lấy logo
    if (CURRENT_USERBAN_ID) {
      try {
        const shopRes = await fetch(`http://localhost:3002/api/user-ban/check/${CURRENT_USERBAN_ID}`);
        if (shopRes.ok) {
          const shopData = await shopRes.json();
          if (shopData.hinhAnh) {
            CURRENT_USER_AVATAR = shopData.hinhAnh;
            // Lưu vào localStorage để dùng lại
            if (userInfo) {
              userInfo.shopAvatar = shopData.hinhAnh;
              if (shopData.tenShop) userInfo.tenShop = shopData.tenShop;
              localStorage.setItem('userInfo', JSON.stringify(userInfo));
            }
          }
          if (shopData.tenShop) {
            CURRENT_USER_NAME = shopData.tenShop;
          }
        }
      } catch (error) {
        console.error('Lỗi khi fetch shop info:', error);
      }
    }
  } else {
    // Customer: fetch avatar từ user profile nếu chưa có
    if (!userInfo?.avatar && CURRENT_USER_ID) {
      try {
        const userRes = await fetch(`http://localhost:3002/api/auth/${CURRENT_USER_ID}`);
        if (userRes.ok) {
          const userData = await userRes.json();
          if (userData.success && userData.data && userData.data.avatar) {
            CURRENT_USER_AVATAR = userData.data.avatar;
            // Cập nhật localStorage
            if (userInfo) {
              userInfo.avatar = userData.data.avatar;
              localStorage.setItem('userInfo', JSON.stringify(userInfo));
            }
          }
        }
      } catch (error) {
        console.error('Lỗi khi fetch avatar từ API:', error);
      }
    }
  }
  
  // Cập nhật UI
  if (currentUserAvatarEl) {
    currentUserAvatarEl.src = CURRENT_USER_AVATAR;
  }
  if (currentUserNameEl) {
    currentUserNameEl.textContent = CURRENT_USER_NAME;
  }
}

// Gọi khi script load
updateCurrentUserInfo();

let selectedShop = null;
let conversations = [];

const socket = io("http://localhost:4000");

if (CURRENT_USER_ROLE === "customer") {
  socket.emit("register", { userId: CURRENT_USER_ID });
} else if (CURRENT_USER_ROLE === "seller") {
  socket.emit("register", { userId: CURRENT_USERBAN_ID });
}

socket.on("receive_message", (msg) => {
  // Reload conversations để nhận conversation đã được restore (nếu có)
  // Chỉ reload nếu đang ở màn hình danh sách conversations
  const shopSelection = document.getElementById("shopSelection");
  if (shopSelection && !shopSelection.classList.contains("hidden")) {
    loadConversations();
  }
  
  if (!selectedShop) {
    updateNotificationBadge();
    return;
  }
  const fromId = msg.from;
  const selectedShopId = (CURRENT_USER_ROLE === "customer") ? selectedShop.maUserBan : selectedShop.maKH;
  if (fromId === selectedShopId) {
    displayMessage(msg, 'received');
  } else {
    updateNotificationBadge();
  }
});

socket.on("shop_online_count", (count) => {
  document.getElementById('onlineCount').innerText = `${count} shop online`;
});

function toggleChatBox() {
  const chatBox = document.getElementById("chatBox");
  const chatIcon = document.querySelector(".chat-icon");
  if (chatBox.classList.contains("hidden")) {
    chatBox.classList.remove("hidden");
    chatBox.classList.add("flex");
    chatIcon.classList.add("hidden");
    loadConversations();
  } else {
    chatBox.classList.add("hidden");
    chatBox.classList.remove("flex");
    chatIcon.classList.remove("hidden");
  }
}

function updateNotificationBadge() {
  const badge = document.querySelector(".notification-badge");
  badge.innerText = parseInt(badge.innerText || 0) + 1;
}

async function loadConversations() {
  try {
    let url = "";
    if (CURRENT_USER_ROLE === "customer") {
      url = `http://localhost:4000/api/conversations?maKH=${CURRENT_USER_ID}`;
    } else if (CURRENT_USER_ROLE === "seller") {
      url = `http://localhost:4000/api/conversations/nguoi-ban?maUserBan=${CURRENT_USERBAN_ID}`;
    }
    console.log("🔍 Loading conversations from:", url);
    console.log("👤 Current user role:", CURRENT_USER_ROLE);
    console.log("👤 Current user ID:", CURRENT_USER_ID || CURRENT_USERBAN_ID);
    
    const res = await fetch(url);
    if (!res.ok) {
      console.error("❌ Failed to fetch conversations:", res.status, res.statusText);
      throw new Error("Failed to fetch conversations");
    }
    conversations = await res.json();
    console.log("✅ Conversations loaded:", conversations.length, "items");
    console.log("📋 Conversations data:", conversations);
    renderShopList(conversations);
  } catch (err) {
    console.error("❌ Error loading conversations:", err);
  }
}

function renderShopList(shopList) {
  const shopListContainer = document.getElementById("shopList");
  shopListContainer.innerHTML = "";

  shopList.forEach((shop) => {
    const tenNguoiNhan = CURRENT_USER_ROLE === "customer" ? shop.tenShop : shop.tenKhachHang;
    // Xác định avatar dựa trên role:
    // - Customer: hiển thị logo shop (hinhAnh)
    // - Seller: hiển thị avatar customer (hinhKH)
    const avatarUrl = CURRENT_USER_ROLE === "customer" 
      ? (shop.hinhAnh || '/images/default-avatar.png')
      : (shop.hinhKH || '/images/default-avatar.png');
    
    const div = document.createElement("div");
    div.className = "flex items-center gap-3 p-3 bg-white dark:bg-slate-700 rounded-lg shadow hover:bg-slate-100 transition group relative";
    // Lưu shop data vào data attribute để có thể truy cập sau
    div.setAttribute("data-shop-id", shop._id);
    div.innerHTML = `
      <div class="flex items-center gap-3 flex-1 cursor-pointer shop-item">
        <img src="${avatarUrl}" 
             class="w-10 h-10 rounded-full object-cover border-2 ${CURRENT_USER_ROLE === "customer" ? 'border-orange-200' : 'border-emerald-200'}"
             onerror="this.src='/images/default-avatar.png'">
        <div class="flex-1">
          <h6 class="font-semibold">${tenNguoiNhan}</h6>
          <p class="text-xs text-gray-500">${shop.tinNhanCuoi || ""}</p>
        </div>
        <span class="text-xs ${shop.online ? 'text-green-500' : 'text-gray-400'}">${shop.online ? "Online" : "Offline"}</span>
      </div>
      <button class="delete-conversation-btn text-red-500 hover:text-red-700 opacity-70 group-hover:opacity-100 transition-opacity p-2 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20"
              title="Xóa hội thoại"
              onclick="event.stopPropagation(); deleteConversation('${shop._id}')">
        <i class="fas fa-trash-alt"></i>
      </button>
    `;
    
    // Thêm event listener cho shop item
    const shopItem = div.querySelector(".shop-item");
    shopItem.addEventListener("click", () => selectShop(shop));
    
    // Event listener cho nút xóa đã được thêm qua onclick attribute
    // Giữ lại để đảm bảo hoạt động
    const deleteBtn = div.querySelector(".delete-conversation-btn");
    if (deleteBtn && !deleteBtn.onclick) {
      deleteBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        deleteConversation(shop._id);
      });
    }
    
    shopListContainer.appendChild(div);
  });
}

function filterShops(keyword) {
  const filtered = conversations.filter(c => {
    const name = CURRENT_USER_ROLE === "customer" ? c.tenShop : c.tenKhachHang;
    return name.toLowerCase().includes(keyword.toLowerCase());
  });
  renderShopList(filtered);
}

async function deleteConversation(conversationId) {
  if (!confirm("Bạn có chắc chắn muốn xóa đoạn hội thoại này?")) {
    return;
  }

  try {
    console.log("🗑️ Deleting conversation:", conversationId, "Role:", CURRENT_USER_ROLE);
    const res = await fetch(`http://localhost:4000/api/conversations/${conversationId}`, {
      method: "DELETE",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ role: CURRENT_USER_ROLE })
    });
    console.log("🗑️ Delete response status:", res.status);

    if (!res.ok) {
      throw new Error("Không thể xóa hội thoại");
    }

    // Nếu đang chat với shop này, quay lại danh sách
    if (selectedShop && selectedShop._id === conversationId) {
      showShopSelection();
    }

    // Reload lại danh sách từ server để đảm bảo dữ liệu chính xác
    await loadConversations();
    
    // Giữ lại filter nếu đang tìm kiếm
    const searchInput = document.getElementById('shopSearchInput');
    const keyword = searchInput ? searchInput.value : "";
    if (keyword) {
      filterShops(keyword);
    }

    // Hiển thị thông báo thành công
    alert("Đã xóa hội thoại thành công");
  } catch (err) {
    console.error("Delete conversation error:", err);
    alert("Không thể xóa hội thoại. Vui lòng thử lại.");
  }
}

async function selectShop(shop) {
  selectedShop = shop;

  const receiverId = CURRENT_USER_ROLE === "customer" ? shop.maUserBan : shop.maKH;
  const receiverName = CURRENT_USER_ROLE === "customer" ? shop.tenShop : shop.tenKhachHang;
  const receiverImage = CURRENT_USER_ROLE === "customer" ? shop.hinhAnh : shop.hinhKH;

  try {
    console.log("🔵 Starting conversation with shop:", shop);
    const startRes = await fetch(`http://localhost:4000/api/conversations/start`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ 
        maKH: shop.maKH, 
        maUserBan: shop.maUserBan,
        role: CURRENT_USER_ROLE 
      })
    });
    
    if (!startRes.ok) {
      const errorText = await startRes.text();
      console.error("❌ Failed to start conversation:", startRes.status, errorText);
      // Vẫn tiếp tục để mở chat, nhưng có thể filter không hoạt động
    } else {
      const startData = await startRes.json();
      console.log("✅ Conversation started/restored:", startData);
    }

    const shopSelection = document.getElementById("shopSelection");
    const chatArea = document.getElementById("chatArea");

    shopSelection.classList.add("hidden");
    shopSelection.classList.remove("block");

    chatArea.classList.remove("hidden");
    chatArea.classList.add("flex");

    document.getElementById("selectedShopImage").src = receiverImage || '/images/default-avatar.png';
    document.getElementById("selectedShopName").textContent = receiverName;
    document.getElementById("selectedShopStatus").textContent = shop.online ? "Online" : "Offline";
    
    // Cập nhật lại avatar của user hiện tại (để đảm bảo có avatar mới nhất)
    updateCurrentUserInfo();

    await loadChatHistory(receiverId);
  } catch (err) {
    console.error("Select shop error:", err);
  }
}

async function loadChatHistory(shopId) {
  try {
    let url = "";
    if (CURRENT_USER_ROLE === "customer") {
      url = `http://localhost:4000/api/chat/history?maKH=${CURRENT_USER_ID}&maUserBan=${shopId}&role=${CURRENT_USER_ROLE}`;
    } else if (CURRENT_USER_ROLE === "seller") {
      url = `http://localhost:4000/api/chat/history?maKH=${selectedShop.maKH}&maUserBan=${CURRENT_USERBAN_ID}&role=${CURRENT_USER_ROLE}`;
    }

    const res = await fetch(url);
    if (!res.ok) throw new Error("Load history failed");

    const messages = await res.json();
    console.log(`📨 Loaded ${messages.length} messages for chat history`);
    const container = document.getElementById("chatMessages");
    container.innerHTML = "";
    messages.forEach(msg => {
      const type = msg.nguoiGui === CURRENT_USER_ROLE ? 'sent' : 'received';
      displayMessage(msg, type);
    });
    container.scrollTop = container.scrollHeight;
  } catch (err) {
    console.error(err);
  }
}

function displayMessage(msg, type) {
  const container = document.getElementById("chatMessages");
  const messageDiv = document.createElement("div");
  
  // Lấy avatar hiện tại (có thể đã được cập nhật bởi updateCurrentUserInfo)
  const currentAvatarEl = document.getElementById('currentUserAvatar');
  const currentAvatar = currentAvatarEl ? currentAvatarEl.src : CURRENT_USER_AVATAR;
  const currentNameEl = document.getElementById('currentUserName');
  const currentName = currentNameEl ? currentNameEl.textContent : CURRENT_USER_NAME;
  
  if (type === 'sent') {
    // Tin nhắn đã gửi - hiển thị bên phải với avatar của user hiện tại
    messageDiv.className = "flex items-end gap-2 justify-end";
    messageDiv.innerHTML = `
      <div class="flex flex-col items-end max-w-[75%]">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs text-gray-500 dark:text-gray-400">${currentName}</span>
        </div>
        <div class="flex items-end gap-2">
          <div class="p-2 px-4 rounded-2xl bg-orange-500 text-white text-sm shadow">
            <div>${msg.noiDung}</div>
            <div class="text-[10px] text-right opacity-70 mt-1">${new Date(msg.createdAt || Date.now()).toLocaleTimeString()}</div>
          </div>
          <img src="${currentAvatar}" 
               class="w-8 h-8 rounded-full border-2 border-orange-500 object-cover flex-shrink-0"
               onerror="this.src='/images/default-avatar.png'">
        </div>
      </div>
    `;
  } else {
    // Tin nhắn nhận được - hiển thị bên trái với avatar của người gửi
    const senderAvatar = selectedShop ? (CURRENT_USER_ROLE === "customer" ? selectedShop.hinhAnh : selectedShop.hinhKH) : '/images/default-avatar.png';
    const senderName = selectedShop ? (CURRENT_USER_ROLE === "customer" ? selectedShop.tenShop : selectedShop.tenKhachHang) : 'Người gửi';
    
    messageDiv.className = "flex items-end gap-2 justify-start";
    messageDiv.innerHTML = `
      <div class="flex flex-col items-start max-w-[75%]">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs text-gray-500 dark:text-gray-400">${senderName}</span>
        </div>
        <div class="flex items-end gap-2">
          <img src="${senderAvatar}" 
               class="w-8 h-8 rounded-full border-2 border-gray-300 dark:border-gray-600 object-cover flex-shrink-0"
               onerror="this.src='/images/default-avatar.png'">
          <div class="p-2 px-4 rounded-2xl bg-gray-200 dark:bg-gray-700 text-sm shadow">
            <div class="text-gray-800 dark:text-gray-200">${msg.noiDung}</div>
            <div class="text-[10px] text-right opacity-70 mt-1 text-gray-600 dark:text-gray-400">${new Date(msg.createdAt || Date.now()).toLocaleTimeString()}</div>
          </div>
        </div>
      </div>
    `;
  }
  
  container.appendChild(messageDiv);
  container.scrollTop = container.scrollHeight;
}

function showShopSelection() {
  const shopSelection = document.getElementById("shopSelection");
  const chatArea = document.getElementById("chatArea");
  shopSelection.classList.remove("hidden");
  shopSelection.classList.add("block");
  chatArea.classList.add("hidden");
  chatArea.classList.remove("flex");
  selectedShop = null;
}

function sendMessage() {
  const input = document.getElementById("messageInput");
  const message = input.value.trim();
  if (!message || !selectedShop) return;

  let fromId, toId;
  if (CURRENT_USER_ROLE === "customer") {
    fromId = CURRENT_USER_ID;
    toId = selectedShop.maUserBan;
  } else {
    fromId = CURRENT_USERBAN_ID;
    toId = selectedShop.maKH;
  }

  const msg = { from: fromId, to: toId, noiDung: message, nguoiGui: CURRENT_USER_ROLE };
  displayMessage(msg, 'sent');
  socket.emit("send_message", msg);
  input.value = "";
}

document.getElementById("messageInput").addEventListener("keypress", (e) => {
  if (e.key === "Enter") sendMessage();
});
</script>
