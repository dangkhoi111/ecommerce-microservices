<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Web Bán Hàng</title>
    <!-- Tailwind CSS (CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        if (window.tailwind) {
            tailwind.config = {
                darkMode: 'class'
            }
        }
    </script>
    <!-- Early theme boot: avoid flash and ensure site-wide dark -->
    <script>
        (function() {
            try {
                var saved = localStorage.getItem('theme');
                var isDark = saved === 'dark';
                if (isDark) {
                    document.documentElement.setAttribute('data-theme', 'dark');
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.removeAttribute('data-theme');
                    document.documentElement.classList.remove('dark');
                }
            } catch (_) {}
        })();
    </script>
    <!-- Alpine.js for lightweight interactivity -->
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body class="bg-neutral-50 text-slate-800 dark:bg-slate-900 dark:text-slate-100">
    <!-- Modern Header - REST RECOVERY Inspired -->
<header class="sticky top-0 z-50 bg-white/95 dark:bg-black/95 backdrop-blur-xl border-b border-slate-200 dark:border-neutral-800 shadow-sm">
    <!-- Top Announcement Banner -->
    <div x-data="{ open: localStorage.getItem('bannerDismissed') !== '1' }" x-show="open" x-transition class="bg-gradient-to-r from-orange-500 via-yellow-500 to-amber-500 dark:from-yellow-600 dark:via-yellow-500 dark:to-amber-500 text-white">
        <div class="container mx-auto px-4 py-2.5 flex items-center justify-between gap-4">
            <div class="flex items-center gap-2.5 text-sm font-medium">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm">
                    <i class="fas fa-bolt text-xs"></i>
                </span>
                <span class="font-bold">MegaStore VN</span>
                <span class="hidden sm:inline opacity-95">— Miễn phí vận chuyển toàn quốc • Bảo hành chính hãng</span>
            </div>
            <div class="flex items-center gap-3">
                <a href="/products" class="hidden sm:inline-flex items-center gap-2 bg-white/20 hover:bg-white/30 px-4 py-1.5 rounded-full text-sm font-semibold transition-all backdrop-blur-sm">
                    <i class="fas fa-sparkles"></i>
                    <span>Khám phá ngay</span>
                </a>
                <button @click="open=false; localStorage.setItem('bannerDismissed','1')" class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-white/10 hover:bg-white/20 transition-all" aria-label="Đóng">
                    <i class="fas fa-xmark"></i>
                </button>
            </div>
        </div>
</div>

    <!-- Top Bar - Utilities -->
    <div class="border-b border-slate-100 dark:border-neutral-900 bg-slate-50/50 dark:bg-neutral-950/50">
        <div class="container mx-auto px-4">
            <div class="flex items-center justify-between h-10 text-xs">
                <!-- Left Section -->
                <div class="flex items-center gap-4">
                    <a href="#" class="flex items-center gap-1.5 text-slate-600 dark:text-neutral-400 hover:text-orange-500 dark:hover:text-yellow-500 transition-colors">
                        <i class="fas fa-bell"></i>
                        <span class="hidden sm:inline font-medium">Thông báo</span>
                    </a>
                    <a href="/support" class="flex items-center gap-1.5 text-slate-600 dark:text-neutral-400 hover:text-orange-500 dark:hover:text-yellow-500 transition-colors">
                        <i class="fas fa-headset"></i>
                        <span class="hidden sm:inline font-medium">Hỗ trợ</span>
                    </a>
                </div>

                <!-- Right Section -->
                <div class="flex items-center gap-4">
                    <!-- Theme Toggle -->
                    <button id="theme-toggle" class="flex items-center gap-1.5 text-slate-600 dark:text-neutral-400 hover:text-orange-500 dark:hover:text-yellow-500 transition-colors font-medium">
                        <i class="fas fa-moon"></i>
                        <span class="hidden sm:inline">Giao diện</span>
                    </button>

                    <!-- User Dropdown -->
                    <div class="user-dropdown relative" style="display: none;">
                        <button class="user-greeting flex items-center gap-2 text-slate-900 dark:text-white hover:text-orange-500 dark:hover:text-yellow-500 transition-colors font-medium">
                            <div class="w-6 h-6 rounded-full bg-gradient-to-br from-orange-500 to-yellow-500 dark:from-yellow-500 dark:to-amber-500 flex items-center justify-center text-white text-xs font-bold overflow-hidden">
                                <img id="user-avatar-header" src="" alt="Avatar" class="w-full h-full object-cover hidden" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                <i class="fas fa-user"></i>
                            </div>
                            <span class="hidden sm:inline" id="user-name"></span>
                            <i class="fas fa-chevron-down text-xs"></i>
                        </button>
                        <div class="dropdown-menu absolute right-0 top-full mt-2 w-56 bg-white dark:bg-neutral-900 rounded-xl shadow-xl border border-slate-200 dark:border-neutral-800 py-2 hidden">
                            <a href="/profile" class="flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 dark:text-neutral-300 hover:bg-slate-50 dark:hover:bg-neutral-800 transition-colors">
                                <i class="fas fa-user-circle w-4"></i>
                                <span>Tài khoản của tôi</span>
                            </a>
                            <a href="/purchase?maKH=" id="purchase-link" class="flex items-center gap-3 px-4 py-2.5 text-sm text-slate-700 dark:text-neutral-300 hover:bg-slate-50 dark:hover:bg-neutral-800 transition-colors">
                                <i class="fas fa-box w-4"></i>
                                <span>Đơn mua</span>
                            </a>
                            <hr class="my-2 border-slate-200 dark:border-neutral-800">
                            <a href="#" onclick="logout()" class="flex items-center gap-3 px-4 py-2.5 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-500/10 transition-colors">
                                <i class="fas fa-sign-out-alt w-4"></i>
                                <span>Đăng xuất</span>
                            </a>
                        </div>
                    </div>

                    <!-- Auth Buttons -->
                    <div class="auth-buttons flex items-center gap-3" style="display: none;">
                        <a href="/login" class="flex items-center gap-1.5 text-slate-600 dark:text-neutral-400 hover:text-orange-500 dark:hover:text-yellow-500 transition-colors font-medium">
                            <i class="fas fa-sign-in-alt"></i>
                            <span class="hidden sm:inline">Đăng nhập</span>
                        </a>
                        <a href="/register" class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-gradient-to-r from-orange-500 to-yellow-500 dark:from-yellow-500 dark:to-amber-500 text-white text-xs font-bold hover:shadow-lg transition-all">
                            <i class="fas fa-user-plus"></i>
                            <span class="hidden sm:inline">Đăng ký</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Header -->
    <div class="py-4">
        <div class="container mx-auto px-4">
            <div class="flex items-center gap-6">
                <!-- Logo -->
                <a href="/" class="flex items-center gap-3 group">
                    <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-orange-500 via-yellow-500 to-amber-500 dark:from-yellow-500 dark:via-yellow-400 dark:to-amber-500 flex items-center justify-center text-white font-black text-lg shadow-lg shadow-orange-500/30 dark:shadow-yellow-500/30 group-hover:scale-105 transition-transform">
                        M
                    </div>
                    <div class="hidden sm:block">
                        <h1 class="text-xl font-black text-slate-900 dark:text-white leading-tight">MegaStore</h1>
                        <p class="text-xs text-slate-500 dark:text-neutral-500 font-medium">Vietnam</p>
                    </div>
                </a>

                <!-- Search Bar -->
                <div class="flex-1 max-w-2xl">
                    <form action="/products" method="GET" class="relative" id="search-form">
                        <div class="relative flex items-center">
                            <i class="fas fa-search absolute left-4 text-slate-400 dark:text-neutral-500 z-10"></i>
                            <input 
                                type="text" 
                                name="q" 
                                id="search-input"
                                placeholder="Tìm kiếm sản phẩm, thương hiệu..." 
                                required 
                                class="w-full pl-11 pr-32 py-3 rounded-full border-2 border-slate-200 dark:border-neutral-800 bg-slate-50 dark:bg-neutral-900 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-neutral-500 focus:border-orange-500 dark:focus:border-yellow-500 focus:bg-white dark:focus:bg-neutral-800 outline-none transition-all text-sm"
                            >
                            <button 
                                type="submit" 
                                id="search-submit-btn"
                                class="absolute right-2 px-6 py-2 rounded-full bg-gradient-to-r from-orange-500 to-yellow-500 dark:from-yellow-500 dark:to-amber-500 text-white font-bold text-sm hover:shadow-lg hover:shadow-orange-500/30 dark:hover:shadow-yellow-500/30 transition-all z-10"
                            >
                                <i class="fas fa-search mr-2"></i>
                                <span class="hidden sm:inline">Tìm kiếm</span>
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Action Buttons -->
                <div class="flex items-center gap-3">
                    <!-- Seller Channel -->
                    <a href="/seller" id="seller-channel-link" class="hidden md:inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-slate-900 dark:bg-white text-white dark:text-black font-bold text-sm hover:scale-105 transition-transform shadow-md">
                    <i class="fas fa-store"></i>
                        <span>Người bán</span>
                    </a>

                    <!-- Cart -->
                    <a id="cart-link" href="/cart" class="relative inline-flex items-center justify-center w-12 h-12 rounded-full bg-slate-100 dark:bg-neutral-900 hover:bg-slate-200 dark:hover:bg-neutral-800 transition-colors group">
                        <i class="fas fa-shopping-cart text-slate-700 dark:text-white group-hover:scale-110 transition-transform"></i>
                        <span class="cart-count absolute -top-1 -right-1 w-5 h-5 rounded-full bg-gradient-to-r from-orange-500 to-yellow-500 dark:from-yellow-500 dark:to-amber-500 text-white text-xs font-bold flex items-center justify-center shadow-lg">0</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="border-t border-slate-100 dark:border-neutral-900 bg-white/50 dark:bg-black/50 backdrop-blur-sm">
        <div class="container mx-auto px-4">
            <!-- Mobile Toggle -->
            <button id="nav-toggle" class="md:hidden py-3 flex items-center gap-2 text-slate-700 dark:text-white font-semibold" aria-label="Toggle navigation" aria-expanded="false">
                <i class="fas fa-bars"></i>
                <span class="text-sm">Menu</span>
            </button>

            <!-- Navigation Links -->
            <ul class="hidden md:flex items-center gap-8 py-3 text-sm font-semibold">
                <li>
                    <a href="/" class="text-slate-700 dark:text-neutral-300 hover:text-orange-500 dark:hover:text-yellow-500 transition-colors flex items-center gap-2">
                        <i class="fas fa-home"></i>
                        <span>Trang chủ</span>
                    </a>
                </li>
                <li>
                    <a href="/products" class="text-slate-700 dark:text-neutral-300 hover:text-orange-500 dark:hover:text-yellow-500 transition-colors flex items-center gap-2">
                        <i class="fas fa-th-large"></i>
                        <span>Sản phẩm</span>
                    </a>
                </li>
                <li>
                    <a href="/blog" class="text-slate-700 dark:text-neutral-300 hover:text-orange-500 dark:hover:text-yellow-500 transition-colors flex items-center gap-2">
                        <i class="fas fa-newspaper"></i>
                        <span>Blog</span>
                    </a>
                </li>
                <li>
                    <a href="/about" class="text-slate-700 dark:text-neutral-300 hover:text-orange-500 dark:hover:text-yellow-500 transition-colors flex items-center gap-2">
                        <i class="fas fa-info-circle"></i>
                        <span>Về chúng tôi</span>
                    </a>
                </li>
                <li>
                    <a href="/contact" class="text-slate-700 dark:text-neutral-300 hover:text-orange-500 dark:hover:text-yellow-500 transition-colors flex items-center gap-2">
                        <i class="fas fa-envelope"></i>
                        <span>Liên hệ</span>
                    </a>
                </li>
                <li class="ml-auto">
                    <a href="#flash-sale" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-orange-500 to-yellow-500 dark:from-yellow-500 dark:to-amber-500 text-white font-bold text-xs hover:shadow-lg hover:shadow-orange-500/30 dark:hover:shadow-yellow-500/30 transition-all animate-pulse">
                        <i class="fas fa-bolt"></i>
                        <span>FLASH SALE</span>
                    </a>
                </li>
            </ul>

            <!-- Mobile Menu -->
            <ul id="mobile-menu" class="md:hidden hidden flex-col gap-2 py-4 border-t border-slate-200 dark:border-neutral-800">
                <li><a href="/" class="block py-2 text-slate-700 dark:text-neutral-300 hover:text-orange-500 dark:hover:text-yellow-500"><i class="fas fa-home mr-2"></i>Trang chủ</a></li>
                <li><a href="/products" class="block py-2 text-slate-700 dark:text-neutral-300 hover:text-orange-500 dark:hover:text-yellow-500"><i class="fas fa-th-large mr-2"></i>Sản phẩm</a></li>
                <li><a href="/blog" class="block py-2 text-slate-700 dark:text-neutral-300 hover:text-orange-500 dark:hover:text-yellow-500"><i class="fas fa-newspaper mr-2"></i>Blog</a></li>
                <li><a href="/about" class="block py-2 text-slate-700 dark:text-neutral-300 hover:text-orange-500 dark:hover:text-yellow-500"><i class="fas fa-info-circle mr-2"></i>Về chúng tôi</a></li>
                <li><a href="/contact" class="block py-2 text-slate-700 dark:text-neutral-300 hover:text-orange-500 dark:hover:text-yellow-500"><i class="fas fa-envelope mr-2"></i>Liên hệ</a></li>
                <li><a href="/seller" class="block py-2 text-orange-500 dark:text-yellow-500 font-bold"><i class="fas fa-store mr-2"></i>Kênh người bán</a></li>
            </ul>
        </div>
    </nav>
</header>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Theme initialization
    const savedTheme = localStorage.getItem('theme') || 'light';
    if (savedTheme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
    } else {
        document.documentElement.removeAttribute('data-theme');
    }
    const themeToggleBtn = document.getElementById('theme-toggle');
    const themeIcon = themeToggleBtn.querySelector('i');
    const applyIcon = () => {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        themeIcon.classList.toggle('fa-moon', !isDark);
        themeIcon.classList.toggle('fa-sun', isDark);
    };
    applyIcon();
    themeToggleBtn.addEventListener('click', function() {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
            document.documentElement.removeAttribute('data-theme');
            document.documentElement.classList.remove('dark');
            localStorage.setItem('theme', 'light');
        } else {
            document.documentElement.setAttribute('data-theme', 'dark');
            document.documentElement.classList.add('dark');
            localStorage.setItem('theme', 'dark');
        }
        applyIcon();
    });

    // Mobile nav toggle
    const navToggle = document.getElementById('nav-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    if (navToggle && mobileMenu) {
        navToggle.addEventListener('click', function() {
            const isOpen = mobileMenu.classList.contains('hidden');
            if (isOpen) {
                mobileMenu.classList.remove('hidden');
                mobileMenu.classList.add('flex');
                navToggle.setAttribute('aria-expanded', 'true');
            } else {
                mobileMenu.classList.add('hidden');
                mobileMenu.classList.remove('flex');
                navToggle.setAttribute('aria-expanded', 'false');
            }
        });
    }

    // User dropdown toggle
    const userGreeting = document.querySelector('.user-greeting');
    const dropdownMenu = document.querySelector('.dropdown-menu');
    if (userGreeting && dropdownMenu) {
        userGreeting.addEventListener('click', function(e) {
            e.stopPropagation();
            dropdownMenu.classList.toggle('hidden');
        });
        
        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.user-dropdown')) {
                dropdownMenu.classList.add('hidden');
            }
        });
    }

    const authToken = localStorage.getItem('authToken');
    const userInfo = localStorage.getItem('userInfo') ? JSON.parse(localStorage.getItem('userInfo')) : null;

    const userMenu = document.querySelector('.user-dropdown');
    const authButtons = document.querySelector('.auth-buttons');
    const purchaseLink = document.getElementById('purchase-link');  // Lấy phần tử "Đơn Mua"

    // Hàm cập nhật avatar trong header
    const updateHeaderAvatar = (avatarUrl) => {
        const userAvatarHeader = document.getElementById('user-avatar-header');
        const userIcon = userAvatarHeader?.nextElementSibling;
        if (avatarUrl) {
            if (userAvatarHeader) {
                userAvatarHeader.src = avatarUrl;
                userAvatarHeader.classList.remove('hidden');
                if (userIcon) userIcon.style.display = 'none';
            }
        } else {
            if (userAvatarHeader) userAvatarHeader.classList.add('hidden');
            if (userIcon) userIcon.style.display = 'flex';
        }
    };

    if (authToken && userInfo) {
        // Đã đăng nhập
        userMenu.style.display = 'block';
        document.getElementById('user-name').textContent = userInfo.hoTen;
        authButtons.style.display = 'none';
        
        // Cập nhật avatar từ localStorage
        updateHeaderAvatar(userInfo.avatar);
        
        // Nếu không có avatar trong localStorage, fetch từ API để đảm bảo có avatar mới nhất
        if (!userInfo.avatar && userInfo.id) {
            fetch(`http://localhost:3002/api/auth/${userInfo.id}`)
                .then(response => response.json())
                .then(result => {
                    if (result.success && result.data && result.data.avatar) {
                        // Cập nhật localStorage
                        userInfo.avatar = result.data.avatar;
                        localStorage.setItem('userInfo', JSON.stringify(userInfo));
                        // Cập nhật UI
                        updateHeaderAvatar(result.data.avatar);
                    }
                })
                .catch(error => {
                    console.error('Lỗi khi fetch avatar từ API:', error);
                });
        }

          // Cập nhật liên kết "Đơn Mua" với maKH
        if (userInfo.id) {
            purchaseLink.href = `/purchase?maKH=${userInfo.id}`;
        }
    } else {
        // Chưa đăng nhập
        authButtons.style.display = 'block';
        userMenu.style.display = 'none';
    }

    // Xử lý click "Người bán hàng"
    const sellerLink = document.getElementById('seller-channel-link');
    sellerLink.addEventListener('click', function(event) {
        event.preventDefault(); // Chặn mặc định

        if (!authToken || !userInfo) {
            alert('Bạn cần đăng nhập tài khoản khách hàng trước!');
            window.location.href = '/login';
            return;
        }

        if (userInfo.role === 'seller') {
            window.location.href = '/seller'; // Đã là người bán
        } else {
            window.location.href = '/seller/register'; // Chưa là người bán
        }
    });
    const cartLink = document.getElementById('cart-link');
    if (authToken && userInfo && userInfo.id) {
        cartLink.href = `/cart?maKH=${userInfo.id}`;
    } else {
        cartLink.href = '/login'; // hoặc giữ nguyên /cart rồi xử lý trong backend
    }

    // Xử lý form tìm kiếm
    const searchForm = document.getElementById('search-form');
    const searchInput = document.getElementById('search-input');
    const searchSubmitBtn = document.getElementById('search-submit-btn');

    if (searchForm && searchInput && searchSubmitBtn) {
        // Xử lý submit form
        searchForm.addEventListener('submit', function(e) {
            const query = searchInput.value.trim();
            if (!query) {
                e.preventDefault();
                searchInput.focus();
                return false;
            }
            // Form sẽ submit tự động với action="/products" và method="GET"
        });

        // Xử lý khi nhấn Enter trong input
        searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                const query = searchInput.value.trim();
                if (query) {
                    searchForm.submit();
                }
            }
        });

        // Xử lý click nút tìm kiếm
        searchSubmitBtn.addEventListener('click', function(e) {
            const query = searchInput.value.trim();
            if (!query) {
                e.preventDefault();
                searchInput.focus();
                return false;
            }
            // Form sẽ submit tự động
        });
    }
});

// Xử lý logout
function logout() {
    localStorage.removeItem('authToken');
    localStorage.removeItem('userInfo');
    localStorage.removeItem('hoTen'); 
    window.location.reload();
}
async function updateCartCountOnHeaderGlobal() {
    const userInfo = localStorage.getItem('userInfo') ? JSON.parse(localStorage.getItem('userInfo')) : null;
    if (!userInfo || !userInfo.id) return;
    try {
        // Lấy giỏ hàng của user
        const cartRes = await fetch(`http://localhost:3003/api/cart/${userInfo.id}`);
        if (!cartRes.ok) return;
        const cartData = await cartRes.json();
        if (!cartData._id) return;
        // Lấy chi tiết giỏ hàng
        const detailRes = await fetch(`http://localhost:3003/api/detailcart/${cartData._id}`);
        if (!detailRes.ok) return;
        const items = await detailRes.json();
        document.querySelectorAll('.cart-count').forEach(el => {
            el.textContent = items.length;
        });
    } catch (e) {
        // Nếu lỗi thì để 0
        document.querySelectorAll('.cart-count').forEach(el => {
            el.textContent = 0;
        });
    }
}

// Gọi hàm này khi load header
document.addEventListener('DOMContentLoaded', function() {
    updateCartCountOnHeaderGlobal();
});
</script>

</body>
</html> 