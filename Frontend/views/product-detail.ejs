    // Hàm lấy và hiển thị danh sách đánh giá
    async function fetchReviews(productId, page = 1, limit = 10, filterRating = null) {
        try {
            let url = `http://localhost:3010/api/reviews/sanpham/${productId}?page=${page}&limit=${limit}`;
            if (filterRating && filterRating !== 'all') {
                url += `&rating=${filterRating}`;
            }

            const res = await fetch(url);
            if (!res.ok) {
                const errorData = await res.json();
                throw new Error(errorData.error || 'Không thể lấy đánh giá');
            }
            const responseData = await res.json();
            const reviews = responseData.reviews || [];
            const totalReviews = responseData.totalReviews || reviews.length;
            const totalPages = responseData.totalPages || 1;
            const currentPage = responseData.currentPage || page;

            console.log('Reviews render:', {
                reviewsCount: reviews.length,
                totalReviews: totalReviews,
                reviews: reviews.map(r => ({ diemSo: r.diemSo, _id: r._id }))
            });

            const reviewsList = document.querySelector('.reviews-list');
            const userInfo = localStorage.getItem('userInfo') ? JSON.parse(localStorage.getItem('userInfo')) : null;
            const currentUserId = userInfo ? userInfo.id : null;
            
            reviewsList.innerHTML = reviews.length > 0 ? reviews.map(review => {
                console.log('Review data:', {
                    _id: review._id,
                    diemSo: review.diemSo,
                    diemSoType: typeof review.diemSo,
                    diemSoRaw: JSON.stringify(review.diemSo)
                });
                
                // Xử lý diemSo - đảm bảo là số nguyên từ 1-5
                let diemSo = 1; // Default
                if (review.diemSo !== null && review.diemSo !== undefined) {
                    const parsed = parseInt(review.diemSo, 10);
                    if (!isNaN(parsed) && parsed >= 1 && parsed <= 5) {
                        diemSo = parsed;
                    } else {
                        console.warn('Invalid diemSo:', review.diemSo, 'defaulting to 1');
                    }
                }
                
                console.log('Final diemSo for display:', diemSo);
                
                // Hiển thị sao - tạo HTML bằng cách lặp để đảm bảo chính xác
                let starsHTML = '';
                let filledCount = 0;
                let emptyCount = 0;
                for (let i = 1; i <= 5; i++) {
                    if (i <= diemSo) {
                        starsHTML += '<i class="fas fa-star filled"></i>';
                        filledCount++;
                    } else {
                        starsHTML += '<i class="far fa-star"></i>';
                        emptyCount++;
                    }
                }
                
                console.log(`Stars HTML for review ${review._id}: diemSo=${diemSo}, filled=${filledCount}, empty=${emptyCount}`);
                
                // Kiểm tra xem đánh giá này có phải của user hiện tại không
                const isMyReview = currentUserId && String(review.maKH) === String(currentUserId);
                
                // Lấy avatar từ review hoặc từ userInfo nếu là review của user hiện tại
                let avatarUrl = '/images/default-avatar.png';
                if (review.avatar) {
                    avatarUrl = review.avatar;
                } else if (isMyReview && userInfo && userInfo.avatar) {
                    avatarUrl = userInfo.avatar;
                }
                
                return `
                    <div class="review-item" data-review-id="${review._id}" data-rating="${diemSo}">
                        <div class="review-user">
                            <img src="${avatarUrl}" alt="User Avatar" class="user-avatar" onerror="this.src='/images/default-avatar.png'">
                            <span class="user-name">${review.hoTen || 'Ẩn danh'}</span>
                            ${isMyReview ? '<span class="my-review-badge" style="margin-left: 8px; padding: 2px 8px; background: linear-gradient(to right, #f97316, #eab308); color: white; border-radius: 12px; font-size: 12px;">Đánh giá của bạn</span>' : ''}
                        </div>
                        <div class="review-content">
                            <div class="review-rating" data-rating="${diemSo}">
                                ${starsHTML}
                            </div>
                            <div class="review-date">${new Date(review.ngayDG).toLocaleString('vi-VN')} | Phân loại hàng: BROWN,M</div>
                            <div class="review-text" id="review-text-${review._id}">${review.noiDung || 'Không có bình luận'}</div>
                            <div class="review-actions">
                                ${isMyReview ? `
                                    <button class="btn-edit-review" data-review-id="${review._id}" data-rating="${diemSo}" data-comment="${(review.noiDung || '').replace(/"/g, '&quot;')}" style="margin-right: 8px; padding: 6px 12px; background: linear-gradient(to right, #f97316, #eab308); color: white; border: none; border-radius: 4px; cursor: pointer;">
                                        <i class="fas fa-edit"></i> Sửa
                                    </button>
                                    <button class="btn-delete-review" data-review-id="${review._id}" style="margin-right: 8px; padding: 6px 12px; background: #f44336; color: white; border: none; border-radius: 4px; cursor: pointer;">
                                        <i class="fas fa-trash"></i> Xóa
                                    </button>
                                ` : `
                                    <button class="btn-helpful">
                                        <i class="far fa-thumbs-up"></i>
                                        Hữu ích?
                                    </button>
                                    <button class="btn-report">
                                        <i class="far fa-flag"></i>
                                        Báo cáo
                                    </button>
                                `}
                            </div>
                        </div>
                    </div>
                `;
            }).join('') : '<p>Chưa có đánh giá nào.</p>';

            const averageRating = reviews.length > 0 
                ? (reviews.reduce((sum, review) => sum + Number(review.diemSo || 0), 0) / reviews.length)
                : 0;
            const ratingCounts = [0, 0, 0, 0, 0];
            reviews.forEach(review => {
                const diemSo = Number(review.diemSo || 0);
                if (diemSo >= 1 && diemSo <= 5) {
                    ratingCounts[diemSo - 1]++;
                }
            });

            document.querySelector('.rating-score .score').textContent = averageRating.toFixed(1);
            
            // Hiển thị sao chính xác với sao nửa
            const fullStars = Math.floor(averageRating);
            const hasHalfStar = averageRating % 1 >= 0.5;
            const emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);
            
            let starsHTML = '';
            for (let i = 0; i < fullStars; i++) {
                starsHTML += '<i class="fas fa-star filled"></i>';
            }
            if (hasHalfStar) {
                starsHTML += '<i class="fas fa-star-half-alt filled"></i>';
            }
            for (let i = 0; i < emptyStars; i++) {
                starsHTML += '<i class="far fa-star"></i>';
            }
            
            document.querySelector('.rating-score .stars').innerHTML = starsHTML;

            const filterButtons = document.querySelectorAll('.rating-filters .filter-btn');
            filterButtons.forEach((btn, index) => {
                if (index > 0 && index <= 5) {
                    btn.textContent = `${5 - index + 1} Sao (${ratingCounts[5 - index]})`;
                } else if (btn.dataset.filter === 'comment') {
                    btn.textContent = `Có Bình Luận (${reviews.filter(r => r.noiDung).length})`;
                } else if (btn.dataset.filter === 'media') {
                    btn.textContent = `Có Hình Ảnh / Video (0)`; // Chưa hỗ trợ media
                }
            });

            const pagination = document.querySelector('.reviews-pagination');
            pagination.innerHTML = `
                ${Array.from({ length: totalPages }, (_, i) => `
                    <button class="page-btn ${i + 1 === currentPage ? 'active' : ''}" data-page="${i + 1}">${i + 1}</button>
                `).join('')}
                <button class="page-btn next ${currentPage === totalPages ? 'disabled' : ''}">
                    <i class="fas fa-chevron-right"></i>
                </button>
            `;

            document.querySelectorAll('.page-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const newPage = parseInt(btn.dataset.page) || (btn.classList.contains('next') ? currentPage + 1 : currentPage);
                    if (newPage <= totalPages) {
                        fetchReviews(productId, newPage, limit, filterRating);
                    }
                });
            });

            filterButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    filterButtons.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    const filter = btn.dataset.filter;
                    fetchReviews(productId, 1, limit, filter === 'all' ? null : filter);
                });
            });

            const count5Star = reviews.filter(r => Number(r.diemSo) === 5).length;
            const fiveStarCountEl = document.querySelector('.rating-score .five-star-count');
            if (fiveStarCountEl) {
                fiveStarCountEl.textContent = count5Star;
            }

            return { reviews, totalReviews, totalPages, currentPage };
        } catch (err) {
            console.error('Lỗi khi lấy đánh giá:', err);
            alert(`Không thể tải đánh giá: ${err.message}`);
        }
    }

    // Hàm gửi đánh giá mới
    async function submitReview(productId) {
        const rating = document.getElementById('rating')?.value;
        const comment = document.getElementById('comment')?.value;
        const userInfo = localStorage.getItem('userInfo') ? JSON.parse(localStorage.getItem('userInfo')) : null;

        console.log('Rating gửi lên:', rating, typeof rating);

        if (!userInfo || !userInfo.id) {
            alert('Vui lòng đăng nhập để gửi đánh giá');
            return;
        }
        if (!rating || !comment.trim()) {
            alert('Vui lòng chọn số sao và nhập bình luận');
            return;
        }

        const reviewData = {
            noiDung: comment,
            diemSo: parseInt(rating),
            maKH: userInfo.id,
            maSP: productId
        };

        try {
            const res = await fetch('http://localhost:3010/api/reviews', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(reviewData),
            });

            if (res.ok) {
                alert('Gửi đánh giá thành công!');
                document.getElementById('review-form').reset();
                fetchReviews(productId);
            } else {
                const errorData = await res.json();
                alert(`Có lỗi khi gửi đánh giá: ${errorData.error || 'Vui lòng thử lại'}`);
            }
        } catch (err) {
            console.error('Lỗi khi gửi đánh giá:', err);
            alert('Có lỗi xảy ra. Vui lòng thử lại.');
        }
    }

    // Gọi fetchReviews khi tải trang
    await fetchReviews(productId);

    // Xử lý sự kiện gửi đánh giá
    document.getElementById('review-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        await submitReview(productId);
    });

    // Xử lý sự kiện sửa đánh giá
    document.addEventListener('click', async (e) => {
        if (e.target.closest('.btn-edit-review')) {
            const btn = e.target.closest('.btn-edit-review');
            const reviewId = btn.dataset.reviewId;
            const currentRating = parseInt(btn.dataset.rating);
            const currentComment = btn.dataset.comment;
            
            // Hiển thị form chỉnh sửa
            const newRating = prompt('Nhập số sao (1-5):', currentRating);
            if (!newRating || isNaN(newRating) || newRating < 1 || newRating > 5) {
                alert('Vui lòng nhập số sao hợp lệ (1-5)');
                return;
            }
            
            const newComment = prompt('Nhập bình luận mới:', currentComment);
            if (newComment === null) {
                return; // User cancel
            }
            
            await updateReview(reviewId, parseInt(newRating), newComment);
        }
    });

    // Xử lý sự kiện xóa đánh giá
    document.addEventListener('click', async (e) => {
        if (e.target.closest('.btn-delete-review')) {
            const btn = e.target.closest('.btn-delete-review');
            const reviewId = btn.dataset.reviewId;
            
            if (!confirm('Bạn có chắc chắn muốn xóa đánh giá này?')) {
                return;
            }
            
            await deleteReview(reviewId);
        }
    });

    // Hàm cập nhật đánh giá
    async function updateReview(reviewId, rating, comment) {
        const userInfo = localStorage.getItem('userInfo') ? JSON.parse(localStorage.getItem('userInfo')) : null;
        
        if (!userInfo || !userInfo.id) {
            alert('Vui lòng đăng nhập để sửa đánh giá');
            return;
        }
        
        if (!rating || !comment.trim()) {
            alert('Vui lòng nhập đầy đủ thông tin');
            return;
        }

        try {
            // Sử dụng route đúng với maDG hoặc _id
            const res = await fetch(`http://localhost:3010/api/reviews/${reviewId}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    noiDung: comment,
                    diemSo: rating,
                    maKH: userInfo.id
                }),
            });

            if (res.ok) {
                alert('Cập nhật đánh giá thành công!');
                await fetchReviews(productId); // Reload reviews
            } else {
                const errorData = await res.json();
                alert(`Có lỗi khi cập nhật đánh giá: ${errorData.error || 'Vui lòng thử lại'}`);
            }
        } catch (err) {
            console.error('Lỗi khi cập nhật đánh giá:', err);
            alert('Có lỗi xảy ra. Vui lòng thử lại.');
        }
    }

    // Hàm xóa đánh giá
    async function deleteReview(reviewId) {
        const userInfo = localStorage.getItem('userInfo') ? JSON.parse(localStorage.getItem('userInfo')) : null;
        
        if (!userInfo || !userInfo.id) {
            alert('Vui lòng đăng nhập để xóa đánh giá');
            return;
        }

        try {
            const res = await fetch(`http://localhost:3010/api/reviews/${reviewId}`, {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    maKH: userInfo.id
                }),
            });

            if (res.ok) {
                alert('Xóa đánh giá thành công!');
                await fetchReviews(productId); // Reload reviews
            } else {
                const errorData = await res.json();
                alert(`Có lỗi khi xóa đánh giá: ${errorData.error || 'Vui lòng thử lại'}`);
            }
        } catch (err) {
            console.error('Lỗi khi xóa đánh giá:', err);
            alert('Có lỗi xảy ra. Vui lòng thử lại.');
        }
    }

    // Xử lý tăng/giảm số lượng - sử dụng class mới
    const quantityInput = document.getElementById('quantity');
    const minusBtn = document.querySelector('.qty-btn-modern.minus');
    const plusBtn = document.querySelector('.qty-btn-modern.plus');
    
    if (minusBtn) {
        minusBtn.addEventListener('click', decreaseQuantity);
    }
    
    if (plusBtn) {
        plusBtn.addEventListener('click', increaseQuantity);
    }

    if (quantityInput) {
        quantityInput.addEventListener('input', () => {
            let value = parseInt(quantityInput.value);
            const min = parseInt(quantityInput.getAttribute('min')) || 1;
            const max = parseInt(quantityInput.getAttribute('max')) || 100;
            if (value < min) value = min;
            if (value > max) value = max;
            quantityInput.value = value;
        });
    }
});

// Quantity functions
function increaseQuantity() {
    const quantityInput = document.getElementById('quantity');
    if (!quantityInput) return;
    const currentValue = parseInt(quantityInput.value) || 1;
    const max = parseInt(quantityInput.getAttribute('max')) || 100;
    if (currentValue < max) {
        quantityInput.value = currentValue + 1;
        quantityInput.dispatchEvent(new Event('change'));
    }
}

function decreaseQuantity() {
    const quantityInput = document.getElementById('quantity');
    if (!quantityInput) return;
    const currentValue = parseInt(quantityInput.value) || 1;
    const min = parseInt(quantityInput.getAttribute('min')) || 1;
    if (currentValue > min) {
        quantityInput.value = currentValue - 1;
        quantityInput.dispatchEvent(new Event('change'));
    }
}

// Change main image function
function changeMainImage(thumbnail) {
    const img = thumbnail.querySelector('img');
    if (!img || !img.src) return;
    
    const mainImage = document.getElementById('mainImage');
    if (mainImage) {
        mainImage.src = img.src;
        mainImage.alt = img.alt;
    }
    
    // Update active thumbnail
    document.querySelectorAll('.thumbnail-modern').forEach(thumb => {
        thumb.classList.remove('active');
    });
    thumbnail.classList.add('active');
}

// Thêm vào giỏ hàng từ danh sách sản phẩm
async function addToCartFromList(productId) {
    const userInfo = localStorage.getItem('userInfo') ? JSON.parse(localStorage.getItem('userInfo')) : null;
    if (!userInfo || !userInfo.id) {
        alert('Vui lòng đăng nhập để thêm vào giỏ hàng');
        window.location.href = '/login';
        return;
    }

    const maKH = userInfo.id;

    try {
        // Lấy thông tin giỏ hàng
        const cartRes = await fetch(`http://localhost:3003/api/cart/${maKH}`);
        if (!cartRes.ok) throw new Error('Không thể lấy thông tin giỏ hàng');
        const cartData = await cartRes.json();
        const cartId = cartData._id;

        // Lấy phiên bản mặc định của sản phẩm (nếu có)
        let variantId = null;
        try {
            const variantRes = await fetch(`http://localhost:3001/api/phienban?maSanPham=${productId}`);
            if (variantRes.ok) {
                const variants = await variantRes.json();
                if (variants && variants.length > 0) {
                    // Lấy phiên bản đầu tiên hoặc phiên bản mặc định
                    variantId = variants[0]._id;
                }
            }
        } catch (err) {
            console.warn('Không thể lấy phiên bản sản phẩm:', err);
        }

        if (!variantId) {
            alert('Sản phẩm này chưa có phiên bản. Vui lòng vào trang chi tiết để chọn.');
            window.location.href = `/products/detail/${productId}`;
            return;
        }

        const cartDetailData = {
            maGH: cartId,
            soluong: 1,
            maPB: variantId,
        };

        const detailCartRes = await fetch('http://localhost:3003/api/detailcart/', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(cartDetailData),
        });

        if (detailCartRes.ok) {
            // Track behavior
            try {
                const RECOMMENDATION_SERVICE_URL = 'http://localhost:3011';
                await fetch(`${RECOMMENDATION_SERVICE_URL}/api/recommendation/track`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        maKH: maKH,
                        maSP: productId,
                        hanhDong: 'add_to_cart',
                        metadata: {}
                    })
                });
            } catch (err) {
                console.warn('Failed to track behavior:', err);
            }

            // Hiển thị feedback
            const btn = event.target.closest('.btn-add-cart-mini');
            if (btn) {
                const originalHTML = btn.innerHTML;
                btn.innerHTML = '<i class="fas fa-check"></i>';
                btn.style.background = 'linear-gradient(135deg, #10b981 0%, #059669 100%)';
                btn.style.borderColor = '#10b981';
                btn.style.color = '#fff';
                setTimeout(() => {
                    btn.innerHTML = originalHTML;
                    btn.style.background = '';
                    btn.style.borderColor = '';
                    btn.style.color = '';
                }, 2000);
            }
        } else {
            const errorData = await detailCartRes.json();
            alert(`Có lỗi khi thêm vào giỏ hàng: ${errorData.message || 'Vui lòng thử lại'}`);
        }
    } catch (err) {
        console.error('Lỗi khi thêm vào giỏ hàng:', err);
        alert('Có lỗi xảy ra. Vui lòng thử lại.');
    }
}

// Mua ngay từ danh sách sản phẩm
async function buyNowFromList(productId) {
    const userInfo = localStorage.getItem('userInfo') ? JSON.parse(localStorage.getItem('userInfo')) : null;
    if (!userInfo || !userInfo.id) {
        alert('Vui lòng đăng nhập để mua hàng');
        window.location.href = '/login';
        return;
    }

    // Chuyển đến trang chi tiết sản phẩm để mua ngay
    window.location.href = `/products/detail/${productId}`;
}

// Image fullscreen function
function openImageFullscreen() {
    const mainImage = document.getElementById('mainImage');
    if (!mainImage || !mainImage.src) return;
    
    const fullscreenDiv = document.createElement('div');
    fullscreenDiv.style.cssText = `
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.95);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: zoom-out;
    `;
    
    const img = document.createElement('img');
    img.src = mainImage.src;
    img.alt = mainImage.alt;
    img.style.cssText = `
        max-width: 90%;
        max-height: 90%;
        object-fit: contain;
    `;
    
    fullscreenDiv.appendChild(img);
    fullscreenDiv.addEventListener('click', () => {
        document.body.removeChild(fullscreenDiv);
    });
    
    document.body.appendChild(fullscreenDiv);
}

function getSelectedVariantId(color, size, data) {
    if (!Array.isArray(data) || data.length === 0) return null;

    // Ưu tiên match cả màu + size nếu có đủ
    let variant = null;
    if (color && size) {
        variant = data.find(item => item.mausac === color && item.kichco === size);
        if (variant) return variant._id;
    }

    // Trường hợp chỉ có màu
    if (color && !size) {
        variant = data.find(item => item.mausac === color);
        if (variant) return variant._id;
    }

    // Trường hợp chỉ có size
    if (!color && size) {
        variant = data.find(item => item.kichco === size);
        if (variant) return variant._id;
    }

    return null;
}

function getDiscountText(maKM) {
    if (!maKM || !maKM.giaTriGiam) return "";
    return maKM.loaiGiamGia === "soTien"
        ? `${maKM.giaTriGiam.toLocaleString("vi-VN")}₫ GIẢM`
        : `${maKM.giaTriGiam}% GIẢM`;
}

function getProductIdFromURL() {
    const parts = window.location.pathname.split("/");
    return parts[parts.length - 1];
}
