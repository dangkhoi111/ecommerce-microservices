    <script>
     document.addEventListener("DOMContentLoaded", async function () {
    console.log('🚀 Product detail page loading...');
    
    // Đảm bảo hàm getProductIdFromURL tồn tại
    if (typeof getProductIdFromURL !== 'function') {
        console.error('❌ getProductIdFromURL function not found!');
        window.location.href = "/";
        return;
    }
    
    const productId = getProductIdFromURL();
    console.log('📋 Product ID from URL:', productId);
    
    if (!productId || productId === "detail" || productId.length < 10) {
        console.error('❌ Invalid product ID:', productId);
        alert("Không tìm thấy sản phẩm! Vui lòng kiểm tra lại URL.");
        window.location.href = "/";
        return;
    }
    
    // Note: quantityInput, minusBtn, plusBtn sẽ được khai báo sau khi DOM load xong

    // Recommendation Service URL
    const RECOMMENDATION_SERVICE_URL = 'http://localhost:3011';

    // Track user behavior - Gọi trực tiếp recommendation service
    const trackBehavior = async (maSP, hanhDong = 'view', metadata = {}) => {
        try {
            const userInfo = JSON.parse(localStorage.getItem('userInfo') || 'null');
            const maKH = userInfo?.id || null;

            // Validate maSP
            if (!maSP) {
                console.warn('⚠️ Cannot track behavior: maSP is missing');
                return;
            }

            const payload = {
                maKH,
                maSP,
                hanhDong,
                metadata
            };

            console.log('📤 Sending behavior to track:', {
                url: `${RECOMMENDATION_SERVICE_URL}/api/recommendation/track`,
                payload
            });

            const response = await fetch(`${RECOMMENDATION_SERVICE_URL}/api/recommendation/track`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                const errorData = await response.json().catch(() => ({ error: 'Unknown error' }));
                console.error('❌ Failed to track behavior:', {
                    status: response.status,
                    statusText: response.statusText,
                    error: errorData
                });
                return;
            }

            const result = await response.json();
            if (result.success) {
                console.log('✅ Behavior tracked successfully:', {
                    maSP,
                    hanhDong,
                    maKH: maKH || 'anonymous'
                });
            }
        } catch (error) {
            console.error('❌ Failed to track behavior:', error);
            console.error('❌ Error details:', {
                message: error.message,
                maSP,
                hanhDong
            });
        }
    };

    // Lấy thông tin sản phẩm
    let dataSP = null;
    try {
        console.log('🔍 Fetching product with ID:', productId);
        console.log('🔗 API URL:', `http://localhost:3001/api/sanphams/${productId}`);
        
        // Tạo AbortController để timeout sau 10 giây
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 10000);
        
        let resSP;
        try {
            resSP = await fetch(`http://localhost:3001/api/sanphams/${productId}`, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json',
                    'Cache-Control': 'no-cache'
                },
                signal: controller.signal
            });
            clearTimeout(timeoutId);
        } catch (fetchError) {
            clearTimeout(timeoutId);
            if (fetchError.name === 'AbortError') {
                throw new Error('Request timeout: Server không phản hồi sau 10 giây. Vui lòng kiểm tra kết nối.');
            } else if (fetchError.message.includes('Failed to fetch') || fetchError.message.includes('NetworkError')) {
                throw new Error('Lỗi kết nối: Không thể kết nối đến server. Vui lòng kiểm tra:\n- Server API có đang chạy không (port 3001)\n- Kết nối internet của bạn');
            } else {
                throw fetchError;
            }
        }
        
        console.log('📡 Response status:', resSP.status, resSP.statusText);
        
        if (!resSP.ok) {
            const errorText = await resSP.text();
            let errorData;
            try {
                errorData = JSON.parse(errorText);
            } catch {
                errorData = { message: errorText || 'Không thể lấy thông tin sản phẩm' };
            }
            
            console.error('❌ API Error Details:', {
                status: resSP.status,
                statusText: resSP.statusText,
                error: errorData,
                url: `http://localhost:3001/api/sanphams/${productId}`,
                productId: productId
            });
            
            // Kiểm tra các lỗi cụ thể
            if (resSP.status === 404) {
                throw new Error(`Không tìm thấy sản phẩm với ID: ${productId}`);
            } else if (resSP.status === 500) {
                throw new Error('Lỗi server khi lấy thông tin sản phẩm. Vui lòng thử lại sau.');
            } else {
                throw new Error(errorData.message || `Không thể lấy thông tin sản phẩm (${resSP.status})`);
            }
        }
        
        const responseData = await resSP.json();
        console.log('✅ Response data received:', {
            hasData: !!responseData,
            hasId: !!responseData._id,
            hasName: !!responseData.tenSP
        });
        
        dataSP = responseData;
        
        if (!dataSP || !dataSP._id) {
            console.error('❌ Invalid product data:', dataSP);
            throw new Error('Dữ liệu sản phẩm không hợp lệ');
        }
        
        console.log('✅ Product data loaded:', {
            id: dataSP._id,
            name: dataSP.tenSP,
            price: dataSP.giaGiam
        });

        // Track product view behavior - Gọi trực tiếp recommendation service
        try {
            await trackBehavior(dataSP._id || productId, 'view', {
                category: dataSP.maDM?.tenDM || null,
                giaGoc: dataSP.giaGoc,
                giaGiam: dataSP.giaGiam,
                maUserBan: dataSP.maUserBan
            });
        } catch (trackError) {
            console.warn('⚠️ Failed to track behavior:', trackError);
            // Không throw error, chỉ log warning
        }

        // Gán dữ liệu vào HTML với error handling
        try {
            const elements = {
                "breadcrumb-product-name": dataSP.tenSP,
                "product-title": dataSP.tenSP,
                "breadcrumb-product-category": dataSP.maDM?.tenDM || 'Chưa phân loại',
                "product-amount": dataSP.giaGiam?.toLocaleString("vi-VN") || '0',
                "original-price": dataSP.giaGoc?.toLocaleString("vi-VN") || '0',
                "discount-pill": getDiscountText(dataSP.maKM),
                "discount-text": getDiscountText(dataSP.maKM),
                "origin": dataSP.tinhThanh || 'Chưa xác định',
                "shop-name": dataSP.tenShop || 'Chưa có tên shop',
                "categoryy": dataSP.maDM?.tenDM || 'Chưa phân loại',
                "description": dataSP.moTa || 'Chưa có mô tả'
            };

            // Update text elements
            Object.entries(elements).forEach(([id, value]) => {
                const el = document.getElementById(id);
                if (el) {
                    el.textContent = value;
                } else {
                    console.warn(`⚠️ Element not found: #${id}`);
                }
            });

            // Update image elements
            if (dataSP.hinhAnh) {
                const mainImage = document.getElementById("mainImage");
                const firstImage = document.getElementById("firstImage");
                if (mainImage) {
                    mainImage.src = dataSP.hinhAnh;
                    mainImage.alt = dataSP.tenSP || 'Sản phẩm';
                }
                if (firstImage) {
                    firstImage.src = dataSP.hinhAnh;
                    firstImage.alt = dataSP.tenSP || 'Sản phẩm';
                }
            }

            if (dataSP.hinhAnhShop) {
                const imgShop = document.getElementById("imgShop");
                if (imgShop) {
                    imgShop.src = dataSP.hinhAnhShop;
                }
            }

            id = dataSP.maUserBan;
        } catch (renderError) {
            console.error('❌ Error rendering product data:', renderError);
            throw new Error('Lỗi khi hiển thị thông tin sản phẩm');
        }

        // GỌI fetchReviews để hiển thị đánh giá sản phẩm
        const reviewsResult = await fetchReviews(productId);
        
        // Xử lý response - có thể là object {reviews, totalReviews} hoặc array
        let reviews = [];
        let totalReviews = 0;
        
        if (Array.isArray(reviewsResult)) {
            reviews = reviewsResult;
            totalReviews = reviews.length;
        } else if (reviewsResult && reviewsResult.reviews) {
            reviews = reviewsResult.reviews;
            totalReviews = reviewsResult.totalReviews || reviews.length;
        } else {
            reviews = [];
            totalReviews = 0;
        }
        
        console.log('Reviews data:', { 
            reviewsCount: reviews.length, 
            totalReviews,
            reviewsResultType: Array.isArray(reviewsResult) ? 'array' : typeof reviewsResult
        });
        
        // Cập nhật rating stars cho product header
        if (reviews && reviews.length > 0) {
            const avgRating = reviews.reduce((sum, r) => sum + Number(r.diemSo || 0), 0) / reviews.length;
            const fullStars = Math.floor(avgRating);
            const hasHalfStar = avgRating % 1 >= 0.5;
            const emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);
            
            let starsHTML = '';
            for (let i = 0; i < fullStars; i++) {
                starsHTML += '<i class="fas fa-star filled"></i>';
            }
            if (hasHalfStar) {
                starsHTML += '<i class="fas fa-star-half-alt filled"></i>';
            }
            for (let i = 0; i < emptyStars; i++) {
                starsHTML += '<i class="far fa-star"></i>';
            }
            starsHTML += `<span class="rating-value">${avgRating.toFixed(1)}</span>`;
            
            const ratingStarsEl = document.getElementById('product-rating-stars');
            if (ratingStarsEl) {
                ratingStarsEl.innerHTML = starsHTML;
            } else {
                console.warn('Không tìm thấy element product-rating-stars');
            }
        }
        
        // Lấy số lượt đã bán từ API order service dựa trên tên sản phẩm
        let soldCount = 0;
        try {
            // Encode tên sản phẩm để tránh lỗi URL
            const encodedProductName = encodeURIComponent(dataSP.tenSP);
            console.log('Đang lấy số lượt đã bán cho sản phẩm:', dataSP.tenSP);
            // Gọi trực tiếp order service (port 3006)
            const orderRes = await fetch(`http://localhost:3006/api/orderitems/sold-count/${encodedProductName}`);
            console.log('API sold-count response status:', orderRes.status);
            
            if (orderRes.ok) {
                const orderData = await orderRes.json();
                soldCount = orderData.soldCount || 0;
                console.log('Số lượt đã bán:', soldCount, 'Từ API:', orderData);
            } else {
                const errorText = await orderRes.text();
                console.log('Không thể lấy số lượt đã bán từ API order:', orderRes.status, errorText);
                // Fallback: thử lấy từ product data nếu có
                soldCount = dataSP.soLuongBan || 0;
            }
        } catch (err) {
            console.error('Lỗi khi lấy số lượt đã bán:', err);
            // Fallback: thử lấy từ product data nếu có
            soldCount = dataSP.soLuongBan || 0;
        }
        
        // Cập nhật số lượt đã bán - thử cả class cũ và mới
        const soldCountEl = document.querySelector('.sold-count-modern .meta-number') || 
                           document.querySelector('.sold-count span') ||
                           document.querySelector('.sold-count-modern span');
        if (soldCountEl) {
            soldCountEl.textContent = soldCount;
            console.log('✅ Đã cập nhật số lượt đã bán:', soldCount);
        } else {
            console.warn('⚠️ Không tìm thấy element để hiển thị số lượt đã bán');
        }
        
        // Cập nhật số đánh giá - thử cả class cũ và mới
        const reviewCountEl = document.querySelector('.review-count-modern .meta-number') || 
                             document.querySelector('.review-count span') ||
                             document.querySelector('.review-count-modern span');
        if (reviewCountEl) {
            reviewCountEl.textContent = totalReviews;
            console.log('✅ Đã cập nhật số đánh giá:', totalReviews);
        } else {
            console.warn('⚠️ Không tìm thấy element để hiển thị số đánh giá');
        }

        // Fetch các sản phẩm khác của shop
        const resRelated = await fetch(`http://localhost:3001/api/public/sanphams/shop/${id}`, {
            headers: {
                'Cache-Control': 'no-cache'
            }
        });
        if (!resRelated.ok) throw new Error('Không thể lấy sản phẩm của shop');
        const shopProducts = await resRelated.json();

        // Render "CÁC SẢN PHẨM KHÁC CỦA SHOP"
        const relatedGrid = document.getElementById('related-products-grid');
        relatedGrid.innerHTML = shopProducts.length > 0
            ? shopProducts.slice(0, 5).map(product => {
                const discountPercent = product.giaGoc > 0 && product.giaGoc > product.giaGiam 
                    ? Math.round(((product.giaGoc - product.giaGiam) / product.giaGoc) * 100) 
                    : 0;
                
                return `
                <div class="product-item">
                    ${discountPercent > 0 ? `<div class="discount-tag">-${discountPercent}%</div>` : ''}
                    <a href="/products/detail/${product._id}" style="display:block;text-decoration:none;cursor:pointer;">
                        <img src="${product.hinhAnh || '/images/no-image.png'}" alt="${product.tenSP}" onerror="this.src='/images/no-image.png'" style="cursor:pointer;">
                    </a>
                    <a href="/products/detail/${product._id}" style="text-decoration:none;color:inherit;">
                        <h4>${product.tenSP}</h4>
                    </a>
                    <p>${new Intl.NumberFormat('vi-VN').format(product.giaGiam || product.giaGoc)}₫</p>
                    <div class="product-item-actions" style="display:flex;gap:8px;width:100%;margin-top:8px;">
                        <button class="btn-add-cart-mini" onclick="event.stopPropagation();addToCartFromList('${product._id}')" style="flex:1;padding:8px 12px;background:#fff;border:2px solid #f97316;border-radius:8px;color:#f97316;font-weight:600;font-size:16px;cursor:pointer;transition:all 0.3s;display:flex;align-items:center;justify-content:center;" onmouseover="this.style.background='#fff7ed';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='#fff';this.style.transform='translateY(0)'">
                            <i class="fas fa-cart-plus"></i>
                        </button>
                        <button class="btn-buy-now-mini" onclick="event.stopPropagation();buyNowFromList('${product._id}')" style="flex:1;padding:8px 12px;background:linear-gradient(135deg, #f97316 0%, #eab308 100%);border:none;border-radius:8px;color:#fff;font-weight:700;font-size:13px;cursor:pointer;transition:all 0.3s;box-shadow:0 2px 8px rgba(249,115,22,0.3);" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 12px rgba(249,115,22,0.4)'" onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 2px 8px rgba(249,115,22,0.3)'">
                            <i class="fas fa-bolt"></i> Mua
                        </button>
                    </div>
                    <a href="/products/detail/${product._id}" class="btn-view-product" style="margin-top:8px;">Xem chi tiết</a>
                </div>
            `;
            }).join('')
            : '<p>Không có sản phẩm khác của shop.</p>';

        // Lấy sản phẩm gợi ý từ Recommendation Service
        let recommendedProducts = [];
        try {
            // Lấy maKH từ localStorage
            const userInfo = localStorage.getItem('userInfo') ? JSON.parse(localStorage.getItem('userInfo')) : null;
            const maKH = userInfo?.id || null;
            
            // Gọi Recommendation Service
            const RECOMMENDATION_SERVICE_URL = 'http://localhost:3011';
            let recommendationUrl = `${RECOMMENDATION_SERVICE_URL}/api/recommendation/recommendations?limit=10&model=hybrid`;
            
            if (maKH) {
                recommendationUrl += `&maKH=${maKH}`;
                console.log('🔍 Fetching personalized recommendations for user:', maKH);
            } else {
                console.log('🔍 Fetching popular products for guest user');
            }
            
            const recResponse = await fetch(recommendationUrl, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json'
                }
            });
            
            if (recResponse.ok) {
                const recData = await recResponse.json();
                console.log('✅ Recommendation data received:', {
                    success: recData.success,
                    model: recData.model,
                    count: recData.count || recData.products?.length || 0
                });
                
                // Recommendation service trả về { success: true, products: [...], count: N }
                if (recData.success && Array.isArray(recData.products)) {
                    recommendedProducts = recData.products;
                } else if (Array.isArray(recData)) {
                    // Fallback: nếu trả về array trực tiếp
                    recommendedProducts = recData;
                }
            } else {
                const errorText = await recResponse.text();
                console.warn('⚠️ Recommendation service error:', recResponse.status, errorText);
                throw new Error(`Recommendation service error: ${recResponse.status}`);
            }
        } catch (recErr) {
            console.warn('⚠️ Recommendation service unavailable, using fallback:', recErr);
            try {
                // Fallback: Lấy sản phẩm phổ biến từ Product Service
                const resRecommended = await fetch('http://localhost:3001/api/public/sanphams', {
                    headers: {
                        'Cache-Control': 'no-cache'
                    }
                });
                if (resRecommended.ok) {
                    const fallbackProducts = await resRecommended.json();
                    recommendedProducts = Array.isArray(fallbackProducts) ? fallbackProducts : [];
                    console.log('✅ Fallback: Loaded', recommendedProducts.length, 'popular products');
                }
            } catch (fallbackErr) {
                console.error('❌ Fallback recommendation fetch failed:', fallbackErr);
                recommendedProducts = [];
            }
        }

        // Xử lý và filter sản phẩm gợi ý
        recommendedProducts = (recommendedProducts || [])
            .map(product => ({
                id: product.productId || product._id,
                tenSP: product.tenSP || 'Sản phẩm không có tên',
                giaGoc: product.giaGoc || 0,
                giaGiam: product.giaGiam ?? product.giaGoc ?? 0,
                hinhAnh: product.hinhAnh || '/images/no-image.png',
                maDM: product.maDM,
                reason: product.reason || 'Gợi ý cho bạn',
                score: product.score || 0
            }))
            .filter(item => item.id && item.id !== productId) // Loại bỏ sản phẩm hiện tại
            .slice(0, 10); // Lấy tối đa 10 sản phẩm

        console.log('📦 Processed recommendations:', recommendedProducts.length, 'products');

        // Render sản phẩm gợi ý - sử dụng cùng cấu trúc như "CÁC SẢN PHẨM KHÁC CỦA SHOP"
        const recommendedGrid = document.getElementById('recommended-products-grid');
        if (recommendedGrid) {
            if (recommendedProducts.length > 0) {
                recommendedGrid.innerHTML = recommendedProducts.map(product => {
                    const discountPercent = product.giaGoc > 0 && product.giaGoc > product.giaGiam 
                        ? Math.round(((product.giaGoc - product.giaGiam) / product.giaGoc) * 100) 
                        : 0;
                    
                    return `
                        <div class="product-item">
                            ${discountPercent > 0 ? 
                                `<div class="discount-tag">-${discountPercent}%</div>` 
                                : ''}
                            <a href="/products/detail/${product.id}" style="display:block;text-decoration:none;cursor:pointer;">
                                <img src="${product.hinhAnh || '/images/no-image.png'}" alt="${product.tenSP}" onerror="this.src='/images/no-image.png'" style="cursor:pointer;">
                            </a>
                            <a href="/products/detail/${product.id}" style="text-decoration:none;color:inherit;">
                                <h4>${product.tenSP}</h4>
                            </a>
                            <p>${new Intl.NumberFormat('vi-VN').format(product.giaGiam || product.giaGoc)}₫</p>
                            <div class="product-item-actions" style="display:flex;gap:8px;width:100%;margin-top:8px;">
                                <button class="btn-add-cart-mini" onclick="event.stopPropagation();addToCartFromList('${product.id}')" style="flex:1;padding:8px 12px;background:#fff;border:2px solid #f97316;border-radius:8px;color:#f97316;font-weight:600;font-size:16px;cursor:pointer;transition:all 0.3s;display:flex;align-items:center;justify-content:center;" onmouseover="this.style.background='#fff7ed';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='#fff';this.style.transform='translateY(0)'">
                                    <i class="fas fa-cart-plus"></i>
                                </button>
                                <button class="btn-buy-now-mini" onclick="event.stopPropagation();buyNowFromList('${product.id}')" style="flex:1;padding:8px 12px;background:linear-gradient(135deg, #f97316 0%, #eab308 100%);border:none;border-radius:8px;color:#fff;font-weight:700;font-size:13px;cursor:pointer;transition:all 0.3s;box-shadow:0 2px 8px rgba(249,115,22,0.3);" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 12px rgba(249,115,22,0.4)'" onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 2px 8px rgba(249,115,22,0.3)'">
                                    <i class="fas fa-bolt"></i> Mua
                                </button>
                            </div>
                            <a href="/products/detail/${product.id}" class="btn-view-product" style="margin-top:8px;">Xem chi tiết</a>
                            ${product.reason ? `<span class="recommendation-reason">${product.reason}</span>` : ''}
                        </div>
                    `;
                }).join('');
            } else {
                recommendedGrid.innerHTML = '<p>Chưa có sản phẩm gợi ý. Hãy xem thêm sản phẩm để nhận gợi ý phù hợp!</p>';
            }
        } else {
            console.warn('⚠️ Element #recommended-products-grid not found');
        }

    } catch (err) {
        console.error('❌ Lỗi khi lấy sản phẩm:', err);
        console.error('❌ Error stack:', err.stack);
        console.error('❌ Product ID:', productId);
        console.error('❌ API URL:', `http://localhost:3001/api/sanphams/${productId}`);
        
        // Hiển thị thông báo lỗi cho người dùng
        const errorMessage = err.message || 'Không thể tải thông tin sản phẩm. Vui lòng thử lại sau.';
        
        // Ẩn loading states
        const loadingElements = document.querySelectorAll('[id*="Đang tải"], [class*="loading"]');
        loadingElements.forEach(el => {
            if (el.textContent.includes('Đang tải')) {
                el.textContent = '';
            }
        });
        
        // Cập nhật các phần tử chính với thông báo lỗi
        const productTitle = document.getElementById("product-title");
        if (productTitle) {
            productTitle.textContent = '❌ Lỗi: Không thể tải sản phẩm';
            productTitle.style.color = '#ef4444';
        }
        
        const priceSection = document.querySelector('.price-section-modern');
        if (priceSection) {
            priceSection.innerHTML = `
                <div style="padding: 30px; text-align: center; background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%); border-radius: 16px; border: 2px solid #fca5a5;">
                    <i class="fas fa-exclamation-triangle" style="font-size: 48px; color: #ef4444; margin-bottom: 15px;"></i>
                    <h3 style="font-weight: 700; color: #dc2626; margin-bottom: 10px; font-size: 20px;">${errorMessage}</h3>
                    <p style="font-size: 14px; color: #7f1d1d; margin-bottom: 20px;">Vui lòng kiểm tra:</p>
                    <ul style="text-align: left; display: inline-block; color: #7f1d1d; margin-bottom: 20px;">
                        <li>Kết nối internet của bạn</li>
                        <li>Server API có đang chạy không (port 3001)</li>
                        <li>Product ID có hợp lệ không: <code style="background: #fff; padding: 2px 6px; border-radius: 4px;">${productId}</code></li>
                    </ul>
                    <button onclick="window.location.reload()" style="padding: 12px 24px; background: linear-gradient(135deg, #f97316 0%, #eab308 100%); color: white; border: none; border-radius: 10px; cursor: pointer; font-weight: 700; font-size: 16px; box-shadow: 0 4px 12px rgba(249, 115, 22, 0.3); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 16px rgba(249, 115, 22, 0.4)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 12px rgba(249, 115, 22, 0.3)'">
                        <i class="fas fa-redo"></i> Tải lại trang
                    </button>
                </div>
            `;
        }
        
        // Cập nhật image area
        const mainImage = document.getElementById("mainImage");
        if (mainImage) {
            mainImage.src = '/images/no-image.png';
            mainImage.alt = 'Không thể tải hình ảnh';
        }
        
        // Cập nhật các phần khác
        const relatedGrid = document.getElementById('related-products-grid');
        if (relatedGrid) {
            relatedGrid.innerHTML = '<p style="color: #ef4444; text-align: center; padding: 20px;">Không thể tải sản phẩm của shop.</p>';
        }
        
        const recommendedGrid = document.getElementById('recommended-products-grid');
        if (recommendedGrid) {
            recommendedGrid.innerHTML = '<p style="color: #ef4444; text-align: center; padding: 20px;">Không thể tải sản phẩm gợi ý.</p>';
        }
        
        // Không redirect, để người dùng có thể thử lại
        return;
    }

    // Lấy phiên bản sản phẩm
    let variantData = [];
    let selectedVariantId = null;
    let selectedColor = null;
    let selectedSize = null;
    let hasColors = false;
    let hasSizes = false;

    try {
        const resPB = await fetch(`http://localhost:3001/api/phienban?maSanPham=${productId}`, {
            headers: {
                'Cache-Control': 'no-cache'
            }
        });
        if (!resPB.ok) throw new Error('Không thể lấy phiên bản sản phẩm');
        variantData = await resPB.json();
        console.log('Variant Data:', variantData); // Log để kiểm tra dữ liệu API

        // Xác định xem dữ liệu phiên bản có màu/kích thước hay không
        hasColors = Array.isArray(variantData) && variantData.some(v => v.mausac !== null && v.mausac !== undefined && v.mausac !== '');
        hasSizes  = Array.isArray(variantData) && variantData.some(v => v.kichco !== null && v.kichco !== undefined && v.kichco !== '');

        // Tham chiếu nhóm UI màu/kích thước trên trang chi tiết
        const colorOptions = document.querySelector(".color-options-modern") || document.querySelector(".color-options");
        const sizeOptions  = document.querySelector(".size-options-modern") || document.querySelector(".size-options");
        const colorGroup   = colorOptions ? colorOptions.closest('.variant-group-modern') || document.querySelector('.color-selection') : document.querySelector('.color-selection');
        const sizeGroup    = sizeOptions  ? sizeOptions.closest('.variant-group-modern')  || document.querySelector('.size-selection')  : document.querySelector('.size-selection');

        // Trường hợp KHÔNG có màu cũng không có kích thước: ẩn UI lựa chọn, tự động chọn phiên bản
        if (variantData.length === 1 && !hasColors && !hasSizes) {
            selectedVariantId = variantData[0]._id; // Lưu mã phiên bản
            console.log('✅ Auto-selected variant (no color/size):', selectedVariantId);
            if (colorGroup) colorGroup.style.display = 'none';
            if (sizeGroup) sizeGroup.style.display = 'none';
        } else {
            // Ẩn nhóm không dùng
            if (!hasColors && colorGroup) colorGroup.style.display = 'none';
            if (!hasSizes && sizeGroup)  sizeGroup.style.display  = 'none';

            const colorSet = new Set();
            const sizeSet  = new Set();
            const colorToSizes = {};
            const sizeToColors = {};

            variantData.forEach(({ mausac, kichco }) => {
                if (hasColors && mausac) {
                    colorSet.add(mausac);
                }
                if (hasSizes && kichco) {
                    sizeSet.add(kichco);
                }
                // Chỉ tạo mapping khi sản phẩm có cả màu và kích thước
                if (hasColors && hasSizes && mausac && kichco) {
                    colorToSizes[mausac] = colorToSizes[mausac] || new Set();
                    sizeToColors[kichco] = sizeToColors[kichco] || new Set();
                    colorToSizes[mausac].add(kichco);
                    sizeToColors[kichco].add(mausac);
                }
            });

            function renderColors() {
                if (!colorOptions || !hasColors) return;
                colorOptions.innerHTML = [...colorSet].map(c => `
                    <button class="color-btn ${c === selectedColor ? "active" : ""}" data-color="${c}" ${
                        hasColors && hasSizes && selectedSize && !sizeToColors[selectedSize]?.has(c) ? "disabled" : ""
                    }>
                        <span class="color-name">${c}</span>
                    </button>
                `).join("");
            }

            function renderSizes() {
                if (!sizeOptions || !hasSizes) return;
                sizeOptions.innerHTML = [...sizeSet].map(s => `
                    <button class="size-btn ${s === selectedSize ? "active" : ""}" data-size="${s}" ${
                        hasColors && hasSizes && selectedColor && !colorToSizes[selectedColor]?.has(s) ? "disabled" : ""
                    }>
                        ${s}
                    </button>
                `).join("");
            }

            function updateVariantUI() {
                renderColors();
                renderSizes();
            }

            if (colorOptions && hasColors) {
                colorOptions.addEventListener("click", (e) => {
                    const btn = e.target.closest(".color-btn");
                    if (!btn || btn.disabled) return;
                    selectedColor = btn.dataset.color;
                    console.log('Selected Color:', selectedColor); // Log để kiểm tra
                    updateVariantUI();
                });
            }

            if (sizeOptions && hasSizes) {
                sizeOptions.addEventListener("click", (e) => {
                    const btn = e.target.closest(".size-btn");
                    if (!btn || btn.disabled) return;
                    selectedSize = btn.dataset.size;
                    console.log('Selected Size:', selectedSize); // Log để kiểm tra
                    updateVariantUI();
                });
            }

            updateVariantUI();
        }
    } catch (err) {
        console.error("Lỗi API phiên bản:", err);
    }

    // Thêm vào giỏ hàng
    document.getElementById('addToCartBtn')?.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        console.log('🛒 Add to cart clicked');
        console.log('Selected variant ID:', selectedVariantId);
        console.log('Selected color:', selectedColor);
        console.log('Selected size:', selectedSize);
        console.log('Variant data:', variantData);

        const userInfo = localStorage.getItem('userInfo') ? JSON.parse(localStorage.getItem('userInfo')) : null;
        if (!userInfo || !userInfo.id) {
            alert('Vui lòng đăng nhập để thêm vào giỏ hàng');
            window.location.href = '/login';
            return;
        }

        const maKH = userInfo.id;
        let variantId = selectedVariantId;

        // Xử lý variant ID
        if (!variantId) {
            // Nếu có variant data và chỉ có 1 variant với mausac và kichco đều null
            if (variantData && variantData.length === 1 && variantData[0].mausac === null && variantData[0].kichco === null) {
                variantId = variantData[0]._id;
                console.log('✅ Using default variant (null color/size):', variantId);
            } else {
                // Bắt buộc chọn thuộc tính cần thiết
                if (hasColors && !selectedColor) {
                    alert('Vui lòng chọn màu sắc');
                    return;
                }
                if (hasSizes && !selectedSize) {
                    alert('Vui lòng chọn kích thước');
                    return;
                }

                variantId = getSelectedVariantId(selectedColor, selectedSize, variantData);
                console.log('✅ Using selected variant:', variantId);

                if (!variantId) {
                    alert('Không tìm thấy phiên bản sản phẩm phù hợp. Vui lòng chọn lại.');
                    return;
                }
            }
        }

        if (!variantId) {
            console.error('❌ No variant ID found');
            alert('Phiên bản sản phẩm không hợp lệ. Vui lòng thử lại.');
            return;
        }

        const quantityInput = document.getElementById('quantity');
        const quantity = quantityInput ? parseInt(quantityInput.value) || 1 : 1;

        console.log('📦 Adding to cart:', {
            maKH,
            variantId,
            quantity,
            productId
        });

        try {
            // Lấy thông tin giỏ hàng
            const cartRes = await fetch(`http://localhost:3003/api/cart/${maKH}`);
            if (!cartRes.ok) {
                const errorText = await cartRes.text();
                console.error('❌ Cart API error:', cartRes.status, errorText);
                throw new Error(`Không thể lấy thông tin giỏ hàng (${cartRes.status})`);
            }
            
            const cartData = await cartRes.json();
            if (!cartData || !cartData._id) {
                throw new Error('Dữ liệu giỏ hàng không hợp lệ');
            }
            
            const cartId = cartData._id;
            console.log('✅ Cart ID:', cartId);

            const cartDetailData = {
                maGH: cartId,
                soluong: quantity,
                maPB: variantId,
            };

            console.log('📤 Sending cart detail:', cartDetailData);

            const detailCartRes = await fetch('http://localhost:3003/api/detailcart/', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(cartDetailData),
            });

            if (detailCartRes.ok) {
                const result = await detailCartRes.json();
                console.log('✅ Added to cart successfully:', result);
                
                // Track add to cart behavior
                try {
                    await trackBehavior(productId, 'add_to_cart', {
                        category: dataSP?.maDM?.tenDM || null,
                        giaGoc: dataSP?.giaGoc,
                        giaGiam: dataSP?.giaGiam,
                        quantity,
                        variantId
                    });
                } catch (trackErr) {
                    console.warn('⚠️ Failed to track behavior:', trackErr);
                }

                // Hiển thị feedback
                const btn = document.getElementById('addToCartBtn');
                if (btn) {
                    const originalHTML = btn.innerHTML;
                    btn.innerHTML = '<i class="fas fa-check"></i> <span>Đã thêm vào giỏ</span>';
                    btn.classList.add('added');
                    btn.style.background = 'linear-gradient(135deg, #10b981 0%, #059669 100%)';
                    btn.style.borderColor = '#10b981';
                    btn.style.color = '#fff';
                    setTimeout(() => {
                        btn.innerHTML = originalHTML;
                        btn.classList.remove('added');
                        btn.style.background = '';
                        btn.style.borderColor = '';
                        btn.style.color = '';
                    }, 2000);
                }
            } else {
                const errorText = await detailCartRes.text();
                let errorData;
                try {
                    errorData = JSON.parse(errorText);
                } catch {
                    errorData = { message: errorText || 'Không thể thêm vào giỏ hàng' };
                }
                
                console.error('❌ Add to cart error:', detailCartRes.status, errorData);
                alert(`Có lỗi khi thêm vào giỏ hàng: ${errorData.message || 'Vui lòng thử lại'}`);
            }
        } catch (err) {
            console.error('❌ Lỗi khi thêm vào giỏ hàng:', err);
            console.error('❌ Error stack:', err.stack);
            alert(`Có lỗi xảy ra: ${err.message || 'Vui lòng thử lại'}`);
        }
    });

    // Biến lưu trữ lựa chọn trong modal
    let modalSelectedColor = null;
    let modalSelectedSize = null;
    let modalQuantity = 1;

    // Hàm mở modal Mua Ngay
    function openBuyNowModal() {
        // Kiểm tra đăng nhập
        const userInfo = localStorage.getItem('userInfo') ? JSON.parse(localStorage.getItem('userInfo')) : null;
        if (!userInfo || !userInfo.id) {
            alert('Vui lòng đăng nhập để mua hàng');
            window.location.href = '/login';
            return;
        }

        const modal = document.getElementById('buyNowModal');
        if (!modal) return;

        // Reset các lựa chọn
        modalSelectedColor = null;
        modalSelectedSize = null;
        modalQuantity = 1;

        // Kiểm tra và hiển thị các tùy chọn
        // Xem giá trị null / undefined / "" là KHÔNG có thuộc tính
        const hasColors = variantData && variantData.some(v => v.mausac !== null && v.mausac !== undefined && v.mausac !== '');
        const hasSizes  = variantData && variantData.some(v => v.kichco !== null && v.kichco !== undefined && v.kichco !== '');

        const colorSelection = document.getElementById('modalColorSelection');
        const sizeSelection = document.getElementById('modalSizeSelection');
        const colorOptions = document.getElementById('modalColorOptions');
        const sizeOptions = document.getElementById('modalSizeOptions');

        // Xử lý màu sắc
        if (hasColors && variantData.length > 0) {
            const colorSet = new Set();
            variantData.forEach(v => {
                if (v.mausac) colorSet.add(v.mausac);
            });

            colorOptions.innerHTML = [...colorSet].map(color => `
                <button class="buy-now-color-btn ${color === modalSelectedColor ? 'active' : ''}" 
                        data-color="${color}">
                    <span>${color}</span>
                </button>
            `).join('');

            colorSelection.style.display = 'block';

            // Event listeners cho màu sắc
            colorOptions.querySelectorAll('.buy-now-color-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    colorOptions.querySelectorAll('.buy-now-color-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    modalSelectedColor = btn.dataset.color;
                    modalSelectedSize = null; // Reset size khi chọn màu mới
                    updateModalSizeOptions();
                    
                    // Cập nhật stock khi chọn màu (nếu đã có size)
                    if (modalSelectedSize && variantData) {
                        const selectedVariant = variantData.find(v => 
                            v.mausac === modalSelectedColor && v.kichco === modalSelectedSize
                        );
                        const modalStockCount = document.getElementById('modalStockCount');
                        if (modalStockCount && selectedVariant) {
                            modalStockCount.textContent = selectedVariant.soLuong || 100;
                        }
                    }
                });
            });
        } else {
            colorSelection.style.display = 'none';
        }

        // Xử lý kích thước
        if (hasSizes && variantData.length > 0) {
            updateModalSizeOptions();
            sizeSelection.style.display = 'block';
        } else {
            sizeSelection.style.display = 'none';
        }

        // Nếu chỉ có 1 variant với mausac và kichco đều null, tự động chọn
        if (variantData && variantData.length === 1 && variantData[0].mausac === null && variantData[0].kichco === null) {
            colorSelection.style.display = 'none';
            sizeSelection.style.display = 'none';
            const modalStockCount = document.getElementById('modalStockCount');
            if (modalStockCount) {
                modalStockCount.textContent = variantData[0].soLuong || 100;
            }
        }

        // Cập nhật số lượng
        const modalQtyInput = document.getElementById('modalQuantity');
        if (modalQtyInput) {
            modalQtyInput.value = modalQuantity;
        }

        // Cập nhật stock info
        const modalStockCount = document.getElementById('modalStockCount');
        if (modalStockCount && variantData && variantData.length > 0) {
            // Lấy stock từ variant đầu tiên hoặc variant được chọn
            let stock = 100; // Default
            if (variantData.length === 1) {
                stock = variantData[0].soLuong || 100;
            } else if (modalSelectedColor && modalSelectedSize) {
                const selectedVariant = variantData.find(v => 
                    v.mausac === modalSelectedColor && v.kichco === modalSelectedSize
                );
                if (selectedVariant) {
                    stock = selectedVariant.soLuong || 100;
                }
            }
            modalStockCount.textContent = stock;
        }

        // Hiển thị modal
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    // Hàm cập nhật tùy chọn kích thước dựa trên màu đã chọn
    function updateModalSizeOptions() {
        const sizeOptions = document.getElementById('modalSizeOptions');
        if (!sizeOptions || !variantData) return;

        const sizeSet = new Set();
        variantData.forEach(v => {
            if (v.kichco) {
                // Nếu đã chọn màu, chỉ hiển thị size tương ứng với màu đó
                if (modalSelectedColor) {
                    if (v.mausac === modalSelectedColor) {
                        sizeSet.add(v.kichco);
                    }
                } else {
                    sizeSet.add(v.kichco);
                }
            }
        });

        sizeOptions.innerHTML = [...sizeSet].map(size => `
            <button class="buy-now-size-btn ${size === modalSelectedSize ? 'active' : ''}" 
                    data-size="${size}">
                ${size}
            </button>
        `).join('');

        // Event listeners cho kích thước
        sizeOptions.querySelectorAll('.buy-now-size-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                sizeOptions.querySelectorAll('.buy-now-size-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                modalSelectedSize = btn.dataset.size;
                
                // Cập nhật stock khi chọn size
                if (variantData && modalSelectedColor && modalSelectedSize) {
                    const selectedVariant = variantData.find(v => 
                        v.mausac === modalSelectedColor && v.kichco === modalSelectedSize
                    );
                    const modalStockCount = document.getElementById('modalStockCount');
                    if (modalStockCount && selectedVariant) {
                        modalStockCount.textContent = selectedVariant.soLuong || 100;
                    }
                }
            });
        });
    }

    // Hàm đóng modal
    function closeBuyNowModal() {
        const modal = document.getElementById('buyNowModal');
        if (modal) {
            modal.style.display = 'none';
            document.body.style.overflow = '';
