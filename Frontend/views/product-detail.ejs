            alert('Vui lòng đăng nhập để mua hàng');
            window.location.href = '/login';
            return;
        }

        const maKH = userInfo.id;

        // Validation
        if (!modalQuantity || modalQuantity < 1) {
            alert('Vui lòng chọn số lượng sản phẩm');
            return;
        }

        // Xác định variant ID
        let variantId = null;

        if (variantData && variantData.length > 0) {
            // Nếu chỉ có 1 variant với mausac và kichco đều null
            if (variantData.length === 1 && variantData[0].mausac === null && variantData[0].kichco === null) {
                variantId = variantData[0]._id;
            } else {
                // Kiểm tra xem có cần chọn màu sắc và kích thước không
                const hasColorsLocal = variantData.some(v => v.mausac !== null && v.mausac !== undefined && v.mausac !== '');
                const hasSizesLocal  = variantData.some(v => v.kichco !== null && v.kichco !== undefined && v.kichco !== '');

                if (hasColorsLocal && !modalSelectedColor) {
                    alert('Vui lòng chọn màu sắc');
                    return;
                }

                if (hasSizesLocal && !modalSelectedSize) {
                    alert('Vui lòng chọn kích thước');
                    return;
                }

                // Tìm variant theo màu/size đã chọn (1 thuộc tính hoặc cả 2)
                variantId = getSelectedVariantId(modalSelectedColor, modalSelectedSize, variantData);
            }
        }

        if (!variantId) {
            alert('Không tìm thấy phiên bản sản phẩm. Vui lòng thử lại.');
            return;
        }

        // Chuyển đến trang checkout trực tiếp với thông tin sản phẩm
        // Không thêm vào giỏ hàng, chỉ thanh toán sản phẩm này
        try {
            const checkoutParams = new URLSearchParams({
                buyNow: 'true',
                productId: productId,
                variantId: variantId,
                quantity: modalQuantity,
                color: modalSelectedColor || '',
                size: modalSelectedSize || ''
            });

            // Track behavior
            await trackBehavior(productId, 'purchase', {
                category: dataSP?.maDM?.tenDM || null,
                giaGoc: dataSP?.giaGoc,
                giaGiam: dataSP?.giaGiam,
                quantity: modalQuantity,
                variantId
            });

            // Đóng modal và chuyển đến trang checkout
            closeBuyNowModal();
            window.location.href = `/checkout?${checkoutParams.toString()}`;
        } catch (err) {
            console.error('❌ Lỗi khi mua ngay:', err);
            alert(`Có lỗi xảy ra: ${err.message || 'Vui lòng thử lại'}`);
        }
    });

