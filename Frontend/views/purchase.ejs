<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Đơn Mua Của Bạn</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  
</head>
<body>

<!-- Purchase Hero Section -->
<section class="text-white py-5 position-relative overflow-hidden" style="background: linear-gradient(135deg, #f97316, #eab308);">
  <div class="container py-4">
    <div class="row align-items-center">
      <div class="col-lg-7 position-relative z-1">
        <span class="badge bg-warning text-dark mb-3">Đơn hàng</span>
        <h1 class="display-4 fw-bold mb-4">Đơn Mua Của Bạn</h1>
        <p class="lead mb-4">Quản lý, theo dõi trạng thái các đơn hàng bạn đã đặt tại MegaStore VN.</p>
      </div>
      <div class="col-lg-5 text-center">
        <i class="fas fa-box-open fa-5x text-white-50"></i>
      </div>
    </div>
  </div>
  <div class="position-absolute top-50 start-0 translate-middle-y" style="z-index:0;">
    <svg width="600" height="400" viewBox="0 0 600 400" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="100" cy="100" r="100" fill="rgba(255,255,255,0.1)"/>
      <circle cx="500" cy="300" r="150" fill="rgba(255,255,255,0.05)"/>
    </svg>
  </div>
</section>

<!-- Main Content -->
<div class="main-content">
  <div class="purchase-container">
    <h2>Đơn Mua Của Bạn</h2>
    <div class="purchase-tabs">
      <button class="active" data-status="">Tất cả</button>
      <button data-status="Chờ xác nhận">Chờ xác nhận</button>
      <button data-status="Đang vận chuyển">Đang vận chuyển</button>
      <button data-status="Đã hoàn thành">Đã hoàn thành</button>
      <button data-status="Đã hủy">Đã hủy</button>
    </div>
    <div class="purchase-list" id="purchase-list">
      <div style="text-align:center;color:#888;padding:32px 0;">Đang tải đơn hàng...</div>
    </div>
  </div>
</div>

<script>
  const urlParams = new URLSearchParams(window.location.search);
  const maKH = urlParams.get('maKH');
  const listContainer = document.getElementById('purchase-list');
  const tabs = document.querySelectorAll('.purchase-tabs button');
  let allOrders = [];

  function renderOrders(statusFilter = null) {
    listContainer.innerHTML = '';
    const filtered = statusFilter
      ? allOrders.filter(order => order.TrangThai === statusFilter)
      : allOrders;

    if (filtered.length === 0) {
      listContainer.innerHTML = '<div style="text-align:center;color:#888;padding:32px 0;">Không có đơn hàng phù hợp.</div>';
      return;
    }

    filtered.forEach(order => {
      const item = document.createElement('div');
      item.classList.add('purchase-item');
      item.innerHTML = `
        <div class="purchase-info">
          <div class="purchase-title">${order.TongTien} VND</div>
          <div class="purchase-status">${order.TrangThai}</div>
        </div>
        <div class="purchase-actions">
          <a href="/order/${order._id}">Xem chi tiết</a>
        </div>
      `;
      listContainer.appendChild(item);
    });
  }

  if (maKH) {
    fetch(`http://localhost:3006/api/orders/?maKH=${maKH}`)
      .then(res => res.json())
      .then(data => {
        allOrders = data || [];
        renderOrders(); // Hiển thị tất cả lúc đầu

        // Gán sự kiện cho nút lọc
        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            tabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            const status = tab.getAttribute('data-status');
            renderOrders(status || null); // null nếu là "Tất cả"
          });
        });
      })
      .catch(err => {
        listContainer.innerHTML = '<div style="text-align:center;color:#888;padding:32px 0;">Không thể tải đơn hàng. Vui lòng thử lại sau.</div>';
        console.error('Lỗi khi tải đơn hàng:', err);
      });
  } else {
    listContainer.innerHTML = '<div style="text-align:center;color:#888;padding:32px 0;">Không có mã khách hàng trong URL.</div>';
    console.error('Không tìm thấy maKH trên URL!');
  }
</script>

</body>
</html>
