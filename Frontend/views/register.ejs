<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký - MegaStore VN</title>
    <meta name="description" content="Đăng ký tài khoản MegaStore VN để mua sắm và theo dõi đơn hàng dễ dàng">
    
    <!-- Tailwind CSS (CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        if (window.tailwind) { 
            tailwind.config = { 
                darkMode: 'class',
                theme: {
                    extend: {
                        animation: {
                            'fade-in': 'fadeIn 0.5s ease-in',
                            'slide-up': 'slideUp 0.6s ease-out',
                        },
                        keyframes: {
                            fadeIn: {
                                '0%': { opacity: '0' },
                                '100%': { opacity: '1' }
                            },
                            slideUp: {
                                '0%': { transform: 'translateY(20px)', opacity: '0' },
                                '100%': { transform: 'translateY(0)', opacity: '1' }
                            }
                        }
                    }
                }
            } 
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gradient-to-br from-slate-50 via-white to-slate-50 dark:from-neutral-900 dark:via-black dark:to-neutral-900 min-h-screen transition-colors duration-300">
    <!-- Hero Section Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/4 w-[600px] h-[600px] opacity-5 dark:opacity-10">
            <div class="w-full h-full rounded-full border-8 border-slate-900 dark:border-white flex items-center justify-center">
                <div class="text-[400px] font-black text-slate-900 dark:text-white">M</div>
            </div>
        </div>
    </div>

    <!-- Register Container -->
    <div class="relative min-h-screen flex items-center justify-center px-4 py-12">
        <div class="w-full max-w-lg">
            <!-- Register Card -->
            <div class="bg-white dark:bg-neutral-900 rounded-3xl shadow-2xl shadow-orange-500/10 dark:shadow-yellow-500/10 border border-slate-200 dark:border-neutral-800 p-8 md:p-10 animate-slide-up">
                <!-- Header -->
                <div class="text-center mb-8">
                    <a href="/" class="inline-block mb-6">
                        <div class="text-3xl font-black bg-gradient-to-r from-orange-500 to-yellow-500 dark:from-yellow-400 dark:to-yellow-200 bg-clip-text text-transparent">
                            MegaStore VN
                        </div>
                    </a>
                    <h1 class="text-2xl md:text-3xl font-black text-slate-900 dark:text-white mb-2">
                        Đăng ký tài khoản
                    </h1>
                    <p class="text-slate-600 dark:text-neutral-400">
                        Tạo tài khoản để mua sắm và theo dõi đơn hàng dễ dàng hơn
                    </p>
                </div>

                <!-- Register Form -->
                <form id="signupForm" class="space-y-6" action="#" method="POST">
                    <!-- Name Fields -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label for="firstName" class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-2">
                                Họ
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fas fa-user text-slate-400 dark:text-neutral-500"></i>
                                </div>
                                <input 
                                    type="text" 
                                    id="firstName" 
                                    name="firstName" 
                                    placeholder="Nhập họ" 
                                    required
                                    class="w-full pl-12 pr-4 py-3 border border-slate-300 dark:border-neutral-700 rounded-xl bg-slate-50 dark:bg-neutral-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-orange-500 dark:focus:ring-yellow-500 focus:border-transparent transition-all"
                                >
                            </div>
                        </div>

                        <div>
                            <label for="lastName" class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-2">
                                Tên
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <i class="fas fa-user text-slate-400 dark:text-neutral-500"></i>
                                </div>
                                <input 
                                    type="text" 
                                    id="lastName" 
                                    name="lastName" 
                                    placeholder="Nhập tên" 
                                    required
                                    class="w-full pl-12 pr-4 py-3 border border-slate-300 dark:border-neutral-700 rounded-xl bg-slate-50 dark:bg-neutral-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-orange-500 dark:focus:ring-yellow-500 focus:border-transparent transition-all"
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Email Field -->
                    <div>
                        <label for="email" class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-2">
                            Email
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <i class="fas fa-envelope text-slate-400 dark:text-neutral-500"></i>
                            </div>
                            <input 
                                type="email" 
                                id="email" 
                                name="email" 
                                placeholder="Nhập email của bạn" 
                                required
                                class="w-full pl-12 pr-4 py-3 border border-slate-300 dark:border-neutral-700 rounded-xl bg-slate-50 dark:bg-neutral-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-orange-500 dark:focus:ring-yellow-500 focus:border-transparent transition-all"
                            >
                        </div>
                    </div>

                    <!-- Phone Field -->
                    <div>
                        <label for="phone" class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-2">
                            Số điện thoại
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <i class="fas fa-phone text-slate-400 dark:text-neutral-500"></i>
                            </div>
                            <input 
                                type="tel" 
                                id="phone" 
                                name="phone" 
                                placeholder="Nhập số điện thoại" 
                                required
                                class="w-full pl-12 pr-4 py-3 border border-slate-300 dark:border-neutral-700 rounded-xl bg-slate-50 dark:bg-neutral-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-orange-500 dark:focus:ring-yellow-500 focus:border-transparent transition-all"
                            >
                        </div>
                    </div>

                    <!-- Password Field -->
                    <div>
                        <label for="password" class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-2">
                            Mật khẩu
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <i class="fas fa-lock text-slate-400 dark:text-neutral-500"></i>
                            </div>
                            <input 
                                type="password" 
                                id="password" 
                                name="password" 
                                placeholder="Tạo mật khẩu" 
                                required
                                class="w-full pl-12 pr-12 py-3 border border-slate-300 dark:border-neutral-700 rounded-xl bg-slate-50 dark:bg-neutral-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-orange-500 dark:focus:ring-yellow-500 focus:border-transparent transition-all"
                            >
                            <button 
                                type="button" 
                                class="absolute inset-y-0 right-0 pr-4 flex items-center toggle-password"
                            >
                                <i class="fas fa-eye text-slate-400 dark:text-neutral-500 hover:text-orange-500 dark:hover:text-yellow-500 transition-colors"></i>
                            </button>
                        </div>
                        <!-- Password Strength Indicator -->
                        <div class="mt-2">
                            <div class="w-full bg-slate-200 dark:bg-neutral-700 rounded-full h-2">
                                <div class="strength-bar h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
                            </div>
                            <span class="strength-text text-xs text-slate-500 dark:text-neutral-400 mt-1 block">Độ mạnh mật khẩu</span>
                        </div>
                    </div>

                    <!-- Confirm Password Field -->
                    <div>
                        <label for="confirmPassword" class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-2">
                            Xác nhận mật khẩu
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <i class="fas fa-lock text-slate-400 dark:text-neutral-500"></i>
                            </div>
                            <input 
                                type="password" 
                                id="confirmPassword" 
                                name="confirmPassword" 
                                placeholder="Nhập lại mật khẩu" 
                                required
                                class="w-full pl-12 pr-4 py-3 border border-slate-300 dark:border-neutral-700 rounded-xl bg-slate-50 dark:bg-neutral-800 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-orange-500 dark:focus:ring-yellow-500 focus:border-transparent transition-all"
                            >
                        </div>
                    </div>

                    <!-- Terms Checkbox -->
                    <div>
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input 
                                type="checkbox" 
                                name="terms" 
                                required
                                class="w-4 h-4 text-orange-500 dark:text-yellow-500 bg-slate-100 dark:bg-neutral-800 border-slate-300 dark:border-neutral-700 rounded focus:ring-orange-500 dark:focus:ring-yellow-500 focus:ring-2 mt-1"
                            >
                            <span class="text-sm text-slate-600 dark:text-neutral-400">
                                Tôi đồng ý với 
                                <a href="/terms" class="text-orange-500 dark:text-yellow-500 hover:text-orange-600 dark:hover:text-yellow-400 transition-colors font-medium">điều khoản sử dụng</a> 
                                và 
                                <a href="/privacy" class="text-orange-500 dark:text-yellow-500 hover:text-orange-600 dark:hover:text-yellow-400 transition-colors font-medium">chính sách bảo mật</a>
                            </span>
                        </label>
                    </div>

                    <!-- Submit Button -->
                    <button 
                        type="submit" 
                        class="w-full py-3 px-4 bg-gradient-to-r from-orange-500 to-yellow-500 dark:from-yellow-500 dark:to-yellow-400 text-white dark:text-black font-bold text-lg rounded-xl shadow-lg shadow-orange-500/25 dark:shadow-yellow-500/25 hover:shadow-xl hover:shadow-orange-500/40 dark:hover:shadow-yellow-500/40 hover:-translate-y-0.5 transition-all duration-200"
                    >
                        Đăng ký
                    </button>

                    <!-- Social Register -->
                    <div class="mt-8">
                        <div class="relative">
                            <div class="absolute inset-0 flex items-center">
                                <div class="w-full border-t border-slate-300 dark:border-neutral-700"></div>
                            </div>
                            <div class="relative flex justify-center text-sm">
                                <span class="px-4 bg-white dark:bg-neutral-900 text-slate-500 dark:text-neutral-400">Hoặc đăng ký với</span>
                            </div>
                        </div>

                        <div class="mt-6 grid grid-cols-2 gap-3">
                            <button 
                                type="button" 
                                class="w-full inline-flex justify-center items-center gap-2 py-3 px-4 border border-slate-300 dark:border-neutral-700 rounded-xl bg-white dark:bg-neutral-800 text-slate-700 dark:text-neutral-300 hover:bg-slate-50 dark:hover:bg-neutral-700 transition-colors"
                            >
                                <i class="fab fa-google text-red-500"></i>
                                <span class="text-sm font-medium">Google</span>
                            </button>
                            <button 
                                type="button" 
                                class="w-full inline-flex justify-center items-center gap-2 py-3 px-4 border border-slate-300 dark:border-neutral-700 rounded-xl bg-white dark:bg-neutral-800 text-slate-700 dark:text-neutral-300 hover:bg-slate-50 dark:hover:bg-neutral-700 transition-colors"
                            >
                                <i class="fab fa-facebook-f text-blue-600"></i>
                                <span class="text-sm font-medium">Facebook</span>
                            </button>
                        </div>
                    </div>
                </form>

                <!-- Footer -->
                <div class="mt-8 text-center">
                    <p class="text-slate-600 dark:text-neutral-400">
                        Đã có tài khoản? 
                        <a href="/login" class="text-orange-500 dark:text-yellow-500 hover:text-orange-600 dark:hover:text-yellow-400 font-semibold transition-colors">
                            Đăng nhập
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script>
      // Toggle password visibility (giữ nguyên)
      document.querySelectorAll('.toggle-password').forEach(button => {
        button.addEventListener('click', function() {
          const input = this.previousElementSibling;
          const icon = this.querySelector('i');
          if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
          } else {
            input.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
          }
        });
      });

      // Password strength checker (giữ nguyên)
      document.getElementById('password').addEventListener('input', function() {
        const password = this.value;
        const strengthBar = document.querySelector('.strength-bar');
        const strengthText = document.querySelector('.strength-text');
        let strength = 0;
        if (/[a-z]/.test(password)) strength++;
        if (/[A-Z]/.test(password)) strength++;
        if (/[0-9]/.test(password)) strength++;
        if (/[^a-zA-Z0-9]/.test(password)) strength++;
        if (password.length >= 8) strength++;
        const pct = (strength / 5) * 100;
        strengthBar.style.width = pct + '%';
        if (strength < 2) {
          strengthBar.style.backgroundColor = '#ff4444';
          strengthText.textContent = 'Yếu';
        } else if (strength < 4) {
          strengthBar.style.backgroundColor = '#ffa700';
          strengthText.textContent = 'Trung bình';
        } else {
          strengthBar.style.backgroundColor = '#00C851';
          strengthText.textContent = 'Mạnh';
        }
      });

      // === XỬ LÝ FORM ĐĂNG KÝ KẾT NỐI USER-SERVICE ===
      document.getElementById('signupForm').addEventListener('submit', async e => {
        e.preventDefault();

        // Lấy dữ liệu từ form
        const ho = document.getElementById('firstName').value.trim();
        const ten = document.getElementById('lastName').value.trim();
        const email = document.getElementById('email').value.trim();
        const sdt = document.getElementById('phone').value.trim();
        const matKhau = document.getElementById('password').value;
        const xacNhanMatKhau = document.getElementById('confirmPassword').value;
        const diaChi = ''; // Nếu bạn có trường địa chỉ, thêm ID và lấy giá trị

        if (matKhau !== xacNhanMatKhau) {
    return alert('Mật khẩu và xác nhận mật khẩu không khớp. Vui lòng nhập lại.');
  }

        // Build payload đúng controller khachHangController.registerKhachHang
        const hoTen =ho +' '+ten;
        const payload = { hoTen, email, sdt, matKhau, diaChi };

        try {
          const res = await fetch('http://localhost:3002/api/auth/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const json = await res.json();
          if (!res.ok) {
            return alert(json.message || 'Đăng ký thất bại');
          }

          alert('Đăng ký thành công! Vui lòng đăng nhập.');
          window.location.href = '/login';
        } catch (err) {
          console.error(err);
          alert('Lỗi kết nối tới server');
        }
      });
    </script>
</body>
</html>
