<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Phân tích bán hàng - Seller Dashboard</title>
    <meta name="description" content="Phân tích và thống kê bán hàng cho người bán - MegaStore VN">
    
    <!-- Tailwind CSS (CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        if (window.tailwind) { 
            tailwind.config = { 
                darkMode: 'class',
                theme: {
                    extend: {
                        animation: {
                            'fade-in': 'fadeIn 0.5s ease-in',
                            'slide-up': 'slideUp 0.6s ease-out',
                            'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        },
                        keyframes: {
                            fadeIn: {
                                '0%': { opacity: '0' },
                                '100%': { opacity: '1' }
                            },
                            slideUp: {
                                '0%': { transform: 'translateY(20px)', opacity: '0' },
                                '100%': { transform: 'translateY(0)', opacity: '1' }
                            }
                        }
                    }
                }
            } 
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* Custom styles for seller layout */
        .seller-layout {
            display: flex;
            min-height: 100vh;
        }
        .main-content {
            flex: 1;
            margin-left: 16rem; /* 64 * 0.25rem = 16rem */
            margin-top: 0;
            padding-top: 0;
        }
        
        /* Override header styles for seller pages */
        .seller-header {
            position: relative !important;
            z-index: 10 !important;
            margin-bottom: 0 !important;
        }
        
        @media (max-width: 768px) {
            .main-content {
                margin-left: 0;
                padding-top: 1rem;
            }
        }
    </style>
</head>
<body class="bg-gradient-to-br from-emerald-50 via-green-50 to-teal-50 dark:from-slate-900 dark:via-emerald-900 dark:to-green-900 min-h-screen transition-colors duration-300" style="font-family: 'Inter', sans-serif;">
    <div class="seller-layout">
        <!-- Sidebar -->
        <%- include('./../elements/navbarseller') %>
        
        <!-- Main Content -->
        <main class="main-content">
            <!-- Seller Header -->
            <div class="bg-white dark:bg-slate-800 border-b border-emerald-200 dark:border-emerald-700 px-6 py-4">
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Phân tích bán hàng</h1>
                        <p class="text-slate-600 dark:text-neutral-400">Thống kê và phân tích hiệu suất bán hàng</p>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="relative">
                            <button class="p-2 text-slate-600 dark:text-neutral-400 hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">
                                <i class="fas fa-bell text-lg"></i>
                                <span class="absolute -top-1 -right-1 bg-red-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center">2</span>
                            </button>
                        </div>
                        <div class="relative group">
                            <button class="flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-emerald-500 to-green-500 dark:from-green-500 dark:to-emerald-500 text-white rounded-xl font-medium hover:shadow-lg transition-all">
                                <i class="fas fa-store"></i>
                                <span id="seller-username">Seller</span>
                                <i class="fas fa-chevron-down text-sm"></i>
                            </button>
                            <div class="absolute right-0 top-full mt-2 w-48 bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-emerald-200 dark:border-emerald-700 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                                <a href="/" class="flex items-center gap-3 px-4 py-2 text-slate-700 dark:text-neutral-300 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 transition-colors">
                                    <i class="fas fa-home"></i>
                                    <span>Trang chủ</span>
                                </a>
                                <a href="#" onclick="logout()" class="flex items-center gap-3 px-4 py-2 text-slate-700 dark:text-neutral-300 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 transition-colors">
                                    <i class="fas fa-sign-out-alt"></i>
                                    <span>Đăng xuất</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Dashboard Content -->
            <div class="p-6 space-y-8">
                <!-- Date Range Picker -->
                <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                    <div class="flex items-center justify-between">
                        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Khoảng thời gian</h2>
                        <div class="flex items-center gap-2">
                            <button class="px-4 py-2 bg-emerald-500 text-white rounded-xl font-medium hover:bg-emerald-600 transition-colors active" data-range="7">7 ngày</button>
                            <button class="px-4 py-2 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-neutral-300 rounded-xl font-medium hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors" data-range="30">30 ngày</button>
                            <button class="px-4 py-2 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-neutral-300 rounded-xl font-medium hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors" data-range="90">3 tháng</button>
                            <button class="px-4 py-2 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-neutral-300 rounded-xl font-medium hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors" data-range="custom">Tùy chỉnh</button>
                        </div>
                    </div>
                </div>

                <!-- Overview Stats -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-500 to-green-500 flex items-center justify-center">
                                <i class="fas fa-dollar-sign text-white text-xl"></i>
                            </div>
                            <div>
                                <h3 class="text-2xl font-black text-slate-900 dark:text-white" id="totalRevenue">45.5M VNĐ</h3>
                                <p class="text-slate-600 dark:text-neutral-400 font-medium">Tổng doanh thu</p>
                                <p class="text-sm text-emerald-600 dark:text-emerald-400 font-semibold">+15% so với kỳ trước</p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center">
                                <i class="fas fa-shopping-cart text-white text-xl"></i>
                            </div>
                            <div>
                                <h3 class="text-2xl font-black text-slate-900 dark:text-white" id="totalOrders">234</h3>
                                <p class="text-slate-600 dark:text-neutral-400 font-medium">Số đơn hàng</p>
                                <p class="text-sm text-emerald-600 dark:text-emerald-400 font-semibold">+8% so với kỳ trước</p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center">
                                <i class="fas fa-chart-line text-white text-xl"></i>
                            </div>
                            <div>
                                <h3 class="text-2xl font-black text-slate-900 dark:text-white" id="avgOrderValue">195,000 VNĐ</h3>
                                <p class="text-slate-600 dark:text-neutral-400 font-medium">Giá trị trung bình/đơn</p>
                                <p class="text-sm text-emerald-600 dark:text-emerald-400 font-semibold">+5% so với kỳ trước</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charts Section -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <!-- Revenue Chart -->
                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-6">Doanh thu theo thời gian</h3>
                        <div class="h-80">
                            <canvas id="revenueChart"></canvas>
                        </div>
                    </div>

                    <!-- Top Products Chart -->
                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-6">Top sản phẩm bán chạy</h3>
                        <div class="h-80">
                            <canvas id="topProductsChart"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Additional Analytics -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <!-- Customer Analysis -->
                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-6">Phân tích khách hàng</h3>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between p-4 bg-emerald-50 dark:bg-emerald-900/20 rounded-xl">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-emerald-500 flex items-center justify-center">
                                        <i class="fas fa-users text-white"></i>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-slate-900 dark:text-white">Khách hàng mới</p>
                                        <p class="text-sm text-slate-500 dark:text-neutral-400">Trong 30 ngày qua</p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <p class="text-2xl font-bold text-emerald-600 dark:text-emerald-400">45</p>
                                    <p class="text-sm text-emerald-600 dark:text-emerald-400">+12%</p>
                                </div>
                            </div>
                            
                            <div class="flex items-center justify-between p-4 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-blue-500 flex items-center justify-center">
                                        <i class="fas fa-redo text-white"></i>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-slate-900 dark:text-white">Khách hàng quay lại</p>
                                        <p class="text-sm text-slate-500 dark:text-neutral-400">Tỷ lệ quay lại</p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <p class="text-2xl font-bold text-blue-600 dark:text-blue-400">68%</p>
                                    <p class="text-sm text-blue-600 dark:text-blue-400">+3%</p>
                                </div>
                            </div>
                            
                            <div class="flex items-center justify-between p-4 bg-purple-50 dark:bg-purple-900/20 rounded-xl">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-purple-500 flex items-center justify-center">
                                        <i class="fas fa-star text-white"></i>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-slate-900 dark:text-white">Đánh giá trung bình</p>
                                        <p class="text-sm text-slate-500 dark:text-neutral-400">Từ khách hàng</p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <p class="text-2xl font-bold text-purple-600 dark:text-purple-400">4.8</p>
                                    <p class="text-sm text-purple-600 dark:text-purple-400">+0.2</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Sales Channels -->
                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-6">Kênh bán hàng</h3>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <div class="w-3 h-3 rounded-full bg-emerald-500"></div>
                                    <span class="text-slate-700 dark:text-neutral-300">Website chính</span>
                                </div>
                                <div class="flex items-center gap-4">
                                    <div class="w-32 bg-slate-200 dark:bg-slate-700 rounded-full h-2">
                                        <div class="bg-emerald-500 h-2 rounded-full" style="width: 75%"></div>
                                    </div>
                                    <span class="text-sm font-semibold text-slate-900 dark:text-white">75%</span>
                                </div>
                            </div>
                            
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <div class="w-3 h-3 rounded-full bg-blue-500"></div>
                                    <span class="text-slate-700 dark:text-neutral-300">Mobile App</span>
                                </div>
                                <div class="flex items-center gap-4">
                                    <div class="w-32 bg-slate-200 dark:bg-slate-700 rounded-full h-2">
                                        <div class="bg-blue-500 h-2 rounded-full" style="width: 20%"></div>
                                    </div>
                                    <span class="text-sm font-semibold text-slate-900 dark:text-white">20%</span>
                                </div>
                            </div>
                            
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <div class="w-3 h-3 rounded-full bg-purple-500"></div>
                                    <span class="text-slate-700 dark:text-neutral-300">Social Media</span>
                                </div>
                                <div class="flex items-center gap-4">
                                    <div class="w-32 bg-slate-200 dark:bg-slate-700 rounded-full h-2">
                                        <div class="bg-purple-500 h-2 rounded-full" style="width: 5%"></div>
                                    </div>
                                    <span class="text-sm font-semibold text-slate-900 dark:text-white">5%</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        function logout() {
            localStorage.removeItem('authToken');
            localStorage.removeItem('userInfo');
            localStorage.removeItem('hoTen');
            window.location.href = '/';
        }

        // Update seller username
        document.addEventListener('DOMContentLoaded', function() {
            const userName = 'Seller';
            try {
                const userInfo = localStorage.getItem('userInfo');
                if (userInfo) {
                    const userObj = JSON.parse(userInfo);
                    if (userObj.hoTen) userName = userObj.hoTen;
                    else if (userObj.name) userName = userObj.name;
                } else if (localStorage.getItem('hoTen')) {
                    userName = localStorage.getItem('hoTen');
                }
            } catch(e) {}
            const el = document.getElementById('seller-username');
            if (el) el.textContent = userName;
        });

        // Date range picker functionality
        document.addEventListener('DOMContentLoaded', function() {
            const rangeButtons = document.querySelectorAll('[data-range]');
            
            rangeButtons.forEach(button => {
                button.addEventListener('click', function() {
                    // Remove active class from all buttons
                    rangeButtons.forEach(btn => {
                        btn.classList.remove('bg-emerald-500', 'text-white');
                        btn.classList.add('bg-slate-100', 'dark:bg-slate-700', 'text-slate-700', 'dark:text-neutral-300');
                    });
                    
                    // Add active class to clicked button
                    this.classList.remove('bg-slate-100', 'dark:bg-slate-700', 'text-slate-700', 'dark:text-neutral-300');
                    this.classList.add('bg-emerald-500', 'text-white');
                    
                    // Update charts based on selected range
                    updateCharts(this.dataset.range);
                });
            });

            // Initialize charts
            initializeCharts();
        });

        function updateCharts(range) {
            console.log('Updating charts for range:', range);
            // Here you would typically fetch new data based on the selected range
            // For now, we'll just update the existing charts
        }

        function initializeCharts() {
            // Check if Chart.js is loaded
            if (typeof Chart === 'undefined') {
                console.error('Chart.js is not loaded');
                return;
            }
            
            // Revenue Chart
            const revenueCtx = document.getElementById('revenueChart');
            if (!revenueCtx) {
                console.error('Revenue chart canvas not found');
                return;
            }
            
            new Chart(revenueCtx.getContext('2d'), {
                type: 'line',
                data: {
                    labels: ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'],
                    datasets: [{
                        label: 'Doanh thu (VNĐ)',
                        data: [1200000, 1900000, 3000000, 5000000, 2000000, 3000000, 4500000],
                        borderColor: 'rgb(16, 185, 129)',
                        backgroundColor: 'rgba(16, 185, 129, 0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return (value / 1000000).toFixed(1) + 'M';
                                }
                            }
                        }
                    }
                }
            });

            // Top Products Chart
            const topProductsCtx = document.getElementById('topProductsChart');
            if (!topProductsCtx) {
                console.error('Top products chart canvas not found');
                return;
            }
            
            new Chart(topProductsCtx.getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: ['iPhone 15', 'Samsung Galaxy', 'MacBook Pro', 'iPad Air', 'Khác'],
                    datasets: [{
                        data: [35, 25, 20, 15, 5],
                        backgroundColor: [
                            'rgb(16, 185, 129)',
                            'rgb(59, 130, 246)',
                            'rgb(168, 85, 247)',
                            'rgb(245, 158, 11)',
                            'rgb(107, 114, 128)'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                usePointStyle: true
                            }
                        }
                    }
                }
            });
        }
    </script>
</body>
</html>