<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tổng quan - Seller Dashboard</title>
    <meta name="description" content="Dashboard tổng quan cho người bán - MegaStore VN">
    
    <!-- Tailwind CSS (CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        if (window.tailwind) { 
            tailwind.config = { 
                darkMode: 'class',
                theme: {
                    extend: {
                        animation: {
                            'fade-in': 'fadeIn 0.5s ease-in',
                            'slide-up': 'slideUp 0.6s ease-out',
                            'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        },
                        keyframes: {
                            fadeIn: {
                                '0%': { opacity: '0' },
                                '100%': { opacity: '1' }
                            },
                            slideUp: {
                                '0%': { transform: 'translateY(20px)', opacity: '0' },
                                '100%': { transform: 'translateY(0)', opacity: '1' }
                            }
                        }
                    }
                }
            } 
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* Custom styles for seller layout */
        .seller-layout {
            display: flex;
            min-height: 100vh;
        }
        .main-content {
            flex: 1;
            margin-left: 16rem; /* 64 * 0.25rem = 16rem */
            margin-top: 0;
            padding-top: 0;
        }
        
        /* Override header styles for seller pages */
        .seller-header {
            position: relative !important;
            z-index: 10 !important;
            margin-bottom: 0 !important;
        }
        
        @media (max-width: 768px) {
            .main-content {
                margin-left: 0;
                padding-top: 1rem;
            }
        }
    </style>
</head>
<body class="bg-gradient-to-br from-emerald-50 via-green-50 to-teal-50 dark:from-slate-900 dark:via-emerald-900 dark:to-green-900 min-h-screen transition-colors duration-300" style="font-family: 'Inter', sans-serif;">
    <div class="seller-layout">
        <!-- Sidebar -->
        <%- include('./../elements/navbarseller') %>
        
        <!-- Main Content -->
        <main class="main-content">
            <!-- Seller Header -->
            <div class="bg-white dark:bg-slate-800 border-b border-emerald-200 dark:border-emerald-700 px-6 py-4">
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Tổng quan</h1>
                        <p class="text-slate-600 dark:text-neutral-400 mt-1">Chào mừng trở lại, <span id="seller-username">Seller</span></p>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="relative group">
                            <button class="flex items-center gap-3 px-4 py-2 text-slate-600 dark:text-neutral-400 hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">
                                <i class="fas fa-bell"></i>
                                <span class="absolute -top-1 -right-1 w-3 h-3 bg-red-500 rounded-full"></span>
                            </button>
                            <div class="absolute right-0 top-full mt-2 w-48 bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-emerald-200 dark:border-emerald-700 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                                <a href="/" class="flex items-center gap-3 px-4 py-2 text-slate-700 dark:text-neutral-300 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 transition-colors">
                                    <i class="fas fa-home"></i>
                                    <span>Trang chủ</span>
                                </a>
                                <a href="#" onclick="logout()" class="flex items-center gap-3 px-4 py-2 text-slate-700 dark:text-neutral-300 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 transition-colors">
                                    <i class="fas fa-sign-out-alt"></i>
                                    <span>Đăng xuất</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
                <!-- Quick Stats -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-slate-600 dark:text-neutral-400 text-sm font-medium">Đơn hàng mới</p>
                                <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">25</p>
                                <p class="text-emerald-600 dark:text-emerald-400 text-sm font-medium mt-1">+12% so với hôm qua</p>
                            </div>
                            <div class="w-12 h-12 bg-emerald-100 dark:bg-emerald-900/30 rounded-xl flex items-center justify-center">
                                <i class="fas fa-shopping-cart text-emerald-500 text-xl"></i>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-slate-600 dark:text-neutral-400 text-sm font-medium">Doanh thu hôm nay</p>
                                <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">8.5M VNĐ</p>
                                <p class="text-emerald-600 dark:text-emerald-400 text-sm font-medium mt-1">+8% so với hôm qua</p>
                            </div>
                            <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center">
                                <i class="fas fa-dollar-sign text-green-500 text-xl"></i>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-slate-600 dark:text-neutral-400 text-sm font-medium">Khách truy cập</p>
                                <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">1,234</p>
                                <p class="text-emerald-600 dark:text-emerald-400 text-sm font-medium mt-1">+15% so với hôm qua</p>
                            </div>
                            <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center">
                                <i class="fas fa-users text-blue-500 text-xl"></i>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-slate-600 dark:text-neutral-400 text-sm font-medium">Đánh giá mới</p>
                                <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">4.8</p>
                                <p class="text-slate-500 dark:text-neutral-400 text-sm font-medium mt-1">12 đánh giá mới</p>
                            </div>
                            <div class="w-12 h-12 bg-yellow-100 dark:bg-yellow-900/30 rounded-xl flex items-center justify-center">
                                <i class="fas fa-star text-yellow-500 text-xl"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Activity -->
                <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 overflow-hidden">
                    <div class="px-6 py-4 border-b border-emerald-200 dark:border-emerald-700">
                        <div class="flex items-center justify-between">
                            <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Hoạt động gần đây</h3>
                            <a href="#" class="text-emerald-600 dark:text-emerald-400 hover:text-emerald-700 dark:hover:text-emerald-300 text-sm font-medium transition-colors">Xem tất cả</a>
                        </div>
                    </div>
                    <div class="p-6 space-y-4">
                        <div class="flex items-center gap-4 p-4 bg-slate-50 dark:bg-slate-700/50 rounded-xl">
                            <div class="w-10 h-10 bg-emerald-100 dark:bg-emerald-900/30 rounded-lg flex items-center justify-center">
                                <i class="fas fa-shopping-bag text-emerald-500"></i>
                            </div>
                            <div class="flex-1">
                                <p class="font-medium text-slate-900 dark:text-white">Đơn hàng mới #12345</p>
                                <p class="text-sm text-slate-500 dark:text-neutral-400">5 phút trước</p>
                            </div>
                            <div class="text-emerald-600 dark:text-emerald-400 font-semibold">
                                +500,000 VNĐ
                            </div>
                        </div>
                        
                        <div class="flex items-center gap-4 p-4 bg-slate-50 dark:bg-slate-700/50 rounded-xl">
                            <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center">
                                <i class="fas fa-comment text-blue-500"></i>
                            </div>
                            <div class="flex-1">
                                <p class="font-medium text-slate-900 dark:text-white">Đánh giá mới cho sản phẩm "Điện thoại XYZ"</p>
                                <p class="text-sm text-slate-500 dark:text-neutral-400">30 phút trước</p>
                            </div>
                            <div class="flex items-center gap-1">
                                <i class="fas fa-star text-yellow-400"></i>
                                <i class="fas fa-star text-yellow-400"></i>
                                <i class="fas fa-star text-yellow-400"></i>
                                <i class="fas fa-star text-yellow-400"></i>
                                <i class="fas fa-star text-yellow-400"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sales Chart -->
                <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 overflow-hidden">
                    <div class="px-6 py-4 border-b border-emerald-200 dark:border-emerald-700">
                        <div class="flex items-center justify-between">
                            <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Biểu đồ doanh số</h3>
                            <div class="flex gap-2">
                                <button class="px-4 py-2 bg-emerald-500 text-white rounded-lg text-sm font-medium hover:bg-emerald-600 transition-colors">7 ngày</button>
                                <button class="px-4 py-2 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-neutral-300 rounded-lg text-sm font-medium hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors">30 ngày</button>
                                <button class="px-4 py-2 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-neutral-300 rounded-lg text-sm font-medium hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors">3 tháng</button>
                            </div>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="h-80 bg-slate-50 dark:bg-slate-700/50 rounded-xl flex items-center justify-center">
                            <div class="text-center">
                                <i class="fas fa-chart-line text-4xl text-slate-400 dark:text-neutral-500 mb-4"></i>
                                <p class="text-slate-500 dark:text-neutral-400">Biểu đồ doanh số sẽ được hiển thị tại đây</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Update seller username
            const userInfo = JSON.parse(localStorage.getItem("userInfo") || "{}");
            let userName = 'Seller';
            try {
                if (userInfo && userInfo.hoTen) userName = userInfo.hoTen;
                else if (userInfo && userInfo.name) userName = userInfo.name;
            } catch(e) {}
            const el = document.getElementById('seller-username');
            if (el) el.textContent = userName;
        });

        function logout() {
            localStorage.removeItem('authToken');
            localStorage.removeItem('userInfo');
            localStorage.removeItem('hoTen');
            window.location.href = '/';
        }
    </script>
</body>
</html>