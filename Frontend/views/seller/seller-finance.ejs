<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tài chính - Seller Dashboard</title>
    <meta name="description" content="Quản lý tài chính cho người bán - MegaStore VN">
    
    <!-- Tailwind CSS (CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        if (window.tailwind) { 
            tailwind.config = { 
                darkMode: 'class',
                theme: {
                    extend: {
                        animation: {
                            'fade-in': 'fadeIn 0.5s ease-in',
                            'slide-up': 'slideUp 0.6s ease-out',
                            'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        },
                        keyframes: {
                            fadeIn: {
                                '0%': { opacity: '0' },
                                '100%': { opacity: '1' }
                            },
                            slideUp: {
                                '0%': { transform: 'translateY(20px)', opacity: '0' },
                                '100%': { transform: 'translateY(0)', opacity: '1' }
                            }
                        }
                    }
                }
            } 
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        /* Custom styles for seller layout */
        .seller-layout {
            display: flex;
            min-height: 100vh;
        }
        .main-content {
            flex: 1;
            margin-left: 16rem; /* 64 * 0.25rem = 16rem */
            margin-top: 0;
            padding-top: 0;
        }
        
        /* Override header styles for seller pages */
        .seller-header {
            position: relative !important;
            z-index: 10 !important;
            margin-bottom: 0 !important;
        }
        
        @media (max-width: 768px) {
            .main-content {
                margin-left: 0;
                padding-top: 1rem;
            }
        }
    </style>
</head>
<body class="bg-gradient-to-br from-emerald-50 via-green-50 to-teal-50 dark:from-slate-900 dark:via-emerald-900 dark:to-green-900 min-h-screen transition-colors duration-300" style="font-family: 'Inter', sans-serif;">
    <div class="seller-layout">
        <!-- Sidebar -->
        <%- include('./../elements/navbarseller') %>
        
        <!-- Main Content -->
        <main class="main-content">
            <!-- Seller Header -->
            <div class="bg-white dark:bg-slate-800 border-b border-emerald-200 dark:border-emerald-700 px-6 py-4">
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Tài chính</h1>
                        <p class="text-slate-600 dark:text-neutral-400 mt-1">Quản lý tài chính và giao dịch</p>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="relative group">
                            <button class="flex items-center gap-3 px-4 py-2 bg-emerald-500 text-white rounded-xl font-medium hover:bg-emerald-600 transition-colors">
                                <i class="fas fa-download"></i>
                                <span>Xuất báo cáo</span>
                            </button>
                        </div>
                        <div class="relative group">
                            <button class="flex items-center gap-3 px-4 py-2 text-slate-600 dark:text-neutral-400 hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">
                                <i class="fas fa-bell"></i>
                                <span class="absolute -top-1 -right-1 w-3 h-3 bg-red-500 rounded-full"></span>
                            </button>
                            <div class="absolute right-0 top-full mt-2 w-48 bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-emerald-200 dark:border-emerald-700 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                                <a href="/" class="flex items-center gap-3 px-4 py-2 text-slate-700 dark:text-neutral-300 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 transition-colors">
                                    <i class="fas fa-home"></i>
                                    <span>Trang chủ</span>
                                </a>
                                <a href="#" onclick="logout()" class="flex items-center gap-3 px-4 py-2 text-slate-700 dark:text-neutral-300 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 transition-colors">
                                    <i class="fas fa-sign-out-alt"></i>
                                    <span>Đăng xuất</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Dashboard Content -->
            <div class="p-6 space-y-8">

                <!-- Finance Stats -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-slate-600 dark:text-neutral-400 text-sm font-medium">Số dư khả dụng</p>
                                <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">12.5M VNĐ</p>
                            </div>
                            <div class="w-12 h-12 bg-emerald-100 dark:bg-emerald-900/30 rounded-xl flex items-center justify-center">
                                <i class="fas fa-wallet text-emerald-500 text-xl"></i>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-slate-600 dark:text-neutral-400 text-sm font-medium">Đang chờ giải ngân</p>
                                <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">5.2M VNĐ</p>
                            </div>
                            <div class="w-12 h-12 bg-yellow-100 dark:bg-yellow-900/30 rounded-xl flex items-center justify-center">
                                <i class="fas fa-clock text-yellow-500 text-xl"></i>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-slate-600 dark:text-neutral-400 text-sm font-medium">Doanh thu tháng này</p>
                                <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">45.5M VNĐ</p>
                            </div>
                            <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center">
                                <i class="fas fa-chart-line text-green-500 text-xl"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Finance Actions -->
                <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 p-6">
                    <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Thao tác nhanh</h3>
                    <div class="flex flex-wrap gap-4">
                        <button class="flex items-center gap-3 px-6 py-3 bg-emerald-500 text-white rounded-xl font-medium hover:bg-emerald-600 transition-colors">
                            <i class="fas fa-wallet"></i>
                            <span>Rút tiền</span>
                        </button>
                        <button class="flex items-center gap-3 px-6 py-3 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-neutral-300 rounded-xl font-medium hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors">
                            <i class="fas fa-history"></i>
                            <span>Lịch sử giao dịch</span>
                        </button>
                        <button class="flex items-center gap-3 px-6 py-3 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-xl font-medium hover:bg-blue-200 dark:hover:bg-blue-900/50 transition-colors">
                            <i class="fas fa-chart-bar"></i>
                            <span>Báo cáo chi tiết</span>
                        </button>
                    </div>
                </div>

                <!-- Transaction History -->
                <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-emerald-500/5 border border-emerald-200 dark:border-emerald-700 overflow-hidden">
                    <div class="px-6 py-4 border-b border-emerald-200 dark:border-emerald-700">
                        <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Lịch sử giao dịch gần đây</h3>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="bg-slate-50 dark:bg-slate-700">
                                <tr>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-slate-500 dark:text-neutral-400 uppercase tracking-wider">Mã giao dịch</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-slate-500 dark:text-neutral-400 uppercase tracking-wider">Ngày</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-slate-500 dark:text-neutral-400 uppercase tracking-wider">Loại</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-slate-500 dark:text-neutral-400 uppercase tracking-wider">Số tiền</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-slate-500 dark:text-neutral-400 uppercase tracking-wider">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-emerald-200 dark:divide-emerald-700">
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900 dark:text-white">#TRX001</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-neutral-400">20/03/2024</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-neutral-400">Rút tiền</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-red-600 dark:text-red-400">-5,000,000 VNĐ</td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400">
                                            Thành công
                                        </span>
                                    </td>
                                </tr>
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900 dark:text-white">#TRX002</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-neutral-400">19/03/2024</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-neutral-400">Nhận tiền</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-green-600 dark:text-green-400">+2,500,000 VNĐ</td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400">
                                            Thành công
                                        </span>
                                    </td>
                                </tr>
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900 dark:text-white">#TRX003</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-neutral-400">18/03/2024</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-neutral-400">Rút tiền</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-red-600 dark:text-red-400">-1,000,000 VNĐ</td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-400">
                                            Đang xử lý
                                        </span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Update seller username
            const userInfo = JSON.parse(localStorage.getItem("userInfo") || "{}");
            let userName = 'Seller';
            try {
                if (userInfo && userInfo.hoTen) userName = userInfo.hoTen;
                else if (userInfo && userInfo.name) userName = userInfo.name;
            } catch(e) {}
            const el = document.getElementById('seller-username');
            if (el) el.textContent = userName;
        });

        function logout() {
            localStorage.removeItem('authToken');
            localStorage.removeItem('userInfo');
            localStorage.removeItem('hoTen');
            window.location.href = '/';
        }
    </script>
</body>
</html>