<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mã giảm giá - Seller Dashboard</title>
    <meta name="description" content="Quản lý mã giảm giá cho người bán - MegaStore VN">
    
    <!-- Tailwind CSS (CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        if (window.tailwind) { 
            tailwind.config = { 
                darkMode: 'class',
                theme: {
                    extend: {
                        animation: {
                            'fade-in': 'fadeIn 0.5s ease-in',
                            'slide-up': 'slideUp 0.6s ease-out',
                            'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        },
                        keyframes: {
                            fadeIn: {
                                '0%': { opacity: '0' },
                                '100%': { opacity: '1' }
                            },
                            slideUp: {
                                '0%': { transform: 'translateY(20px)', opacity: '0' },
                                '100%': { transform: 'translateY(0)', opacity: '1' }
                            }
                        }
                    }
                }
            } 
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
     <style>
         /* Custom styles for seller layout */
         .seller-layout {
             display: flex;
             min-height: 100vh;
         }
         .main-content {
             flex: 1;
             margin-left: 16rem; /* 64 * 0.25rem = 16rem */
             margin-top: 0;
             padding-top: 0;
         }
         .main-contentt {
             flex: 1;
             margin-left: 0; /* 64 * 0.25rem = 16rem */
             margin-top: 0;
             padding-top: 0;
         }
         /* Override header styles for seller pages */
         .seller-header {
             position: relative !important;
             z-index: 10 !important;
             margin-bottom: 0 !important;
         }
         
         @media (max-width: 768px) {
             .main-content {
                 margin-left: 0;
                 padding-top: 1rem;
             }
         }

         /* Promotion form styling */
         .promotion-form {
             background: white;
             border-radius: 12px;
             box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
             padding: 24px;
             margin: 20px 24px;
             border: 1px solid #e5e7eb;
             width: calc(100% - 48px);
         }

         .form-group {
             margin-bottom: 20px;
         }

         .form-group label {
             display: block;
             font-weight: 600;
             color: #374151;
             margin-bottom: 8px;
             font-size: 14px;
         }

         .form-group input,
         .form-group select {
             width: 100%;
             padding: 12px 16px;
             border: 2px solid #e5e7eb;
             border-radius: 8px;
             font-size: 14px;
             transition: all 0.2s;
             background: white;
         }

         .form-group input:focus,
         .form-group select:focus {
             outline: none;
             border-color: #10b981;
             box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
         }

         .form-row {
             display: grid;
             grid-template-columns: 1fr 1fr;
             gap: 20px;
         }

         .form-actions {
             display: flex;
             gap: 12px;
             margin-top: 24px;
             padding-top: 20px;
             border-top: 1px solid #e5e7eb;
         }

         .btn-primary {
             background: linear-gradient(135deg, #10b981, #059669);
             color: white;
             border: none;
             padding: 10px 20px;
             border-radius: 8px;
             font-weight: 600;
             cursor: pointer;
             transition: all 0.2s;
             font-size: 14px;
             white-space: nowrap;
         }

         .btn-primary:hover {
             transform: translateY(-1px);
             box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
         }

         .btn-secondary {
             background: #f3f4f6;
             color: #374151;
             border: 2px solid #e5e7eb;
             padding: 12px 24px;
             border-radius: 8px;
             font-weight: 600;
             cursor: pointer;
             transition: all 0.2s;
             flex: 1;
         }

         .btn-secondary:hover {
             background: #e5e7eb;
         }

         /* Section header */
         .section-header {
             display: flex;
             justify-content: flex-end;
             align-items: center;
             margin-bottom: 24px;
             padding: 16px 24px;
             border-bottom: 2px solid #f3f4f6;
             width: 100%;
         }

         .section-header h2 {
             font-size: 24px;
             font-weight: 700;
             color: #111827;
             margin: 0;
         }

         .section-header h3 {
             font-size: 18px;
             font-weight: 600;
             color: #374151;
             margin: 0;
         }

         /* Promotions list */
         .promotions-list {
             background: white;
             border-radius: 12px;
             box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
             margin: 20px 24px;
             overflow: hidden;
             border: 1px solid #e5e7eb;
             width: calc(100% - 48px);
         }

         .promotions-grid {
             display: flex;
             flex-wrap: wrap;
             gap: 24px;
             padding: 24px;
             width: 100%;
         }

         /* Promotion card */
         .promotion-card {
             background: white;
             border: 2px solid #e5e7eb;
             border-radius: 12px;
             padding: 20px;
             transition: all 0.2s;
             position: relative;
             flex: 1;
             min-width: 300px;
             max-width: 500px;
         }

         .promotion-card:hover {
             transform: translateY(-2px);
             box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
             border-color: #10b981;
         }

         .promotion-card.expired {
             opacity: 0.6;
             background: #f9fafb;
         }

         .promotion-header {
             display: flex;
             justify-content: space-between;
             align-items: center;
             margin-bottom: 16px;
         }

         .promotion-header h4 {
             font-size: 18px;
             font-weight: 700;
             color: #111827;
             margin: 0;
         }

         .promotion-code {
             background: linear-gradient(135deg, #10b981, #059669);
             color: white;
             padding: 6px 12px;
             border-radius: 20px;
             font-size: 12px;
             font-weight: 600;
         }

         .promotion-details {
             margin-bottom: 16px;
         }

         .promotion-details p {
             margin: 8px 0;
             color: #6b7280;
             font-size: 14px;
             display: flex;
             align-items: center;
             gap: 8px;
         }

         .promotion-details i {
             color: #10b981;
             width: 16px;
         }

         .promotion-actions {
             display: flex;
             gap: 8px;
         }

         .btn-icon {
             padding: 8px 12px;
             border: none;
             border-radius: 6px;
             cursor: pointer;
             transition: all 0.2s;
             font-size: 14px;
         }

         .btn-icon.edit {
             background: #dbeafe;
             color: #2563eb;
         }

         .btn-icon.edit:hover {
             background: #bfdbfe;
         }

         .btn-icon.delete {
             background: #fee2e2;
             color: #dc2626;
         }

         .btn-icon.delete:hover {
             background: #fecaca;
         }

         /* Content container */
         .content-section {
             width: 100%;
             margin: 0;
             padding: 0;
         }

         /* Responsive */
         @media (max-width: 768px) {
             .form-row {
                 grid-template-columns: 1fr;
             }
             
             .promotions-grid {
                 flex-direction: column;
                 padding: 16px;
             }

             .promotion-card {
                 min-width: unset;
                 max-width: unset;
                 flex: none;
             }
             
             .section-header {
                 flex-direction: column;
                 align-items: flex-start;
                 gap: 16px;
                 padding-left: 16px;
                 padding-right: 16px;
             }

             .content-section {
                 padding: 0;
             }

             .promotion-form {
                 margin: 20px 16px;
                 padding: 20px;
                 width: calc(100% - 32px);
             }

             .promotions-list {
                 margin: 20px 16px;
                 width: calc(100% - 32px);
             }

             .section-header {
                 padding: 16px;
             }
         }
     </style>
</head>
<body class="bg-gradient-to-br from-emerald-50 via-green-50 to-teal-50 dark:from-slate-900 dark:via-emerald-900 dark:to-green-900 min-h-screen transition-colors duration-300" style="font-family: 'Inter', sans-serif;">
    <div class="seller-layout">
        <!-- Sidebar -->
        <%- include('./../elements/navbarseller') %>
        
        <!-- Main Content -->
        <main class="main-content">
            <!-- Seller Header -->
            <div class="bg-white dark:bg-slate-800 border-b border-emerald-200 dark:border-emerald-700 px-6 py-4">
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Mã giảm giá</h1>
                        <p class="text-slate-600 dark:text-neutral-400">Quản lý mã giảm giá và khuyến mãi</p>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="relative">
                            <button class="p-2 text-slate-600 dark:text-neutral-400 hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">
                                <i class="fas fa-bell text-lg"></i>
                                <span class="absolute -top-1 -right-1 bg-red-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center">2</span>
                            </button>
                        </div>
                        <div class="relative group">
                            <button class="flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-emerald-500 to-green-500 dark:from-green-500 dark:to-emerald-500 text-white rounded-xl font-medium hover:shadow-lg transition-all">
                                <i class="fas fa-store"></i>
                                <span id="seller-username">Seller</span>
                                <i class="fas fa-chevron-down text-sm"></i>
                            </button>
                            <div class="absolute right-0 top-full mt-2 w-48 bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-emerald-200 dark:border-emerald-700 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                                <a href="/" class="flex items-center gap-3 px-4 py-2 text-slate-700 dark:text-neutral-300 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 transition-colors">
                                    <i class="fas fa-home"></i>
                                    <span>Trang chủ</span>
                                </a>
                                <a href="#" onclick="logout()" class="flex items-center gap-3 px-4 py-2 text-slate-700 dark:text-neutral-300 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 transition-colors">
                                    <i class="fas fa-sign-out-alt"></i>
                                    <span>Đăng xuất</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            
            <!-- Dashboard Content -->
            <div class="p-6 space-y-8">
<main class="main-contentt">
    <section id="promotion" class="content-section">
      <div class="section-header">
        
        <button class="btn-primary" id="addPromotionBtn">
          <i class="fas fa-plus"></i> Tạo mã giảm giá mới
        </button>
      </div>
                <!-- Promotion Form -->
                 <form id="promotionForm" class="promotion-form" style="display: none;">
        <div class="form-group">
          <input type="hidden" name="maUserBan" id="maUserBan"  />
        </div>
        <div class="form-group">
          <label>Tên mã giảm giá</label>
          <input type="text" name="tenKM" required />
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Mã giảm giá</label>
            <input type="text" name="ma" required />
          </div>
          <div class="form-group">
            <label>Loại giảm giá</label>
            <select name="loaiGiamGia" required>
              <option value="phanTram">Phần trăm</option>
              <option value="soTien">Số tiền cố định</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Giá trị giảm</label>
          <input type="number" name="giaTriGiam" required />
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Ngày bắt đầu</label>
            <input type="date" name="ngayBatDau" required />
          </div>
          <div class="form-group">
            <label>Ngày kết thúc</label>
            <input type="date" name="ngayKetThuc" required />
          </div>
        </div>
        <div class="form-group">
          <label>Đơn hàng tối thiểu</label>
          <input type="number" name="donHangToiThieu" />
        </div>
        <div class="form-actions">
          <button type="submit" class="btn-primary">Lưu mã giảm giá</button>
          <button type="button" class="btn-secondary" id="cancelPromotionBtn">Hủy</button>
        </div>
      </form>

      <!-- Danh sách mã giảm giá -->
      <div class="promotions-list">
        <div class="section-header">
          <h3>Mã giảm giá đang hoạt động</h3>
        </div>
        <div class="promotions-grid" id="activePromos"></div>
      </div>

      <div class="promotions-list">
        <div class="section-header">
          <h3>Mã giảm giá đã hết hạn</h3>
        </div>
        <div class="promotions-grid" id="expiredPromos"></div>
      </div>
    </section>
  </main>

  <script>
    const addPromotionBtn = document.getElementById('addPromotionBtn');
    const promotionForm = document.getElementById('promotionForm');
    const cancelPromotionBtn = document.getElementById('cancelPromotionBtn');

    const userInfo = JSON.parse(localStorage.getItem('userInfo'));
    const userBanId =userInfo.userBanId;
      document.getElementById('maUserBan').value = userBanId;


    addPromotionBtn.addEventListener('click', () => {
      promotionForm.reset();
      delete promotionForm.dataset.editingId; // xoa thuoc tinh data-edittingId
      promotionForm.style.display = 'block'; // hien thi form
      promotionForm.scrollIntoView({ behavior: 'smooth' }); // cuon trang toi vi tri form
    });

    cancelPromotionBtn.addEventListener('click', () => {
      promotionForm.style.display = 'none';
      promotionForm.reset();
      delete promotionForm.dataset.editingId;
    });

    promotionForm.addEventListener('submit', async (e) => {
      const token = localStorage.getItem('authToken');
      e.preventDefault();
      const formData = new FormData(promotionForm);
      const payload = Object.fromEntries(formData.entries());

      const editingId = promotionForm.dataset.editingId;

      const method = editingId ? 'PUT' : 'POST';
      const url = editingId
        ? `http://localhost:3001/api/khuyenmai/${editingId}`
        : `http://localhost:3001/api/khuyenmai`;

      try {
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' ,
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(payload),
        });

        const result = await res.json();
        if (!res.ok) throw new Error(result.error || 'Lỗi server');

        alert(editingId ? '✅ Cập nhật thành công' : '✅ Tạo mã giảm giá thành công');
        promotionForm.reset();
        delete promotionForm.dataset.editingId;
        promotionForm.style.display = 'none';
        loadPromotions();
      } catch (err) {
        alert('❌ ' + err.message);
      }
    });

    async function loadPromotions() {
  try {
    const token = localStorage.getItem('authToken');
      const res = await fetch('http://localhost:3001/api/khuyenmai', {
    headers: {
      'Authorization': `Bearer ${token}`, // Gửi token qua header
    }
  })
    // if (!res.ok) throw new Error('Không thể tải khuyến mãi');
    // Nhận về đúng hai mảng đã được phân loại ở backend
    const { active, expired } = await res.json();

    // Hàm render chung cho 1 promotion card
    const renderCard = (km, isExpired = false) => `
      <div class="promotion-card${isExpired ? ' expired' : ''}">
        <div class="promotion-header">
          <h4>${km.displayDiscount}</h4>
          <span class="promotion-code">${km.ma}</span>
        </div>
        <div class="promotion-details">
          <p><i class="fas fa-calendar"></i> ${km.period}</p>
          <p><i class="fas fa-tag"></i> Đơn tối thiểu: ${km.donHangToiThieu}</p>
        </div>
        <div class="promotion-actions">
          <button class="btn-icon edit" data-id="${km.id}"><i class="fas fa-edit"></i></button>
          <button class="btn-icon delete" data-id="${km.id}"><i class="fas fa-trash"></i></button>
        </div>
      </div>`;

    // Render active (không có class expired)
    const activeHtml = active.map(km => renderCard(km, false)).join('');
    document.getElementById('activePromos').innerHTML = activeHtml || '<p>Chưa có mã nào.</p>';

    // Render expired (có class expired để CSS làm mờ)
    const expiredHtml = expired.map(km => renderCard(km, true)).join('');
    document.getElementById('expiredPromos').innerHTML = expiredHtml || '<p>Chưa có mã nào hết hạn.</p>';

  } catch (err) {
    // alert('❌ ' + err.message);
  }
}


    async function deletePromotion(id) {
      const token = localStorage.getItem('authToken');
      const isConfirmed = confirm('Bạn có chắc chắn muốn xóa mã giảm giá này?');
      if (!isConfirmed) return;

      try {
        const res = await fetch(`http://localhost:3001/api/khuyenmai/${id}`, { method: 'DELETE',
        headers: {
    'Authorization': `Bearer ${token}`
  },
         });
        const result = await res.json();
        if (!res.ok) throw new Error(result.error || 'Lỗi server');
        document.querySelector(`.promotion-card button.delete[data-id="${id}"]`)?.closest('.promotion-card')?.remove();
        alert('✅ Xóa thành công');
      } catch (err) {
        alert('❌ ' + err.message);
      }
    }

    async function editPromotion(id) {
      const token = localStorage.getItem('authToken');
      try {
        const res = await fetch(`http://localhost:3001/api/khuyenmai/${id}`,{
          headers: {
    'Authorization': `Bearer ${token}`
  },
        });
        if (!res.ok) throw new Error('Không tìm thấy mã khuyến mãi');
        const km = await res.json();

        promotionForm.style.display = 'block';
        promotionForm.scrollIntoView({ behavior: 'smooth' });
        promotionForm.dataset.editingId = id;

        promotionForm.maUserBan.value = km.maUserBan || '';
        promotionForm.tenKM.value = km.tenKM || '';
        promotionForm.ma.value = km.ma || '';
        promotionForm.loaiGiamGia.value = km.loaiGiamGia || '';
        promotionForm.giaTriGiam.value = km.giaTriGiam || '';
        promotionForm.ngayBatDau.value = km.ngayBatDau?.slice(0,10) || '';
        promotionForm.ngayKetThuc.value = km.ngayKetThuc?.slice(0,10) || '';
        promotionForm.donHangToiThieu.value = km.donHangToiThieu || '';
      } catch (err) {
        alert('❌ ' + err.message);
      }
    }

    document.addEventListener('click', (e) => {
      const deleteBtn = e.target.closest('.delete');
      const editBtn = e.target.closest('.edit');
      if (deleteBtn) deletePromotion(deleteBtn.dataset.id);
      if (editBtn) editPromotion(editBtn.dataset.id);
    });
function logout() {
                localStorage.removeItem('authToken');
                localStorage.removeItem('userInfo');
                localStorage.removeItem('hoTen');
                window.location.href = '/';
            }
    window.addEventListener('DOMContentLoaded', loadPromotions);
  </script>
</body>
</html>
