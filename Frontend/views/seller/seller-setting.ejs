                            </div>
                            
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 dark:text-neutral-300 mb-2">
                                    Logo cửa hàng
                                </label>
                                <div class="flex items-center gap-4">
                                    <div class="w-20 h-20 rounded-xl overflow-hidden border-2 border-emerald-200 dark:border-emerald-700">
                                        <img id="shop-logo" src="/images/store-logo.jpg" alt="Store Logo" class="w-full h-full object-cover">
                                    </div>
                                    <div>
                                        <input type="file" id="shop-logo-input" accept="image/*" class="hidden">
                                        <button type="button" class="px-4 py-2 bg-emerald-500 text-white rounded-xl hover:bg-emerald-600 transition-colors" onclick="document.getElementById('shop-logo-input').click()">
