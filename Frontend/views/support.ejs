    <!-- Bootstrap Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Custom JavaScript -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize Bootstrap components
            var triggerTabList = [].slice.call(document.querySelectorAll('.list-group-item'))
            triggerTabList.forEach(function(triggerEl) {
                triggerEl.addEventListener('click', function(e) {
                    e.preventDefault();
                    // Remove active class from all items
                    triggerTabList.forEach(item => item.classList.remove('active'));
                    // Add active class to clicked item
                    this.classList.add('active');
                });
            });

            const supportInvoiceForm = document.getElementById('support-invoice-form');
            if (supportInvoiceForm) {
                const orderIdInput = document.getElementById('support-invoice-order-id');
                const fileInput = document.getElementById('support-invoice-file');
                const submitBtn = document.getElementById('support-invoice-submit');
                const errorEl = document.getElementById('support-invoice-error');
                const resultContainer = document.getElementById('support-invoice-result');
                const placeholder = document.getElementById('support-invoice-placeholder');
                const statusEl = document.getElementById('support-invoice-status');
                const detailsEl = document.getElementById('support-invoice-details');
                const rawEl = document.getElementById('support-invoice-raw');
                const linkEl = document.getElementById('support-invoice-link');

                const renderResult = (invoice) => {
                    if (!invoice) {
                        statusEl.textContent = 'Chưa có dữ liệu';
                        detailsEl.innerHTML = '<li>• Không tìm thấy thông tin từ hóa đơn</li>';
                        rawEl.textContent = 'Chưa có nội dung';
                        linkEl.classList.add('d-none');
                        return;
                    }

                    statusEl.textContent = invoice.status === 'processed'
                        ? 'Đã xử lý'
                        : invoice.status === 'failed'
                            ? 'Xử lý thất bại'
                            : 'Đang chờ xử lý';

                    if (invoice.parsed) {
                        const items = [];
                        // Thông tin đơn hàng
                        if (invoice.parsed.orderCode) {
                            items.push(`<strong>📋 Mã đơn:</strong> ${invoice.parsed.orderCode}`);
                        }
                        if (invoice.parsed.date) {
                            items.push(`<strong>📅 Ngày:</strong> ${invoice.parsed.date}`);
                        }
                        if (invoice.parsed.status) {
                            items.push(`<strong>🔄 Trạng thái:</strong> ${invoice.parsed.status}`);
                        }
                        if (invoice.parsed.paymentMethod) {
                            items.push(`<strong>💳 Phương thức:</strong> ${invoice.parsed.paymentMethod.toUpperCase()}`);
                        }
                        
                        // Thông tin khách hàng
                        if (invoice.parsed.customer) {
                            items.push(`<strong>👤 Họ tên:</strong> ${invoice.parsed.customer}`);
                        }
                        if (invoice.parsed.phone) {
                            items.push(`<strong>📞 SĐT:</strong> ${invoice.parsed.phone}`);
                        }
                        if (invoice.parsed.address) {
                            items.push(`<strong>📍 Địa chỉ:</strong> ${invoice.parsed.address}`);
                        }
                        if (invoice.parsed.province) {
                            items.push(`<strong>🏙️ Tỉnh/Thành:</strong> ${invoice.parsed.province}`);
                        }
                        
                        // Sản phẩm
                        if (invoice.parsed.products && invoice.parsed.products.length > 0) {
                            items.push(`<strong>🛍️ Sản phẩm (${invoice.parsed.products.length}):</strong>`);
                            invoice.parsed.products.forEach((product, idx) => {
                                const productPrice = product.price ? `${Number(product.price).toLocaleString('vi-VN')} VNĐ` : '-';
                                const colorLabel = product.color || '-';
                                const sizeLabel = product.size || '-';
                                items.push(`&nbsp;&nbsp;${idx + 1}. ${product.name} - SL: ${product.quantity || 1} - Màu: ${colorLabel} - Kích thước: ${sizeLabel} - Giá: ${productPrice}`);
                            });
                        }
                        
                        // Tổng tiền
                        if (invoice.parsed.total) {
                            const totalNumber = Number(invoice.parsed.total);
                            const formattedTotal = Number.isFinite(totalNumber)
                                ? `${totalNumber.toLocaleString('vi-VN')} VNĐ`
                                : `${invoice.parsed.total} VNĐ`;
                            items.push(`<strong>💰 Tổng tiền:</strong> <span class="text-primary fw-bold">${formattedTotal}</span>`);
                        }

                        detailsEl.innerHTML = items.length
                            ? items.map(item => `<li class="mb-2">${item}</li>`).join('')
                            : '<li>• Không trích xuất được thông tin</li>';
                    } else {
                        detailsEl.innerHTML = '<li>• Không trích xuất được thông tin</li>';
                    }

                    rawEl.textContent = invoice.rawText || 'Không có nội dung OCR';

                    if (invoice.imagePath) {
                        linkEl.href = `http://localhost:3006/${invoice.imagePath}`;
                        linkEl.classList.remove('d-none');
                    } else {
                        linkEl.classList.add('d-none');
                    }
                };

                supportInvoiceForm.addEventListener('submit', async (event) => {
                    event.preventDefault();
                    errorEl.textContent = '';

                    const orderId = orderIdInput.value.trim();
                    const file = fileInput.files[0];

                    if (!orderId) {
                        errorEl.textContent = 'Vui lòng nhập mã đơn hàng trước khi quét hóa đơn.';
                        return;
                    }

                    if (!file) {
                        errorEl.textContent = 'Vui lòng chọn ảnh hóa đơn.';
                        return;
                    }

                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class=\"spinner-border spinner-border-sm me-2\"></span>Đang xử lý...';

                    const formData = new FormData();
                    formData.append('orderId', orderId);
                    formData.append('invoice', file);

                    try {
                        const response = await fetch('http://localhost:3006/api/invoices', {
                            method: 'POST',
                            body: formData
                        });

                        const data = await response.json();

                        if (!response.ok) {
                            renderResult(data.invoice);
                            throw new Error(data.message || 'Không thể xử lý hóa đơn');
                        }

                        renderResult(data.invoice);
                        resultContainer.classList.remove('d-none');
                        placeholder.classList.add('d-none');
                    } catch (err) {
                        errorEl.textContent = err.message || 'Đã xảy ra lỗi khi quét hóa đơn.';
                    } finally {
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = '<i class=\"fas fa-magic me-2\"></i>Quét hóa đơn';
                    }
                });
            }
        });
    </script>
</body>
</html> 